# Phase 0 (crawl) needs no secrets. Phase 1 (enrich/brief) needs an Anthropic key.

# LLM enrichment + brief generation (Phase 1) — Claude Haiku
ANTHROPIC_API_KEY=
# VNNEWS_MODEL=claude-haiku-4-5-20251001

# Embeddings for semantic search (Phase 3) — Gemini gemini-embedding-001.
# Same key/model/dims are used to embed the query at search time.
GEMINI_API_KEY=
# VNNEWS_EMBED_MODEL=gemini-embedding-001
# VNNEWS_EMBED_DIMS=256

# Max articles to enrich per `enrich` run (cost guard)
# VNNEWS_ENRICH_LIMIT=40

# SQLite database path (defaults to ./data/news.db relative to pipeline/)
# VNNEWS_DB_PATH=data/news.db

# Where generated briefs are written (defaults to ../src/content/articles)
# VNNEWS_ARTICLES_DIR=../src/content/articles

# Optional: POST the weekly brief to your email/CRM automation (same var the
# Astro lead system uses). Unset = newsletter notify is skipped.
# LEAD_WEBHOOK_URL=

# Optional: push daily English headlines to a public Telegram channel. Both must
# be set or the Telegram step is skipped. Bot must be an admin of the channel.
# TELEGRAM_BOT_TOKEN=123456:ABC-...
# TELEGRAM_CHANNEL=@yourchannel   # or numeric -100... id

# Override the crawler User-Agent (must stay descriptive + contactable)
# VNNEWS_USER_AGENT=vnmarketinsights-bot/0.1 (+https://vnmarketinsights.com)
