---
// Canonical Layout - Reference-style page with sticky index and utility bar
import BaseLayout from './BaseLayout.astro';
import SectionIndex from '../components/SectionIndex.astro';
import UtilityBar from '../components/UtilityBar.astro';
import ContentSection from '../components/ContentSection.astro';
import AnchorLink from '../components/AnchorLink.astro';
import SourcesSection from '../components/SourcesSection.astro';
import RelatedTopics from '../components/RelatedTopics.astro';

const {
  title,
  description,
  canonicalURL,
  structuredData,
  sections = [],
  sources = [],
  limitations = [],
  lastUpdated,
  publishedDate,
  articleSection,
  relatedTopics = [],
  faqs = [],
  hasTables = false
} = Astro.props;

// BaseLayout now auto-emits Article + Organization + Breadcrumb schema.
// Only the FAQ schema is page-specific — we attach it via structuredData.
const faqSchema = faqs && faqs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    }
  : null;

const extraStructured = [faqSchema, ...(Array.isArray(structuredData) ? structuredData : [structuredData])].filter(Boolean);
const passThroughStructured = extraStructured.length === 1 ? extraStructured[0] : (extraStructured.length > 0 ? extraStructured : undefined);
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  pageType="Article"
  publishedDate={publishedDate || lastUpdated}
  lastUpdated={lastUpdated}
  articleSection={articleSection}
  structuredData={passThroughStructured}
>
  <div class="canonical-page">
    {/* Mobile Section Dropdown */}
    <div class="mobile-section-nav">
      <label for="section-select" class="visually-hidden">Jump to section</label>
      <select id="section-select" class="section-dropdown" onchange="document.getElementById(this.value)?.scrollIntoView({behavior: 'smooth'})">
        <option value="">Jump to section...</option>
        {sections.map(section => (
          <option value={section.id}>{section.title}</option>
        ))}
      </select>
    </div>

    <aside class="page-sidebar">
      <SectionIndex sections={sections} />
    </aside>

    <main class="page-content">
      <UtilityBar title={title} hasTables={hasTables} />

      <article class="reference-article">
        <slot />

        {faqs.length > 0 && (
          <ContentSection id="faq">
            <h2>
              Frequently Asked Questions
              <AnchorLink id="faq" />
            </h2>
            <div class="faq-list">
              {faqs.map(faq => (
                <details class="faq-item">
                  <summary class="faq-question">{faq.question}</summary>
                  <div class="faq-answer-container">
                    <p class="faq-answer">{faq.answer}</p>
                  </div>
                </details>
              ))}
            </div>
          </ContentSection>
        )}

        {/* Related Topics - Before Sources */}
        {relatedTopics.length > 0 && (
          <RelatedTopics topics={relatedTopics} />
        )}

        {/* Sources Section */}
        <SourcesSection
          sources={sources}
          limitations={limitations}
          lastUpdated={lastUpdated}
        />
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .canonical-page {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    width: 100%;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .mobile-section-nav {
    display: none;
    margin-bottom: 2rem;
  }

  .section-dropdown {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
  }

  .page-sidebar {
    order: 1;
  }

  .page-content {
    order: 2;
    min-width: 0;
    position: relative;
  }

  .reference-article {
    max-width: 680px;
  }

  .reference-article h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  .reference-article h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .reference-article h3 {
    font-size: 1.125rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .reference-article p {
    margin-bottom: 1.25rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .reference-article ul {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .reference-article li {
    margin-bottom: 0.625rem;
    line-height: 1.6;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-subtle);
  }
  .faq-question {
    cursor: pointer;
    padding: 1rem 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    list-style: none;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    float: right;
    color: var(--color-text-muted);
    font-weight: 400;
  }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container {
    padding: 0 1.25rem 1rem;
    border-top: 1px solid var(--color-border-light);
    margin-top: -1px;
  }
  .faq-answer {
    margin: 1rem 0 0;
    color: var(--color-text);
    line-height: 1.65;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1024px) {
    .canonical-page {
      grid-template-columns: 160px 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .canonical-page {
      grid-template-columns: 1fr;
      padding: 1.5rem 1rem;
    }

    .mobile-section-nav {
      display: block;
    }

    .page-sidebar {
      display: none;
    }

    .reference-article h1 {
      font-size: 1.75rem;
    }

    .reference-article h2 {
      font-size: 1.375rem;
    }
  }
</style>
</content>