---
// Auto-updated "Recent developments" block for topic pages.
// Data is generated by the pipeline (pipeline/vnnews/publish.py) into
// src/data/recent-by-topic.json and committed back via GitHub Actions.
import recent from '../data/recent-by-topic.json';

interface Props {
  /** Site topic slug, e.g. "payments" (must match keys in recent-by-topic.json). */
  topic: string;
  title?: string;
}

interface RecentItem {
  title: string;
  url: string;
  source: string;
  summary_en: string;
  pubDate: string;
  sentiment: number;
  importance: number;
}

const { topic, title = 'Recent developments' } = Astro.props;
const topics = (recent as any).topics ?? {};
const items: RecentItem[] = topics[topic] ?? [];
const generatedAt = (recent as any).generatedAt as string | null;

const fmtDate = (d: string) => {
  const parsed = new Date(d);
  return Number.isNaN(parsed.getTime())
    ? ''
    : parsed.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};
---

{items.length > 0 && (
  <section class="recent-developments" aria-labelledby="recent-dev-heading">
    <h2 id="recent-dev-heading">{title}</h2>
    <p class="recent-dev-note">
      Auto-summarized from public news sources. Neutral, factual, not investment advice.
    </p>
    <ul class="recent-dev-list">
      {items.map((item) => (
        <li class="recent-dev-item">
          <a class="recent-dev-title" href={item.url} target="_blank" rel="noopener nofollow">
            {item.summary_en?.trim() || item.title}
          </a>
          <div class="recent-dev-meta">
            <span class="recent-dev-source">{item.source}</span>
            {fmtDate(item.pubDate) && <span class="recent-dev-date">· {fmtDate(item.pubDate)}</span>}
          </div>
        </li>
      ))}
    </ul>
    {generatedAt && (
      <p class="recent-dev-updated">
        Updated {new Date(generatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    )}
  </section>
)}

<style>
  .recent-developments { margin: 2.5rem 0; }
  .recent-dev-note { color: var(--color-text-muted, #5a5a5a); font-size: 0.875rem; margin: 0.25rem 0 1rem; }
  .recent-dev-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .recent-dev-item {
    padding: 1rem 0;
    border-top: 1px solid var(--color-border, #e5e5e5);
    background: transparent;
  }
  .recent-dev-title { display: block; font-family: var(--font-serif, Georgia, serif); font-size: 1.15rem; font-weight: 600; color: var(--color-text, #1a1a1a); text-decoration: none; line-height: 1.45; }
  .recent-dev-title:hover { color: var(--color-accent, #c0392b); text-decoration: none; }
  .recent-dev-meta { margin-top: 0.5rem; font-size: 0.8125rem; color: var(--color-text-muted, #5a5a5a); }
  .recent-dev-source { font-weight: 500; }
  .recent-dev-updated { margin-top: 1rem; font-size: 0.8125rem; color: var(--color-text-muted, #5a5a5a); }
</style>
