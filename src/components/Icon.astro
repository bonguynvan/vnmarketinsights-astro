---
// Thin-line inline-SVG icon set (no dependency). currentColor + stroke-based so
// icons inherit text color and the broadsheet palette. Replaces emoji across the
// UI. Add new glyphs to PATHS as needed.
interface Props {
  name: string;
  size?: number;
  class?: string;
  title?: string; // when set, icon is labelled; otherwise aria-hidden
}
const { name, size = 20, class: cls, title } = Astro.props;

// Each entry is the inner markup of a 24x24 viewBox (stroke paths).
const PATHS: Record<string, string> = {
  factory: '<path d="M2 20h20M4 20V9l5 3V9l5 3V9l5 3v8"/><path d="M9 20v-4h2v4"/>',
  bank: '<path d="M3 21h18"/><path d="M4 10h16"/><path d="M5 10V7l7-4 7 4v3"/><path d="M6 10v8M10 10v8M14 10v8M18 10v8"/>',
  package: '<path d="M21 8 12 3 3 8v8l9 5 9-5Z"/><path d="m3 8 9 5 9-5"/><path d="M12 13v8"/>',
  "trending-up": '<path d="m3 17 6-6 4 4 8-8"/><path d="M17 7h4v4"/>',
  cart: '<circle cx="9" cy="20" r="1.2"/><circle cx="18" cy="20" r="1.2"/><path d="M2 3h2l2.4 12.4a1 1 0 0 0 1 .8h9.5a1 1 0 0 0 1-.8L21 7H5"/>',
  home: '<path d="m3 11 9-7 9 7"/><path d="M5 10v10h14V10"/><path d="M10 20v-6h4v6"/>',
  newspaper: '<path d="M4 5h13v15H5a1 1 0 0 1-1-1Z"/><path d="M17 8h3v10a1 1 0 0 1-2 0"/><path d="M7 8h7M7 12h7M7 16h5"/>',
  "bar-chart": '<path d="M4 20V10M10 20V4M16 20v-8M22 20H2"/>',
  cpu: '<rect x="7" y="7" width="10" height="10" rx="1"/><path d="M10 11h4v4h-4z"/><path d="M9 2v3M15 2v3M9 19v3M15 19v3M2 9h3M2 15h3M19 9h3M19 15h3"/>',
  warning: '<path d="M10.3 3.3 1.8 18a1 1 0 0 0 .9 1.5h18.6a1 1 0 0 0 .9-1.5L13.7 3.3a1 1 0 0 0-1.7 0Z"/><path d="M12 9v4M12 17h.01"/>',
  camera: '<path d="M3 8h3l2-2h8l2 2h3v11H3Z"/><circle cx="12" cy="13" r="3.2"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  database: '<ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v14c0 1.7 3.6 3 8 3s8-1.3 8-3V5"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>',
  flame: '<path d="M12 3s5 4 5 9a5 5 0 0 1-10 0c0-2 1-3 1-3 .5 2 2 2.5 2 2.5C9 9 12 7 12 3Z"/>',
  radar: '<path d="M19.07 4.93A10 10 0 1 0 21 12"/><path d="M12 12 19 5"/><circle cx="12" cy="12" r="1.3"/>',
  rocket: '<path d="M5 15c-1 1-1.5 4-1.5 4S6.5 18.5 7.5 17.5"/><path d="M9 16c-2-2-2-6 1-9 2.3-2.3 5-2.7 6.5-2.5.2 1.5-.2 4.2-2.5 6.5-3 3-7 3-9 1Z"/><circle cx="14" cy="9" r="1.4"/>',
  check: '<path d="m4 12 5 5L20 6"/>',
  x: '<path d="M5 5l14 14M19 5 5 19"/>',
};

const inner = PATHS[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={["icon", cls]}
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : '') + inner}
/>

<style>
  .icon { display: inline-block; vertical-align: -0.15em; flex-shrink: 0; }
</style>
