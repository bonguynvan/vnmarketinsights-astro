---
// Subscribe CTA. Email collection is paused (no durable serverless store yet),
// so this points readers to the Telegram channel — a zero-signup subscribe path.
// title/description props are accepted for backward compatibility but unused.
interface Props {
  title?: string;
  description?: string;
  source?: string;
}

const { source = 'generic' } = Astro.props;
const TELEGRAM_URL = 'https://t.me/vnmarketinsights';
---

<section class="lead-capture" data-source={source}>
  <h2>Get daily Vietnam market headlines</h2>
  <p>Follow our Telegram channel for a quick daily digest of Vietnam market news — no signup, just tap <strong>Join</strong>.</p>
  <a
    class="lead-capture__cta"
    href={TELEGRAM_URL}
    target="_blank"
    rel="noopener"
    data-track-event="lead_capture_telegram_click"
    data-track-category="acquisition"
    data-track-label={source}
  >
    Join on Telegram →
  </a>
  <p class="lead-capture__meta">Free · leave anytime. Prefer to browse? Read the <a href="/insights">latest insights</a>.</p>
</section>

<style>
  .lead-capture {
    margin-top: var(--space-10);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    background: var(--color-bg-subtle);
  }
  .lead-capture h2 {
    margin: 0 0 var(--space-2) 0;
    border: none;
  }
  .lead-capture p {
    margin: 0 0 var(--space-4) 0;
    color: var(--color-text-muted);
  }
  .lead-capture__cta {
    display: inline-flex;
    align-items: center;
    border-radius: 2px;
    padding: var(--space-3) var(--space-5);
    font-weight: 600;
    color: white;
    background: var(--color-accent);
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .lead-capture__cta:hover { background: var(--color-accent-hover); color: white; }
  .lead-capture__meta {
    margin: var(--space-4) 0 0;
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }
  .lead-capture__meta a { color: var(--color-accent); text-decoration: none; }
  .lead-capture__meta a:hover { text-decoration: underline; }
</style>
