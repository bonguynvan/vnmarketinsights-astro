---
import BaseLayout from '@layouts/BaseLayout.astro';
import BarChart from '@components/BarChart.astro';
import CiteThis from '@components/CiteThis.astro';
import RecentDevelopments from '@components/RecentDevelopments.astro';

const title = "Vietnam Stock Market 2026 — VN-Index, Exchanges & Investment Data";
const description = "Vietnam stock market report: VN-Index and VN30, HOSE/HNX/UPCoM exchanges, market capitalization, foreign ownership, the FTSE Russell emerging-market upgrade (effective Sept 2026), ETFs, and full-year 2025 data with sources.";
const canonicalURL = "https://vnmarketinsights.com/financial-markets";

const faqs = [
  {
    question: "What stock exchanges are in Vietnam?",
    answer: "Vietnam has three trading venues: the Ho Chi Minh City Stock Exchange (HOSE) — the main listed market for large caps; the Hanoi Stock Exchange (HNX) — listed mid-caps and bonds; and the Unlisted Public Company Market (UPCoM) — a secondary venue for public but unlisted companies. All operate under the Vietnam Exchange holding structure."
  },
  {
    question: "What is the VN30 index?",
    answer: "The VN30 tracks the 30 largest and most liquid stocks listed on HOSE by market capitalization and free float. It is the underlying index for VN30 futures and many ETFs, and is commonly used as a benchmark for institutional investors and structured products in Vietnam."
  },
  {
    question: "Who regulates Vietnam's stock market?",
    answer: "The State Securities Commission of Vietnam (SSC), under the Ministry of Finance, is the primary regulator. Clearing and settlement run through the Vietnam Securities Depository (VSD). The Securities Law and supporting decrees define listing, disclosure, and trading rules."
  },
  {
    question: "Can foreign investors trade Vietnamese stocks?",
    answer: "Yes — foreign investors can buy and sell securities through licensed local brokers after obtaining a securities trading code from VSD. Foreign ownership limits apply per sector and per security (often 49% baseline, lower in regulated sectors such as banking), and certain prudential and reporting rules apply. Access improved markedly with the November 2024 non-prefunding model (removing the pre-funding barrier for foreign institutions) and the KRX trading system launched in May 2025."
  },
  {
    question: "Is Vietnam an emerging market? (FTSE Russell upgrade)",
    answer: "Yes — FTSE Russell confirmed on 7 April 2026 that Vietnam is reclassified from Frontier to Secondary Emerging Market, effective from the open on 21 September 2026. It is the first of four phased inclusion tranches running to September 2027, and is estimated to draw roughly US$1.5 billion in initial passive inflows (with active mandates expected to add multiples over the following years). The upgrade followed reforms including the non-prefunding model, the KRX trading platform, and rules letting global investors access the market through their international brokers. MSCI still classifies Vietnam as a frontier market."
  },
  {
    question: "How big is the Vietnam stock market?",
    answer: "The VN-Index closed 2025 near 1,784 points (up about 41%, its strongest year in eight), with total market capitalization around US$387 billion — roughly 84% of GDP — placing Vietnam among the larger Southeast Asian equity markets. Retail investors account for a high share of daily trading turnover relative to institutional participants, a structural feature versus more developed markets."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  mainClass="container"
  pageType="Article"
  articleSection="Financial Markets"
  publishedDate="2026-02-22"
  lastUpdated="2026-07-04"
  structuredData={faqSchema}
>
  <article class="topic-page">
    <header class="topic-header">
      <h1>{title}</h1>
      <p class="topic-lead">Reference overview of Vietnam's equity and securities markets. This page covers exchanges, indices, and market structure—not investment advice.</p>
    </header>

    <p class="topic-definition">
      <strong>Vietnam's financial markets</strong> comprise the equity, fixed-income, and derivatives venues that channel capital between issuers and investors. The equity market is operated by the <strong>Ho Chi Minh City Stock Exchange (HOSE)</strong>, the <strong>Hanoi Stock Exchange (HNX)</strong>, and the <strong>UPCoM</strong> board for unlisted public companies. The flagship benchmarks are the VN-Index and VN30, with retail investors providing the bulk of daily trading turnover and foreign investors operating under sector-specific ownership caps. The VN-Index closed 2025 at about <strong>1,784 points (up ~41% on the year)</strong>, with total market capitalisation near <strong>$387 billion</strong> (~84% of GDP) and record average daily turnover around <strong>$1.2 billion</strong> (HOSE / VietnamPlus, 2025–2026). In a landmark shift, <strong>FTSE Russell confirmed Vietnam's reclassification from Frontier to Secondary Emerging Market, effective 21 September 2026</strong> — the first of four inclusion tranches running to September 2027, expected to draw an initial ~$1.5 billion in passive inflows and put Vietnam on the radar of global EM mandates.
    </p>

    <section>
      <h2>Overview</h2>
      <p>
        Vietnam's stock market is operated by the Ho Chi Minh City Stock Exchange (HOSE), the Hanoi Stock Exchange (HNX), and the Unlisted Public Company Market (UPCoM). The market has grown from a small bourse in the early 2000s to one of the largest in Southeast Asia by market capitalization. Retail investors account for a significant share of trading volume.
      </p>
      <BarChart
        title="Vietnam stock market — 2025 highlights"
        data={[
          { label: 'VN-Index annual return', value: 41, display: '+41%' },
          { label: 'Market cap / GDP', value: 84, display: '~84%' },
          { label: 'Capital raised, US$B', value: 5.7, display: '$5.7B' },
          { label: 'Avg daily turnover, US$B', value: 1.2, display: '$1.2B' },
        ]}
        max={100}
        source="HOSE / VietnamPlus, 2025"
        caption="2025 was a record year: the VN-Index closed near 1,784 (+41%), and capital raised via equity and bonds nearly doubled versus 2024."
      />
    </section>

    <section>
      <h2>Exchanges</h2>
      <ul class="characteristics-list">
        <li><strong>HOSE (Ho Chi Minh Stock Exchange)</strong>: Main board for large-cap listed companies; VN30 and VN100 indices.</li>
        <li><strong>HNX (Hanoi Stock Exchange)</strong>: Mid and small cap; derivatives (futures on VN30) and bond trading.</li>
        <li><strong>UPCoM</strong>: Unlisted public companies; less liquid, different listing rules.</li>
      </ul>
    </section>

    <section>
      <h2>Key indices</h2>
      <ul class="characteristics-list">
        <li><strong>VN30</strong>: Top 30 largest and most liquid stocks on HOSE.</li>
        <li><strong>VN100</strong>: Top 100 by market cap and liquidity.</li>
        <li><strong>VN-Index</strong>: Broad market index of HOSE.</li>
        <li><strong>HNX-Index</strong>: Broad index of HNX.</li>
      </ul>
    </section>

    <section>
      <h2>Regulation and infrastructure</h2>
      <p>
        The State Securities Commission (SSC) regulates the market. The Vietnam Securities Depository (VSD) handles clearing and settlement. Foreign ownership limits apply to many listed companies; sectors such as banking and listed state-owned enterprises have specific caps.
      </p>
    </section>

    <section>
      <h2>Related articles</h2>
      <ul class="sources-list">
        <li><a href="/insights/13-vietnam-stock-market-overview">Vietnam Stock Market Overview</a> — Exchanges, market size, regulation.</li>
        <li><a href="/insights/14-vn30-index-intro">VN30 Index: Overview and Composition</a> — What the VN30 is and how it is used.</li>
        <li><a href="/insights">All articles & insights</a></li>
      </ul>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer-container">
              <p class="faq-answer">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Sources</h2>
      <ul class="sources-list">
        <li><a href="https://www.ssc.gov.vn" target="_blank" rel="noopener noreferrer">State Securities Commission of Vietnam (SSC)</a></li>
        <li><a href="https://www.hsx.vn" target="_blank" rel="noopener noreferrer">Ho Chi Minh City Stock Exchange (HOSE)</a></li>
        <li><a href="https://www.hnx.vn" target="_blank" rel="noopener noreferrer">Hanoi Stock Exchange (HNX)</a></li>
        <li><a href="https://www.vsd.vn" target="_blank" rel="noopener noreferrer">Vietnam Securities Depository (VSD)</a></li>
      </ul>
    </section>

    <p class="topic-footer">
      <a href="/topics">All topics</a> · <a href="/regulations">Regulations</a> · <a href="/">Home</a>
    </p>
  </article>

  <CiteThis title="Vietnam Stock Market 2026" url={canonicalURL} updated="June 2026" />

  <RecentDevelopments topic="financial-markets" />

  <section class="further-reading" aria-label="Further reading">
    <h2>Further reading</h2>
    <ul>
    <li><a href="/guides/how-to-invest-in-vietnam-stock-market/">How to invest in the Vietnam stock market</a></li>
    <li><a href="/guides/vietnam-market-entry-guide/">Vietnam market entry guide</a></li>
    <li><a href="/stats/vietnam-stock-market-2026/">Vietnam Stock Market Statistics 2026</a></li>
    <li><a href="/compare/vietcombank-vs-techcombank-vs-vpbank/">Vietcombank vs Techcombank vs VPBank — banks compared</a></li>
    <li><a href="/compare/vn-index-vs-vn30/">VN-Index vs VN30 — index comparison</a></li>
    <li><a href="/stats/vietnam-economy-2026/">Vietnam Economy Statistics 2026</a> · <a href="/stats/vietnam-real-estate-2026/">Real Estate Statistics 2026</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .topic-definition { font-size: 1.0625rem; line-height: 1.7; margin: 1rem 0 2.5rem; padding: 1rem 1.25rem; border-left: 3px solid var(--color-accent); background: var(--color-bg-subtle); border-radius: 0 6px 6px 0; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
</style>

<style>
  .topic-page { width: 100%; }
  .topic-header { margin-bottom: var(--space-10); }
  .topic-lead { color: var(--color-text-muted); font-size: var(--text-lg); margin-top: var(--space-3); }
  .characteristics-list { list-style: none; padding: 0; }
  .characteristics-list li { position: relative; padding-left: var(--space-4); margin-bottom: var(--space-3); }
  .characteristics-list li::before { content: "—"; position: absolute; left: 0; color: var(--color-text-light); }
  .sources-list { font-size: var(--text-sm); }
  .sources-list li { margin-bottom: var(--space-2); }
  .topic-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
