---
import BaseLayout from '@layouts/BaseLayout.astro';
import { technicalOutlook, calculateShortTerm } from '@utils/stockSignals';
import { SNAPSHOT_TICKERS, snapshotAsOfLabel } from '../../data/stockSnapshot';

export function getStaticPaths() {
  return SNAPSHOT_TICKERS.map((t) => ({
    params: { ticker: t.ticker.toLowerCase() },
    props: { entry: t },
  }));
}

const { entry } = Astro.props;
const asOf = snapshotAsOfLabel();

const outlook = technicalOutlook(entry.bars);
const shortTerm = calculateShortTerm(entry.ticker, entry.bars);

const title = `${entry.ticker} (${entry.name}) — Technical Outlook & Signals (${asOf})`;
const description = `Rules-based technical outlook for ${entry.ticker} (${entry.name}) on the Vietnam stock market: trend score, price vs MA50/MA200, RSI, 52-week range position, and short-term signals. Data as of ${asOf}. Not investment advice.`;
const canonical = `https://vnmarketinsights.com/markets/${entry.ticker.toLowerCase()}/`;

const trendHex: Record<string, string> = {
  green: '#16a34a',
  yellow: '#ca8a04',
  orange: '#ea580c',
  red: '#c8102e',
};
const hex = trendHex[outlook.trendColor] ?? '#666';

const vnd = (n: number): string =>
  n > 0 ? `${Math.round(n).toLocaleString('en-US')} ₫` : '—';

const indicators = [
  { label: 'Last close', value: vnd(outlook.lastClose) },
  { label: '50-day MA', value: vnd(outlook.ma50) },
  { label: '200-day MA', value: vnd(outlook.ma200) },
  { label: 'RSI(14)', value: outlook.rsi > 0 ? Math.round(outlook.rsi).toString() : '—' },
  { label: '52-week high', value: vnd(outlook.week52High) },
  { label: '52-week low', value: vnd(outlook.week52Low) },
  {
    label: 'Position in 52w range',
    value: outlook.rangePositionPct > 0 ? `${Math.round(outlook.rangePositionPct)}%` : '—',
  },
];

// Dataset schema — this is a structured, data-backed page.
const datasetSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${entry.ticker} technical outlook`,
  description,
  url: canonical,
  dateModified: new Date(new Date().getFullYear(), 0, 1).toISOString().slice(0, 10),
  creator: { '@type': 'Organization', name: 'Vietnam Market Insights' },
  isAccessibleForFree: true,
  keywords: [entry.ticker, entry.name, 'Vietnam stock', 'technical analysis', entry.sector],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Markets"
  lastUpdated="2026-06-27"
  structuredData={datasetSchema}
  mainClass="container"
>
  <article class="outlook-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/markets/">Markets</a>
      <span aria-hidden="true">/</span>
      <span>{entry.ticker}</span>
    </nav>

    <header class="outlook-header">
      <h1>{entry.ticker} — {entry.name}</h1>
      <p class="outlook-sub">
        <span class="sector-tag">{entry.sector}</span>
        <span class="as-of">Technical outlook · data as of {asOf}</span>
      </p>
    </header>

    <section>
      <div class="score-hero" style={`--trend: ${hex}`}>
        <div class="score-dial">
          <span class="score-num">{outlook.score}</span>
          <span class="score-den">/ 50</span>
        </div>
        <div class="score-meta">
          <span class="score-verdict">{outlook.trend}</span>
          <span class="score-label">Technical score</span>
          <span class="bias-row">
            Short-term bias:
            <span class={`bias-pill bias-${shortTerm.biasColor}`}>{shortTerm.bias}</span>
          </span>
        </div>
      </div>
    </section>

    <section>
      <h2>Key indicators</h2>
      <div class="ind-grid">
        {indicators.map((i) => (
          <div class="ind-cell">
            <span class="ind-label">{i.label}</span>
            <span class="ind-value">{i.value}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2>What the chart is saying</h2>
      <p>Each line is generated by the scoring engine from the price history:</p>
      <ul class="reason-list">
        {outlook.reasons.map((r) => (
          <li>{r}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Short-term signals</h2>
      {shortTerm.signals.length > 0 ? (
        <ul class="signal-list">
          {shortTerm.signals.map((s) => (
            <li class={`signal-item dir-${s.direction}`}>
              <div class="signal-head">
                <span class="signal-label">{s.label}</span>
                <span class="signal-tf">{s.timeframe} · strength {s.strength}</span>
              </div>
              <p class="signal-detail">{s.detail}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="note">No short-term signals are firing on {entry.ticker} right now.</p>
      )}
    </section>

    <p class="disclaimer">
      ⚠️ <strong>Not investment advice.</strong> This is a transparent, rules-based read of common
      indicators on daily prices as of {asOf} — see the
      <a href="/guides/how-stock-signals-are-scored/">scoring methodology</a>. It excludes
      fundamentals, news, and your circumstances. Always do your own research.
    </p>

    <section>
      <h2>Compare across the market</h2>
      <ul class="related-list">
        <li><a href="/markets/">All tickers — technical outlook board</a></li>
        <li><a href="/guides/how-stock-signals-are-scored/">How signals are scored (methodology)</a></li>
        <li><a href="/guides/how-to-invest-in-vietnam-stock-market/">How to invest in the Vietnam stock market</a></li>
        <li><a href="/financial-markets/">Vietnam financial markets — overview</a></li>
      </ul>
    </section>

    <p class="guide-footer">
      <a href="/markets/">← Markets board</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .outlook-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .outlook-header { margin-bottom: var(--space-6); }
  .outlook-header h1 { border: none; margin-bottom: var(--space-2); }
  .outlook-sub { display: flex; gap: var(--space-3); align-items: center; flex-wrap: wrap; margin: 0; }
  .sector-tag { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent); font-weight: 600; }
  .as-of { font-size: var(--text-sm); color: var(--color-text-muted); }

  .score-hero { display: flex; gap: var(--space-6); align-items: center; flex-wrap: wrap; border: 1px solid var(--color-border-light); border-top: 4px solid var(--trend); border-radius: 4px; padding: var(--space-5) var(--space-6); background: var(--color-bg-subtle); }
  .score-dial { display: flex; align-items: baseline; gap: 0.25rem; }
  .score-num { font-family: var(--font-serif, Georgia, serif); font-size: 3.25rem; font-weight: 700; line-height: 1; color: var(--trend); font-variant-numeric: tabular-nums; }
  .score-den { font-size: var(--text-lg); color: var(--color-text-muted); }
  .score-meta { display: flex; flex-direction: column; gap: 0.3rem; }
  .score-verdict { font-size: var(--text-xl); font-weight: 700; color: var(--trend); }
  .score-label { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); }
  .bias-row { font-size: var(--text-sm); color: var(--color-text-muted); margin-top: 0.2rem; }
  .bias-pill { display: inline-block; margin-left: 0.35rem; padding: 0.1rem 0.6rem; border-radius: 999px; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .bias-green { background: color-mix(in srgb, #16a34a 18%, transparent); color: #15803d; }
  .bias-red { background: color-mix(in srgb, var(--color-accent) 18%, transparent); color: var(--color-accent); }
  .bias-gray { background: var(--color-border-light); color: var(--color-text-muted); }

  .ind-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--space-3); margin: var(--space-4) 0; }
  .ind-cell { border: 1px solid var(--color-border-light); border-radius: 2px; padding: var(--space-3); display: flex; flex-direction: column; gap: 0.2rem; background: var(--color-bg-subtle); }
  .ind-label { font-size: var(--text-xs); color: var(--color-text-muted); }
  .ind-value { font-weight: 700; font-variant-numeric: tabular-nums; }

  .reason-list { list-style: none; padding: 0; margin: var(--space-4) 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .reason-list li { padding: var(--space-2) var(--space-3); background: var(--color-bg-subtle); border: 1px solid var(--color-border-light); border-radius: 2px; line-height: 1.5; font-size: var(--text-sm); }

  .signal-list { list-style: none; padding: 0; margin: var(--space-4) 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .signal-item { border: 1px solid var(--color-border-light); border-left-width: 4px; border-radius: 2px; padding: var(--space-3) var(--space-4); background: var(--color-bg-subtle); }
  .signal-item.dir-bullish { border-left-color: #16a34a; }
  .signal-item.dir-bearish { border-left-color: var(--color-accent); }
  .signal-head { display: flex; justify-content: space-between; gap: var(--space-3); flex-wrap: wrap; }
  .signal-label { font-weight: 700; }
  .signal-tf { font-size: var(--text-xs); color: var(--color-text-muted); white-space: nowrap; }
  .signal-detail { margin: 0.4rem 0 0; font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.5; }

  .note { font-size: var(--text-sm); color: var(--color-text-muted); }
  .disclaimer { font-size: var(--text-sm); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent) 7%, transparent); border-left: 3px solid var(--color-accent); padding: var(--space-3); border-radius: 2px; margin: var(--space-6) 0; line-height: 1.55; }
  .disclaimer a { color: var(--color-accent); }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .guide-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .guide-footer a { color: var(--color-text-muted); }
  .guide-footer a:hover { color: var(--color-accent); }
</style>
