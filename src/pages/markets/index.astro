---
import BaseLayout from '@layouts/BaseLayout.astro';
import { technicalOutlook, calculateShortTerm } from '@utils/stockSignals';
import { SNAPSHOT_TICKERS, snapshotAsOfLabel, STOCK_SNAPSHOT } from '../../data/stockSnapshot';

const asOf = snapshotAsOfLabel();
const title = `Vietnam Stock Technical Outlook Board (${asOf})`;
const description = `A rules-based technical outlook for ${SNAPSHOT_TICKERS.length} large-cap Vietnamese stocks: trend score, RSI, price vs MA200, and short-term bias, ranked. Data as of ${asOf}. Not investment advice.`;
const canonical = "https://vnmarketinsights.com/markets/";

const rows = SNAPSHOT_TICKERS.map((t) => {
  const o = technicalOutlook(t.bars);
  const st = calculateShortTerm(t.ticker, t.bars);
  return {
    ticker: t.ticker,
    name: t.name,
    sector: t.sector,
    score: o.score,
    trend: o.trend,
    trendColor: o.trendColor,
    rsi: o.rsi,
    aboveMA200: o.ma200 > 0 && o.lastClose > o.ma200,
    bias: st.bias,
    biasColor: st.biasColor,
  };
}).sort((a, b) => b.score - a.score);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Vietnam Stock Technical Outlook Board",
  "itemListElement": rows.map((r, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://vnmarketinsights.com/markets/${r.ticker.toLowerCase()}/`,
    "name": `${r.ticker} — ${r.name}`,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="CollectionPage"
  structuredData={itemListSchema}
  mainClass="container"
>
  <div class="markets-index">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Markets</span>
    </nav>

    <header class="markets-header">
      <h1>Vietnam Stock Technical Outlook Board</h1>
      <p class="markets-lead">
        A transparent, rules-based technical read on {SNAPSHOT_TICKERS.length} large-cap Vietnamese
        stocks — each scored 0–50 on trend structure (price vs MA200, the MA50/MA200 cross), RSI
        momentum, and 52-week range position, then ranked. Tap a ticker for the full breakdown.
      </p>
      <p class="markets-meta">
        Data as of <strong>{asOf}</strong> · daily prices · {STOCK_SNAPSHOT.source}
      </p>
    </header>

    <div class="table-wrap">
      <table class="board">
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Sector</th>
            <th class="num">Score</th>
            <th>Trend</th>
            <th class="num">RSI</th>
            <th>vs MA200</th>
            <th>Short-term</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td>
                <a class="tk" href={`/markets/${r.ticker.toLowerCase()}/`}>
                  <strong>{r.ticker}</strong>
                  <span class="tk-name">{r.name}</span>
                </a>
              </td>
              <td class="sector">{r.sector}</td>
              <td class="num"><strong>{r.score}</strong><span class="den">/50</span></td>
              <td><span class={`trend trend-${r.trendColor}`}>{r.trend}</span></td>
              <td class="num">{r.rsi > 0 ? Math.round(r.rsi) : '—'}</td>
              <td>{r.aboveMA200 ? '▲ above' : '▼ below'}</td>
              <td><span class={`bias-pill bias-${r.biasColor}`}>{r.bias}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="disclaimer">
      ⚠️ <strong>Not investment advice.</strong> Scores are a deterministic summary of common
      technical indicators on daily prices — see the
      <a href="/guides/how-stock-signals-are-scored/">methodology</a>. They exclude fundamentals,
      news, and your circumstances.
    </p>

    <section class="more-section">
      <h2>Explore more</h2>
      <ul class="related-list">
        <li><a href="/guides/how-stock-signals-are-scored/">How signals are scored</a> · <a href="/guides/stock-signal-worked-example/">worked example</a></li>
        <li><a href="/guides/how-to-invest-in-vietnam-stock-market/">How to invest in the Vietnam stock market</a></li>
        <li><a href="/compare/vn-index-vs-vn30/">VN-Index vs VN30</a> · <a href="/financial-markets/">financial markets overview</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .markets-index { max-width: var(--container-width, 72rem); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .markets-header { margin-bottom: var(--space-6); max-width: var(--reading-width); }
  .markets-header h1 { border: none; margin-bottom: var(--space-3); }
  .markets-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .markets-meta { font-size: var(--text-sm); color: var(--color-text-muted); }

  .table-wrap { overflow-x: auto; border: 1px solid var(--color-border-light); border-radius: 4px; }
  .board { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .board th, .board td { text-align: left; padding: var(--space-3); border-bottom: 1px solid var(--color-border-light); white-space: nowrap; }
  .board thead th { background: var(--color-bg-subtle); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); position: sticky; top: 0; }
  .board th.num, .board td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .board tbody tr:hover { background: color-mix(in srgb, var(--color-accent) 5%, transparent); }
  .tk { display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .tk strong { color: var(--color-accent); }
  .tk-name { font-size: var(--text-xs); color: var(--color-text-muted); }
  .tk:hover strong { text-decoration: underline; }
  .sector { color: var(--color-text-muted); }
  .den { font-size: var(--text-xs); color: var(--color-text-muted); }
  .trend { font-weight: 600; }
  .trend-green { color: #15803d; }
  .trend-yellow { color: #ca8a04; }
  .trend-orange { color: #ea580c; }
  .trend-red { color: var(--color-accent); }
  .bias-pill { display: inline-block; padding: 0.1rem 0.55rem; border-radius: 999px; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
  .bias-green { background: color-mix(in srgb, #16a34a 18%, transparent); color: #15803d; }
  .bias-red { background: color-mix(in srgb, var(--color-accent) 18%, transparent); color: var(--color-accent); }
  .bias-gray { background: var(--color-border-light); color: var(--color-text-muted); }

  .disclaimer { font-size: var(--text-sm); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent) 7%, transparent); border-left: 3px solid var(--color-accent); padding: var(--space-3); border-radius: 2px; margin: var(--space-6) 0; line-height: 1.55; }
  .disclaimer a { color: var(--color-accent); }
  .more-section { margin-top: var(--space-8); max-width: var(--reading-width); }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
</style>
