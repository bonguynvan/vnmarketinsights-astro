---
import BaseLayout from '@layouts/BaseLayout.astro';
import trendsData from '../../data/trends.json';

interface TrendPoint {
  date: string;
  count: number;
  sentiment: number;
}
interface Trend {
  topic: string;
  siteSlug: string;
  total: number;
  growthRate: number;
  avgSentiment: number;
  tag: string;
  series: TrendPoint[];
}

const TOPIC_LABELS: Record<string, string> = {
  payments: 'Payments', ecommerce: 'E-commerce', logistics: 'Logistics',
  consumers: 'Consumers', regulation: 'Regulation', stocks: 'Stock Market',
  macro: 'Macroeconomy', platforms: 'Platforms', other: 'Other',
};

const data = trendsData as unknown as { generatedAt: string | null; trends: Trend[] };
const trends = data.trends ?? [];
const hasData = trends.length > 0;

const tagClass = (tag: string): string =>
  ({
    'Rising Star': 'tag-rising',
    'Flash Trend': 'tag-flash',
    Stable: 'tag-stable',
    Saturated: 'tag-saturated',
    Emerging: 'tag-emerging',
  })[tag] ?? 'tag-emerging';

const sentimentClass = (s: number): string =>
  s > 0.2 ? 'sent-pos' : s < -0.2 ? 'sent-neg' : 'sent-neu';

const maxCount = Math.max(1, ...trends.flatMap((t) => t.series.map((p) => p.count)));
const fmtPct = (g: number): string => `${g > 0 ? '+' : ''}${Math.round(g * 100)}%`;
const updated = data.generatedAt
  ? new Date(data.generatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout
  title="Trend Radar — Vietnam Market Topic Momentum"
  description="Topic momentum across Vietnam market news: weekly mention volume, growth, and sentiment, derived from an AI-enriched news corpus."
  canonicalURL="https://vnmarketinsights.com/trends/"
  mainClass="container"
  noindex={!hasData}
>
  <div class="trends-page">
    <header class="trends-header">
      <div class="trends-badge"><span class="badge-dot"></span> AI-enriched corpus</div>
      <h1>Trend Radar</h1>
      <p class="trends-sub">
        Topic momentum across Vietnam market news — mention volume, growth, and
        sentiment, computed from our AI-summarized news corpus. Each topic links
        to its reference page.
      </p>
      {updated && <p class="trends-updated">Updated {updated}</p>}
    </header>

    {hasData ? (
      <div class="trend-grid">
        {trends.map((t) => (
          <article class="trend-card">
            <div class="trend-card-top">
              <h2 class="trend-name">{TOPIC_LABELS[t.topic] ?? t.topic}</h2>
              <span class={`trend-tag ${tagClass(t.tag)}`}>{t.tag}</span>
            </div>

            <div class="trend-stats">
              <div class="trend-stat">
                <span class="stat-num">{t.total}</span>
                <span class="stat-label">mentions</span>
              </div>
              <div class="trend-stat">
                <span class={`stat-num ${t.growthRate >= 0 ? 'pos' : 'neg'}`}>{fmtPct(t.growthRate)}</span>
                <span class="stat-label">growth</span>
              </div>
              <div class="trend-stat">
                <span class={`stat-dot ${sentimentClass(t.avgSentiment)}`} aria-hidden="true"></span>
                <span class="stat-label">{t.avgSentiment > 0.2 ? 'positive' : t.avgSentiment < -0.2 ? 'cautious' : 'neutral'}</span>
              </div>
            </div>

            <div class="trend-spark" role="img" aria-label={`Mention volume over ${t.series.length} days`}>
              {t.series.map((p) => (
                <span class="spark-bar" style={`height:${Math.max(8, Math.round((p.count / maxCount) * 100))}%`} title={`${p.date}: ${p.count}`}></span>
              ))}
            </div>

            {t.siteSlug && (
              <a class="trend-link" href={`/${t.siteSlug}`}>Explore {TOPIC_LABELS[t.topic] ?? t.topic} →</a>
            )}
          </article>
        ))}
      </div>
    ) : (
      <div class="trend-empty">
        <span class="trend-empty-icon" aria-hidden="true">📡</span>
        <h2>Collecting signal…</h2>
        <p>The trend corpus is being populated by the news pipeline. Check back shortly, or explore the reference topics in the meantime.</p>
        <div class="trend-empty-actions">
          <a href="/topics" class="trend-btn primary">Browse topics</a>
          <a href="/insights" class="trend-btn">Latest insights</a>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .trends-page { width: 100%; }
  .trends-header { margin-bottom: var(--space-8, 2rem); }
  .trends-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.8125rem; font-weight: 600; color: var(--color-accent, #2563eb);
    background: color-mix(in srgb, var(--color-accent, #2563eb) 10%, transparent);
    padding: 0.25rem 0.6rem; border-radius: 999px; margin-bottom: 0.75rem;
  }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-accent, #2563eb); }
  .trends-sub { color: var(--color-text-muted, #5a5a5a); max-width: 60ch; line-height: 1.6; }
  .trends-updated { color: var(--color-text-muted, #5a5a5a); font-size: 0.8125rem; margin-top: 0.5rem; }

  .trend-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }
  .trend-card {
    border: 1px solid var(--color-border, #e5e5e5); border-radius: 14px;
    padding: 1.25rem; background: #fff; display: flex; flex-direction: column; gap: 1rem;
  }
  .trend-card-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .trend-name { font-size: 1.125rem; margin: 0; border: none; }
  .trend-tag { font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.55rem; border-radius: 999px; white-space: nowrap; }
  .tag-rising { background: #dcfce7; color: #166534; }
  .tag-flash { background: #fef3c7; color: #92400e; }
  .tag-stable { background: #e0e7ff; color: #3730a3; }
  .tag-saturated { background: #fee2e2; color: #991b1b; }
  .tag-emerging { background: #f1f5f9; color: #475569; }

  .trend-stats { display: flex; gap: 1.25rem; }
  .trend-stat { display: flex; flex-direction: column; }
  .stat-num { font-size: 1.35rem; font-weight: 700; color: var(--color-text, #1a1a1a); line-height: 1.1; }
  .stat-num.pos { color: #166534; } .stat-num.neg { color: #991b1b; }
  .stat-label { font-size: 0.75rem; color: var(--color-text-muted, #5a5a5a); }
  .stat-dot { width: 14px; height: 14px; border-radius: 50%; margin-bottom: 0.2rem; }
  .sent-pos { background: #22c55e; } .sent-neg { background: #ef4444; } .sent-neu { background: #f59e0b; }

  .trend-spark { display: flex; align-items: flex-end; gap: 3px; height: 56px; }
  .spark-bar { flex: 1; min-width: 3px; background: var(--color-accent, #2563eb); opacity: 0.75; border-radius: 2px 2px 0 0; }

  .trend-link { font-size: 0.875rem; font-weight: 600; color: var(--color-accent, #2563eb); text-decoration: none; }
  .trend-link:hover { text-decoration: underline; }

  .trend-empty { max-width: 520px; margin: 3rem auto; text-align: center; padding: 2.5rem;
    background: var(--color-bg-subtle, #f8f8f8); border: 1px solid var(--color-border, #e5e5e5); border-radius: 16px; }
  .trend-empty-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }
  .trend-empty-actions { display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.5rem; flex-wrap: wrap; }
  .trend-btn { padding: 0.6rem 1.1rem; border-radius: 8px; font-weight: 600; text-decoration: none;
    border: 1px solid var(--color-border, #e5e5e5); color: var(--color-text, #1a1a1a); }
  .trend-btn.primary { background: var(--color-text, #1a1a1a); color: var(--color-bg, #fff); border-color: var(--color-text, #1a1a1a); }
</style>
