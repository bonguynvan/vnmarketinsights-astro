---
import TopicLayout from '../layouts/TopicLayout.astro';
import RecentDevelopments from '../components/RecentDevelopments.astro';
import { getRelatedTopics } from '../data/topic-graph';

// Title is year-pinned to signal freshness and capture year-based queries.
// Bump the year + lastUpdated date during the annual content refresh.
const title = "Vietnam E-commerce Market — Platforms, Players & Statistics (2026)";
const lastUpdated = "February 2026";

const relatedTopics = getRelatedTopics('ecommerce');

const faqs = [
  {
    question: "How big is the e-commerce market in Vietnam?",
    answer: "Vietnam's B2C e-commerce revenue reached approximately $31 billion in 2025 (Ministry of Industry and Trade / VECOM), accounting for nearly 10% of total retail sales of goods and consumer services, after several years of 20–25%+ annual growth. Narrower marketplace-GMV estimates run lower, so figures vary by definition."
  },
  {
    question: "What are the major e-commerce platforms in Vietnam?",
    answer: "Shopee leads with about 60–65% market share by GMV, followed by Lazada (20–25%), TikTok Shop (rapidly growing in live commerce), and domestic platforms Tiki and Sendo. Facebook and Zalo dominate social commerce."
  },
  {
    question: "How do people pay for online shopping in Vietnam?",
    answer: "Cash-on-delivery (COD) is still widely used, especially in rural areas, but digital payments — bank transfers, e-wallets like MoMo, ZaloPay, ShopeePay, and ViettelPay — now process the majority of e-commerce transactions in major cities."
  },
  {
    question: "How does cross-border e-commerce work in Vietnam?",
    answer: "Vietnamese consumers buy from international sellers via Shopee International, Lazada Global, and direct platforms such as Taobao, AliExpress, and Amazon. Customs treatment depends on order value and product category, with simplified clearance for low-value shipments."
  },
  {
    question: "How fast is delivery in Vietnamese e-commerce?",
    answer: "Same-day and next-day delivery have become standard in Hanoi and Ho Chi Minh City, served by platform logistics (SPX, LEX, TikiNOW) and third-party couriers (GHN, GHTK, J&T, Ninja Van). Tier-2 and tier-3 cities typically see 2–4 day delivery."
  },
  {
    question: "What is live commerce in Vietnam?",
    answer: "Live commerce — selling products via livestream — is a major channel on TikTok Shop, Facebook Live, and Shopee Live. Categories like fashion, beauty, and FMCG see large livestream-driven GMV, particularly during platform mega-sale days."
  }
];
---

<TopicLayout title={title} lastUpdated={lastUpdated} relatedTopics={relatedTopics} faqs={faqs}>
  <p class="topic-definition">
    <strong>E-commerce in Vietnam</strong> refers to the buying and selling of goods and services through online platforms — marketplaces, social networks, branded apps, and direct-to-consumer websites. As of 2025, B2C e-commerce revenue reached approximately <strong>$31 billion</strong> (Ministry of Industry and Trade), accounting for nearly 10% of total retail sales after years of 20–25%+ annual growth. It spans marketplaces (Shopee, Lazada, Tiki, TikTok Shop), social commerce (Facebook, Zalo), and platform-integrated logistics serving a base of more than 60 million online shoppers.
  </p>

  <section>
    <h2>Overview</h2>
    <p>
      Vietnam's e-commerce market is one of the fastest-growing in Southeast Asia,
      fueled by rising internet penetration, smartphone adoption, and a young demographic
      comfortable with digital transactions. The sector has evolved from early C2C classifieds
      to sophisticated B2C platforms, live commerce, and integrated super-app ecosystems.
    </p>
    <p>
      Cross-border e-commerce plays a significant role, with Vietnamese consumers actively
      purchasing from international platforms while local platforms expand regionally.
    </p>
  </section>

  <section>
    <h2>Key Characteristics</h2>
    <ul class="characteristics-list">
      <li>Mobile-first commerce: Over 70% of e-commerce transactions occur via mobile devices</li>
      <li>Cash-on-delivery (COD) remains significant despite digital payment growth</li>
      <li>Live commerce and social selling through Facebook, Zalo, and TikTok gaining traction</li>
      <li>Intense price competition with heavy discounting and voucher culture</li>
      <li>Same-day and next-day delivery becoming standard expectations in major cities</li>
      <li>Cross-border purchases from China, Korea, and US platforms common</li>
    </ul>
  </section>

  <section>
    <h2>Market Structure</h2>

    <h3>Platform Types</h3>
    <ul>
      <li><strong>B2C Marketplaces</strong>: Shopee, Lazada, Tiki dominating general merchandise</li>
      <li><strong>C2C Platforms</strong>: Facebook Marketplace, Cho Tot for peer-to-peer transactions</li>
      <li><strong>Social Commerce</strong>: Selling through Facebook Live, Zalo Official Accounts, TikTok Shop</li>
      <li><strong>D2C Brands</strong>: Direct-to-consumer websites bypassing marketplaces</li>
      <li><strong>Vertical Specialists</strong>: Thegioididong (electronics), FPT Shop, Bach Hoa Xanh (grocery)</li>
    </ul>

    <h3>Product Categories</h3>
    <ul>
      <li>Electronics and mobile devices (highest transaction value)</li>
      <li>Fashion and apparel (high volume, frequent purchases)</li>
      <li>Beauty and personal care (strong cross-border demand)</li>
      <li>Mother and baby products (quality-focused purchasing)</li>
      <li>Home appliances and furniture (growing segment)</li>
      <li>Groceries and FMCG (emerging, logistics-intensive)</li>
    </ul>

    <h3>Logistics and Fulfillment</h3>
    <ul>
      <li>Platform-owned logistics: SPX Express, Lazada Logistics, TikiNOW</li>
      <li>Third-party delivery: GHN, GHTK, J&T Express, Ninja Van</li>
      <li>Warehouse infrastructure concentrated in Hanoi and Ho Chi Minh City</li>
      <li>Cash-on-delivery handling adds complexity to reverse logistics</li>
    </ul>
  </section>

  <section>
    <h2>Major Players</h2>

    <h3>E-commerce Platforms</h3>
    <ul>
      <li><strong>Shopee</strong>: Market leader, Sea Group subsidiary, strong in lower-tier cities</li>
      <li><strong>Lazada</strong>: Alibaba-owned, LazMall for authentic brands, strong logistics</li>
      <li><strong>Tiki</strong>: Vietnamese-owned, TikiNOW for fast delivery, book-to-general pivot</li>
      <li><strong>Sendo</strong>: FPT Corporation-backed, strong in tier-2/3 cities</li>
      <li><strong>Cho Tot</strong>: Carousell-owned classifieds, C2C focus</li>
    </ul>

    <h3>Social and Live Commerce</h3>
    <ul>
      <li><strong>Facebook</strong>: Dominant social commerce platform via pages and live streaming</li>
      <li><strong>Zalo</strong>: Official Accounts for brand stores, integrated with ZaloPay</li>
      <li><strong>TikTok Shop</strong>: Rapidly growing live commerce and short-video selling</li>
    </ul>

    <h3>Vertical Retailers</h3>
    <ul>
      <li><strong>Thegioididong / Dien May Xanh</strong>: Mobile World Investment Corporation, electronics dominance</li>
      <li><strong>FPT Shop / FPT Digital</strong>: FPT Retail subsidiary, electronics and digital services</li>
      <li><strong>Bach Hoa Xanh</strong>: Mobile World, grocery chain with online ordering</li>
      <li><strong>WinMart+</strong>: Masan Group convenience store network</li>
      <li><strong>Co.opmart / Co.opXtra</strong>: Saigon Co-op supermarket chain</li>
    </ul>

    <h3>Support Services</h3>
    <ul>
      <li><strong>GHN (Giao Hang Nhanh)</strong>: Fast delivery service, Scommerce subsidiary</li>
      <li><strong>GHTK (Giao Hang Tiet Kiem)</strong>: Cost-effective delivery, widely used by sellers</li>
      <li><strong>J&T Express</strong>: International player, aggressive pricing</li>
      <li><strong>Ninja Van</strong>: Regional logistics provider</li>
      <li><strong>KiotViet</strong>: POS and inventory management for small retailers</li>
    </ul>
  </section>

  <section>
    <h2>Why This Matters</h2>
    <ul class="characteristics-list">
      <li>COD requirements impact cash flow and working capital for cross-border sellers</li>
      <li>Platform fees (2-5% + payment processing) affect unit economics significantly</li>
      <li>Social commerce requires different marketing approaches than traditional e-commerce</li>
      <li>Same-day delivery expectations require local warehouse or 3PL partnerships</li>
      <li>Price sensitivity necessitates localized pricing strategies and promotion planning</li>
      <li>Mobile-first UX is non-negotiable; desktop experiences are secondary</li>
    </ul>
  </section>

  <section>
    <h2>Sources</h2>
    <ul class="sources-list">
      <li>Ministry of Industry and Trade E-commerce White Paper</li>
      <li>Vietnam E-commerce Association (VECOM) Industry Reports</li>
      <li>Google, Temasek, Bain & Company e-Conomy SEA Report</li>
      <li>Metric / iPrice Group Vietnam E-commerce Reports</li>
      <li>Shopee, Lazada, Tiki seller ecosystem publications</li>
      <li>Vietnam News Agency and VnExpress business coverage</li>
    </ul>
  </section>

  <RecentDevelopments topic="ecommerce" />

  <section class="further-reading" aria-label="Further reading">
    <h2>Further reading</h2>
    <ul>
      <li><a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">Shopee vs Lazada vs TikTok Shop — platform comparison</a></li>
      <li><a href="/stats/vietnam-ecommerce-2026/">Vietnam E-commerce Statistics 2026</a></li>
      <li><a href="/guides/how-to-sell-on-shopee-vietnam/">How to sell on Shopee Vietnam</a></li>
      <li><a href="/guides/how-to-sell-on-tiktok-shop-vietnam/">How to sell on TikTok Shop Vietnam</a></li>
      <li><a href="/guides/cross-border-ecommerce-into-vietnam/">Cross-border e-commerce into Vietnam</a></li>
    </ul>
  </section>
</TopicLayout>
