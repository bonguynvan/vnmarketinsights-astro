---
import BaseLayout from '@layouts/BaseLayout.astro';
import GrowthJourneyPanel from '@components/GrowthJourneyPanel.astro';
import WeekInMarkets from '@components/WeekInMarkets.astro';
---

<BaseLayout
  title="Vietnam Market Insights"
  description="Reference and tools for Vietnam market — from ecommerce to financial markets. Topics, glossary, and free tools: website snapshot, keyword miner."
  canonicalURL="https://vnmarketinsights.com/"
  mainClass="container-wide"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Vietnam Market Insights",
    "description": "Reference and tools for Vietnam market — ecommerce and financial markets",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://vnmarketinsights.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }}
>
  <GrowthJourneyPanel title="First-value progress" />

  <section class="hero">
    <div class="hero__content">
      <span class="hero__eyebrow">
        <svg class="hero__star" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 7.1-1.01L12 2z"/></svg>
        Vietnam Market Insights
      </span>
      <h1 class="hero__title">Understand Vietnam's market, <span class="hero__title-accent">made legible</span></h1>
      <p class="hero__subtitle">
        Structured reference pages, real data, and free tools for operators, founders, and
        researchers — across e-commerce, payments, logistics, and financial markets.
      </p>
      <div class="hero__actions">
        <a href="/topics" class="hero__primary-btn" data-track-event="homepage_cta_click" data-track-category="acquisition" data-track-label="explore_topics">Explore the market</a>
        <a href="/snapshot" class="hero__secondary-btn" data-track-event="homepage_secondary_click" data-track-category="acquisition" data-track-label="analyze_first_website">Analyze a website</a>
      </div>
    </div>

    <dl class="hero__stats" aria-label="Vietnam at a glance (2024)">
      <div class="hero-stat">
        <dt class="hero-stat__label">GDP (2024)</dt>
        <dd class="hero-stat__value">$476B</dd>
        <dd class="hero-stat__sub">+7.09% growth</dd>
      </div>
      <div class="hero-stat">
        <dt class="hero-stat__label">Population</dt>
        <dd class="hero-stat__value">~101M</dd>
        <dd class="hero-stat__sub">young, mobile-first</dd>
      </div>
      <div class="hero-stat">
        <dt class="hero-stat__label">E-commerce</dt>
        <dd class="hero-stat__value">$25B+</dd>
        <dd class="hero-stat__sub">#3 in Southeast Asia</dd>
      </div>
      <div class="hero-stat">
        <dt class="hero-stat__label">Internet users</dt>
        <dd class="hero-stat__value">78.4M</dd>
        <dd class="hero-stat__sub">79% penetration</dd>
      </div>
    </dl>
  </section>

  <WeekInMarkets />

  <section class="quick-starts">
    <h2>Start with one practical use case</h2>
    <div class="quick-starts__grid">
      <a href="/snapshot" class="quick-start-card" data-track-event="homepage_quickstart_click" data-track-category="acquisition" data-track-label="competitor_snapshot">
        <h3>Competitor website snapshot</h3>
        <p>Check tech stack and SEO quality before building a market brief.</p>
      </a>
      <a href="/keywords" class="quick-start-card" data-track-event="homepage_quickstart_click" data-track-category="acquisition" data-track-label="keyword_ideas">
        <h3>Keyword demand ideas</h3>
        <p>Mine search opportunities around your product category.</p>
      </a>
      <a href="/start" class="quick-start-card" data-track-event="homepage_quickstart_click" data-track-category="acquisition" data-track-label="starter_flows">
        <h3>Guided starter flows</h3>
        <p>Follow pre-built 2-minute flows for research, SEO, and market entry.</p>
      </a>
    </div>
  </section>

  <section class="pillars">
    <div class="pillar">
      <h2>Reference</h2>
      <p>Structured pages on payments, e-commerce, logistics, consumers, regulations, and financial markets.</p>
      <p><a href="/topics" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="topics">Topics</a> · <a href="/insights" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="insights">Insights</a> · <a href="/glossary" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="glossary">Glossary</a></p>
    </div>
    <div class="pillar">
      <h2>Tools</h2>
      <p>Free utility pages to move from reading to action in the same session.</p>
      <p><a href="/tools" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="tools_hub">Tools hub</a> · <a href="/snapshot" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="snapshot">Snapshot</a> · <a href="/keywords" data-track-event="homepage_pillar_click" data-track-category="acquisition" data-track-label="keywords">Keyword Miner</a></p>
    </div>
  </section>

  <!-- Methodology -->
  <section class="methodology">
    <h2>Methodology and data sources</h2>
    <p>
      This site compiles publicly available data and summaries from government publications,
      industry reports, and open sources. Sources include the <a href="https://moit.gov.vn" target="_blank" rel="noopener noreferrer">Ministry of Industry and Trade</a>,
      <a href="https://sbv.gov.vn" target="_blank" rel="noopener noreferrer">State Bank of Vietnam</a>,
      <a href="http://www.vecom.vn" target="_blank" rel="noopener noreferrer">VECOM</a>, and international
      organizations. All data is attributed to original sources.
    </p>
    <a href="/about" class="methodology__link">Read full methodology →</a>
  </section>

  <!-- Mission -->
  <section class="mission">
    <blockquote class="mission__quote">
      <p>
        All content is reference-based, not news-driven. No predictions, no opinions, no affiliate links.
        Just factual information attributed to verifiable sources.
      </p>
    </blockquote>
  </section>
</BaseLayout>

<style>
  /* Broadsheet front page: left-aligned, ruled, serif masthead headline. */
  .hero {
    text-align: left;
    margin-bottom: var(--space-10);
    padding: var(--space-8) 0 var(--space-10);
    border-top: 3px solid var(--color-ink);
    border-bottom: 1px solid var(--color-border);
  }
  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }
  .hero__star { width: 14px; height: 14px; color: var(--color-gold); }
  .hero__title {
    margin: 0 0 var(--space-5); border: none;
    font-size: var(--text-5xl); line-height: var(--leading-display); letter-spacing: -0.025em;
    max-width: 20ch;
  }
  .hero__title-accent { color: var(--color-accent); font-style: italic; }
  .hero__subtitle {
    font-size: var(--text-xl); color: var(--color-text-muted);
    max-width: 62ch; margin: 0 0 var(--space-6); line-height: 1.55;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: flex-start; }
  .hero__primary-btn {
    display: inline-flex; align-items: center; padding: var(--space-3) var(--space-6);
    background: var(--color-accent); color: white; border-radius: 2px; font-weight: 600; text-decoration: none;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .hero__primary-btn:hover { background: var(--color-accent-hover); transform: translateY(-1px); color: white; }
  .hero__secondary-btn {
    display: inline-flex; align-items: center; padding: var(--space-3) var(--space-6);
    background: transparent; color: var(--color-ink); border: 1px solid var(--color-ink); border-radius: 2px; font-weight: 600; text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .hero__secondary-btn:hover { background: var(--color-ink); color: var(--color-bg); }

  /* Market-data ribbon: ruled row with hairline column dividers. */
  .hero__stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: var(--space-8) 0 0;
    border-top: 1px solid var(--color-border);
  }
  .hero-stat {
    padding: var(--space-4) var(--space-5) 0 0;
    text-align: left;
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-4);
  }
  .hero-stat:first-child { border-left: none; padding-left: 0; }
  .hero-stat__label { margin: 0; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-light); font-weight: 600; }
  .hero-stat__value { margin: var(--space-2) 0 0; font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: 600; line-height: 1; color: var(--color-ink); font-variant-numeric: tabular-nums; }
  .hero-stat__sub { margin: var(--space-1) 0 0; font-size: var(--text-xs); color: var(--color-text-muted); }

  @media (max-width: 640px) {
    .hero { padding: var(--space-6) 0 var(--space-8); }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 0; }
    .hero-stat:nth-child(3) { border-left: none; padding-left: 0; }
    .hero-stat { padding-top: var(--space-4); }
  }

  .quick-starts { margin-bottom: var(--space-12); }
  .quick-starts h2 { margin-top: 0; border: none; }
  .quick-starts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-5);
    margin-top: var(--space-4);
  }
  .quick-start-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border-light);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    background: white;
    transition: all 0.2s ease;
  }
  .quick-start-card h3 { margin: 0 0 var(--space-2) 0; color: var(--color-text); }
  .quick-start-card p { margin: 0; color: var(--color-text-muted); font-size: var(--text-sm); }
  .quick-start-card:hover { text-decoration: none; transform: translateY(-2px); border-color: var(--color-accent); }

  .pillars { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-8); margin-bottom: var(--space-12); }
  .pillar { padding: var(--space-6); background: var(--color-bg-subtle); border-radius: 2px; }
  .pillar h2 { font-size: var(--text-xl); margin-top: 0; margin-bottom: var(--space-3); border: none; }
  .pillar p { margin-bottom: var(--space-3); }
  .pillar p:last-child { margin-bottom: 0; }

  .methodology { margin-bottom: var(--space-10); }
  .methodology__link { font-weight: 500; }
  .mission { padding: var(--space-8); background: var(--color-bg-subtle); border-radius: 2px; }
  .mission__quote { margin: 0; border: none; padding: 0; }
  .mission__quote p { margin: 0; font-style: italic; color: var(--color-text-muted); }

</style>
