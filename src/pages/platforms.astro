---
import TopicLayout from '../layouts/TopicLayout.astro';
import { getRelatedTopics } from '../data/topic-graph';

const title = "Vietnam Digital Platforms — Super-Apps, Social & Marketplaces (2026)";
const lastUpdated = "February 2026";

const relatedTopics = getRelatedTopics('platforms');

const faqs = [
  {
    question: "What is a super-app in Vietnam?",
    answer: "A super-app combines multiple consumer services — messaging, payments, ride-hailing, food delivery, e-commerce — into a single mobile application. Grab and Zalo are the dominant super-apps in Vietnam, with MoMo and ShopeePay expanding from payments into broader services."
  },
  {
    question: "Which mobile apps are popular in Vietnam?",
    answer: "By daily active users, top apps include Zalo (messaging), Facebook and Messenger, TikTok, YouTube, Shopee, Grab, MoMo, and Lazada. Local-built apps Zalo and MoMo lead in their categories against global competitors."
  },
  {
    question: "How is digital advertising structured in Vietnam?",
    answer: "Digital ad spend is concentrated on Facebook, Google (Search and YouTube), TikTok, and Zalo. E-commerce platforms (Shopee, Lazada, TikTok Shop) capture growing budgets via on-platform ads tied to live commerce and merchant tools."
  },
  {
    question: "Are foreign platforms regulated in Vietnam?",
    answer: "Yes — cross-border platforms operating in Vietnam are subject to local laws on data localization, content moderation, advertising disclosure, and tax obligations. The 2018 Cybersecurity Law, the 2023 Personal Data Protection Decree, and sector-specific decrees apply to foreign tech platforms reaching Vietnamese users."
  },
  {
    question: "What role does Zalo play in Vietnam?",
    answer: "Zalo, developed by VNG, is the most widely used messaging app in Vietnam with broad penetration across age groups. It hosts Official Accounts for brands, integrates ZaloPay for payments, and is a primary channel for customer service, social commerce, and government service notifications."
  }
];
---

<TopicLayout title={title} lastUpdated={lastUpdated} relatedTopics={relatedTopics} faqs={faqs}>
  <p class="topic-definition">
    <strong>Vietnam's digital platforms</strong> are the apps and services that mediate communication, payments, commerce, transportation, and content for a base of <strong>~77 million internet users and ~72 million smartphone users</strong>. Domestic super-apps Zalo (messaging + payments) and MoMo (wallet + lifestyle) compete with international platforms Grab, Facebook, TikTok, Shopee, and Lazada. The platform layer increasingly bundles services — wallet, commerce, delivery, content — into single mobile experiences.
  </p>

  <section>
    <h2>Overview</h2>
    <p>
      Vietnam's digital platform ecosystem has evolved from single-purpose apps to
      integrated super-apps that combine messaging, payments, commerce, and services.
      Local platforms dominate in messaging and domestic services, while international
      platforms compete in social media, entertainment, and cloud infrastructure.
    </p>
    <p>
      Platform choice significantly impacts go-to-market strategy, as each platform
      has distinct user demographics, content formats, and monetization mechanisms.
    </p>
  </section>

  <section>
    <h2>Key Characteristics</h2>
    <ul class="characteristics-list">
      <li>Super-app model: Users expect multiple services within single applications</li>
      <li>Local platforms dominate messaging (Zalo); international platforms lead social media</li>
      <li>Mobile-native design essential; desktop usage minimal outside enterprise</li>
      <li>Content moderation increasingly strict under cybersecurity regulations</li>
      <li>Platform fees and commission rates vary significantly (0% to 30%)</li>
      <li>Cross-platform integration limited; each platform operates as distinct ecosystem</li>
    </ul>
  </section>

  <section>
    <h2>Platform Categories</h2>

    <h3>Messaging and Super-Apps</h3>
    <ul>
      <li><strong>Zalo</strong>: Vietnam's dominant messaging app (75% market share), social features, mini-apps</li>
      <li><strong>Grab</strong>: Ride-hailing expanded to payments, delivery, financial services</li>
      <li><strong>MoMo</strong>: Payment app expanding to commerce, services, content</li>
      <li><strong>Facebook Messenger</strong>: Secondary messaging for international connections</li>
    </ul>

    <h3>Social Media</h3>
    <ul>
      <li><strong>Facebook</strong>: Widest reach, dominant for news and community groups</li>
      <li><strong>YouTube</strong>: Primary video platform, strong creator economy</li>
      <li><strong>TikTok</strong>: Rapid growth, dominant among under-30 demographic</li>
      <li><strong>Instagram</strong>: Urban youth, lifestyle and fashion focus</li>
      <li><strong>LinkedIn</strong>: Professional networking, B2B marketing</li>
      <li><strong>Twitter/X</strong>: Niche usage, journalists and tech community</li>
    </ul>

    <h3>E-commerce Marketplaces</h3>
    <ul>
      <li><strong>Shopee</strong>: Integrated shopping, live streaming, games, social features</li>
      <li><strong>Lazada</strong>: Alibaba ecosystem, LazMall brand focus</li>
      <li><strong>Tiki</strong>: Vietnamese-owned, book and general merchandise</li>
      <li><strong>Facebook Marketplace</strong>: C2C classifieds, social selling</li>
      <li><strong>TikTok Shop</strong>: Short video commerce, live selling</li>
    </ul>

    <h3>Cloud and Infrastructure</h3>
    <ul>
      <li><strong>Amazon Web Services</strong>: Market leader, local region (Singapore, planning Vietnam)</li>
      <li><strong>Microsoft Azure</strong>: Enterprise stronghold, Office 365 integration</li>
      <li><strong>Google Cloud</strong>: GCP services, Firebase for mobile</li>
      <li><strong>Alibaba Cloud</strong>: Popular with Chinese-connected businesses</li>
      <li><strong>Viettel Cloud, FPT Cloud</strong>: Local providers, data residency compliance</li>
    </ul>

    <h3>Enterprise and Productivity</h3>
    <ul>
      <li><strong>Microsoft 365 / Google Workspace</strong>: Standard business productivity</li>
      <li><strong>Slack, Microsoft Teams</strong>: Team collaboration, Teams dominant in enterprises</li>
      <li><strong>Zoom, Google Meet</strong>: Video conferencing</li>
      <li><strong>Notion, Trello, Asana</strong>: Project management, Notion growing among startups</li>
      <li><strong>Lark</strong>: Bytedance's enterprise suite, growing presence</li>
    </ul>
  </section>

  <section>
    <h2>Major Players</h2>

    <h3>Local Platform Companies</h3>
    <ul>
      <li><strong>VNG Corporation</strong>: Zalo, ZaloPay, game publishing (Vietnam's only unicorn)</li>
      <li><strong>Viettel Group</strong>: ViettelPay, Viettel Cloud, MyViettel super-app</li>
      <li><strong>FPT Corporation</strong>: FPT Play, Sendo, FPT Cloud, educational platforms</li>
      <li><strong>Masan Group</strong>: WinMart+, integrated retail and fintech ecosystem</li>
      <li><strong>Tiki</strong>: Local e-commerce platform, TikiNOW logistics</li>
    </ul>

    <h3>International Platform Companies</h3>
    <ul>
      <li><strong>Meta</strong>: Facebook, Instagram, WhatsApp, Messenger</li>
      <li><strong>Google</strong>: Search, YouTube, Android, Google Ads</li>
      <li><strong>ByteDance</strong>: TikTok, CapCut, Lark</li>
      <li><strong>Sea Group</strong>: Shopee, Garena games</li>
      <li><strong>Alibaba</strong>: Lazada, Alibaba.com B2B</li>
      <li><strong>Grab Holdings</strong>: Super-app (Singapore headquarters)</li>
    </ul>

    <h3>Developer and Technical Platforms</h3>
    <ul>
      <li><strong>GitHub, GitLab</strong>: Source control and CI/CD</li>
      <li><strong>Firebase, Supabase</strong>: Backend-as-a-service</li>
      <li><strong>Cloudflare</strong>: CDN and security</li>
      <li><strong>Vercel, Netlify</strong>: Frontend deployment</li>
      <li><strong>Postman, Figma</strong>: Design and API development</li>
    </ul>
  </section>

  <section>
    <h2>Why This Matters</h2>
    <ul class="characteristics-list">
      <li>Platform choice determines addressable demographic and content strategy</li>
      <li>Zalo Official Accounts essential for customer service and notifications</li>
      <li>Super-app integrations (mini-apps) reduce user acquisition friction</li>
      <li>Platform commission structures significantly impact unit economics</li>
      <li>Content localization required; English-only platforms have limited reach</li>
      <li>Platform policy changes can disrupt distribution overnight</li>
    </ul>
  </section>

  <section>
    <h2>Sources</h2>
    <ul class="sources-list">
      <li>DataReportal Digital Vietnam reports</li>
      <li>App Annie / data.ai mobile app statistics</li>
      <li>We Are Social Global Digital Reports</li>
      <li>Platform self-reported user numbers and transparency reports</li>
      <li>Vietnam Internet Association industry data</li>
      <li>Company press releases and investor filings</li>
    </ul>
  </section>

  <section class="further-reading" aria-label="Further reading">
    <h2>Further reading</h2>
    <ul>
      <li><a href="/compare/grab-vs-be-vs-gojek/">Grab vs Be vs Gojek — super-app comparison</a></li>
      <li><a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">Shopee vs Lazada vs TikTok Shop — marketplace comparison</a></li>
    </ul>
  </section>
</TopicLayout>
