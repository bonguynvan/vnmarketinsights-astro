---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadCapture from '@components/LeadCapture.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = entry.data.title ?? 'Article';
const description = entry.data.description ?? 'Vietnam market insights article';
// Briefs and company pages get a generated per-page OG image
// (scripts/make-brief-og.mjs).
const hasGeneratedOg =
  entry.data.category === 'Market Brief' || entry.data.category === 'Company';
const ogImage = hasGeneratedOg ? `/og/${entry.slug}.png` : undefined;

// NewsArticle JSON-LD for weekly briefs (timely, news-style content) to help
// Google News / rich results understand them.
const SITE = 'https://vnmarketinsights.com';
const newsSchema =
  entry.data.category === 'Market Brief'
    ? {
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        headline: title,
        description,
        datePublished: entry.data.publishedDate,
        dateModified: entry.data.lastUpdated ?? entry.data.publishedDate,
        image: ogImage ? new URL(ogImage, SITE).href : undefined,
        mainEntityOfPage: `${SITE}/insights/${entry.slug}/`,
        publisher: {
          '@type': 'Organization',
          name: 'Vietnam Market Insights',
          logo: { '@type': 'ImageObject', url: `${SITE}/og-image.png` },
        },
      }
    : undefined;

// Related insights: same category first (newest), topped up with other recent
// articles so the block is always populated. Computed at build time.
const RELATED_COUNT = 4;
const byDate = (a: typeof entry, b: typeof entry) => {
  const da = a.data.publishedDate ? new Date(a.data.publishedDate).valueOf() : 0;
  const db = b.data.publishedDate ? new Date(b.data.publishedDate).valueOf() : 0;
  return db - da;
};
const collection = await getCollection('articles');
const all = collection.filter((a) => a.slug !== entry.slug);
const sameCategory = all
  .filter((a) => entry.data.category && a.data.category === entry.data.category)
  .sort(byDate);
const fillers = all.filter((a) => !sameCategory.includes(a)).sort(byDate);
const related = [...sameCategory, ...fillers].slice(0, RELATED_COUNT);

// hreflang for EN/VI brief pairs (VI variant slug = <en>-vi).
const slugs = new Set(collection.map((a) => a.slug));
const briefUrl = (s: string) => `${SITE}/insights/${s}/`;
let alternateLanguages: Array<{ hreflang: string; href: string }> = [];
if (entry.data.category === 'Market Brief') {
  const enSlug = entry.slug.endsWith('-vi') ? entry.slug.slice(0, -3) : entry.slug;
  const viSlug = `${enSlug}-vi`;
  if (slugs.has(enSlug) && slugs.has(viSlug)) {
    alternateLanguages = [
      { hreflang: 'en', href: briefUrl(enSlug) },
      { hreflang: 'vi', href: briefUrl(viSlug) },
      { hreflang: 'x-default', href: briefUrl(enSlug) },
    ];
  }
}
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={`https://vnmarketinsights.com/insights/${entry.slug}/`}
  mainClass="container"
  pageType="Article"
  {...(ogImage ? { image: ogImage } : {})}
  {...(newsSchema ? { structuredData: newsSchema } : {})}
  {...(alternateLanguages.length ? { alternateLanguages } : {})}
  publishedDate={entry.data.publishedDate}
  lastUpdated={entry.data.lastUpdated}
  articleSection={entry.data.category}
>
  <article class="article-page">
    <header class="article-header">
      {entry.data.publishedDate && (
        <time class="article-meta" datetime={new Date(entry.data.publishedDate).toISOString()}>
          {new Date(entry.data.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      <h1>{title}</h1>
    </header>
    <div class="article-body prose">
      <Content />
    </div>
    {related.length > 0 && (
      <aside class="related-insights" aria-label="Related insights">
        <h2>Related insights</h2>
        <ul class="related-grid">
          {related.map((rel) => (
            <li>
              <a href={`/insights/${rel.slug}`} class="related-card">
                {rel.data.category && <span class="related-cat">{rel.data.category}</span>}
                <span class="related-title">{rel.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <footer class="article-footer">
      <a href="/insights">← All articles</a> · <a href="/topics">Topics</a>
    </footer>
    <LeadCapture
      source={`insight_${entry.slug}`}
      title="Get the next insight in your inbox"
      description="One short weekly brief with new articles, tools, and practical market updates."
    />
  </article>
</BaseLayout>

<style>
  .article-page { width: 100%; }
  .article-header { margin-bottom: var(--space-8); }
  .article-meta { font-size: var(--text-sm); color: var(--color-text-light); display: block; margin-bottom: var(--space-2); }
  .article-header h1 { border: none; margin-bottom: 0; }
  .article-body { margin: var(--space-8) 0; }
  .article-body :global(h2) { margin-top: var(--space-10); }
  .article-body :global(h3) { margin-top: var(--space-6); }
  .article-body :global(ul), .article-body :global(ol) { padding-left: var(--space-6); }
  .article-footer { margin-top: var(--space-10); padding-top: var(--space-6); border-top: 1px solid var(--color-border-light); font-size: var(--text-sm); color: var(--color-text-muted); }

  .related-insights { margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid var(--color-border-light); }
  .related-insights h2 { border: none; margin-bottom: var(--space-5); font-size: var(--text-xl); }
  .related-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-4); }
  .related-grid li { margin: 0; }
  .related-card { display: flex; flex-direction: column; gap: var(--space-2); height: 100%; padding: var(--space-4); border: 1px solid var(--color-border-light); border-radius: 10px; text-decoration: none; color: inherit; transition: border-color 0.18s ease, transform 0.18s ease; }
  .related-card:hover { border-color: var(--color-accent); transform: translateY(-2px); text-decoration: none; color: inherit; }
  .related-cat { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-accent); font-weight: 600; }
  .related-title { font-weight: 600; line-height: 1.35; color: var(--color-text); }
</style>
