---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadCapture from '@components/LeadCapture.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort((a, b) => {
  const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).valueOf() : 0;
  const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).valueOf() : 0;
  return dateB - dateA;
});

// Topic filter chips, derived from article categories (most common first).
const categoryCounts = articles.reduce<Record<string, number>>((acc, entry) => {
  const cat = entry.data.category;
  if (cat) acc[cat] = (acc[cat] ?? 0) + 1;
  return acc;
}, {});
const categories = Object.keys(categoryCounts).sort((a, b) => categoryCounts[b] - categoryCounts[a]);

// Latest weekly brief (EN), surfaced as a hero. `articles` is newest-first.
const latestBrief = articles.find(
  (entry) => entry.data.category === 'Market Brief' && !entry.slug.endsWith('-vi'),
);

const site = "https://vnmarketinsights.com";
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Vietnam Market Insights — Articles",
  "numberOfItems": articles.length,
  "itemListElement": articles.map((entry, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `${site}/insights/${entry.slug}/`,
    "name": entry.data.title,
  })),
};
---

<BaseLayout
  title="Articles & Insights"
  description="In-depth articles on Vietnam's digital economy, ecommerce, fintech, logistics, and market structure."
  canonicalURL="https://vnmarketinsights.com/insights/"
  pageType="CollectionPage"
  structuredData={itemListSchema}
  mainClass="container-wide"
>
  <article class="insights-page">
    <header class="insights-header">
      <h1>Articles & Insights</h1>
      <p class="insights-lead">In-depth reference articles on Vietnam's market: digital economy, ecommerce, fintech, logistics, and regulations.</p>
    </header>

    {latestBrief && (
      <a href={`/insights/${latestBrief.slug}`} class="brief-hero" data-track-event="insight_click" data-track-category="acquisition" data-track-label={latestBrief.slug}>
        <div class="brief-hero-tag">
          <span class="brief-hero-dot"></span> Latest weekly brief
        </div>
        <h2 class="brief-hero-title">{latestBrief.data.title}</h2>
        {latestBrief.data.description && <p class="brief-hero-desc">{latestBrief.data.description}</p>}
        <span class="brief-hero-cta">Read the brief →</span>
      </a>
    )}

    {categories.length > 1 && (
      <nav class="insights-filter" aria-label="Filter by topic">
        <button type="button" class="filter-chip is-active" data-filter="all">
          All <span class="filter-count">{articles.length}</span>
        </button>
        {categories.map((cat) => (
          <button type="button" class="filter-chip" data-filter={cat}>
            {cat} <span class="filter-count">{categoryCounts[cat]}</span>
          </button>
        ))}
      </nav>
    )}

    <section class="insights-list">
      <ul class="article-grid">
        {articles.map((entry) => (
          <li class="article-card-item" data-category={entry.data.category ?? 'Uncategorized'}>
            <a href={`/insights/${entry.slug}`} class="article-card" data-track-event="insight_click" data-track-category="acquisition" data-track-label={entry.slug}>
              {entry.data.publishedDate && (
                <time class="article-date" datetime={new Date(entry.data.publishedDate).toISOString()}>
                  {new Date(entry.data.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              )}
              <span class="article-title">{entry.data.title}</span>
              {entry.data.description && <span class="article-desc">{entry.data.description}</span>}
              <span class="article-cta">Read article →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <p class="insights-footer">
      <a href="/topics">Topics</a> · <a href="/">Home</a>
    </p>
    <LeadCapture
      source="insights_hub"
      title="Get new insights each week"
      description="Get one practical market brief with links to new articles and datasets."
    />
  </article>

  <script is:inline>
    (() => {
      const chips = document.querySelectorAll('.filter-chip');
      const items = document.querySelectorAll('.article-card-item');
      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const filter = chip.getAttribute('data-filter');
          chips.forEach((c) => c.classList.toggle('is-active', c === chip));
          items.forEach((item) => {
            const match = filter === 'all' || item.getAttribute('data-category') === filter;
            item.style.display = match ? '' : 'none';
          });
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .insights-page { }
  .insights-filter {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .filter-chip {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.85rem; border-radius: 999px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    color: var(--color-text-muted); font-size: var(--text-sm); font-weight: 600;
    cursor: pointer; transition: all 0.15s ease;
  }
  .filter-chip:hover { border-color: var(--color-accent); color: var(--color-text); }
  .filter-chip.is-active { background: var(--color-text); color: var(--color-bg); border-color: var(--color-text); }
  .filter-count { font-size: var(--text-xs); opacity: 0.7; }
  .insights-header { margin-bottom: var(--space-10); }
  .insights-header h1 { margin-bottom: var(--space-3); border: none; }
  .insights-lead { color: var(--color-text-muted); font-size: var(--text-lg); max-width: 640px; }
  .brief-hero {
    display: block; margin: var(--space-6) 0 var(--space-8);
    padding: var(--space-6);
    border: 1px solid var(--color-border); border-radius: 16px;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 8%, var(--color-bg)), var(--color-bg));
    text-decoration: none; color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .brief-hero:hover { transform: translateY(-3px); border-color: var(--color-accent); text-decoration: none; color: inherit; box-shadow: 0 8px 24px color-mix(in srgb, var(--color-accent) 14%, transparent); }
  .brief-hero-tag { display: inline-flex; align-items: center; gap: 0.4rem; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent); margin-bottom: var(--space-3); }
  .brief-hero-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-accent); }
  .brief-hero-title { font-size: var(--text-2xl); font-weight: 800; line-height: 1.25; margin: 0 0 var(--space-2); border: none; color: var(--color-text); }
  .brief-hero-desc { color: var(--color-text-muted); margin: 0 0 var(--space-3); max-width: 70ch; line-height: 1.55; }
  .brief-hero-cta { font-weight: 600; color: var(--color-accent); font-size: var(--text-sm); }
  .insights-list { margin: var(--space-8) 0; }
  .article-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }
  .article-card-item { margin: 0; }
  .article-card {
    display: flex; flex-direction: column; height: 100%;
    padding: var(--space-5);
    border: 1px solid var(--color-border-light); border-radius: 12px;
    background: var(--color-bg); text-decoration: none; color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .article-card:hover {
    text-decoration: none; color: inherit;
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
  .article-date { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-light); margin-bottom: var(--space-2); }
  .article-title { font-weight: 700; font-size: var(--text-lg); line-height: 1.3; color: var(--color-text); display: block; margin-bottom: var(--space-2); }
  .article-desc { font-size: var(--text-sm); color: var(--color-text-muted); display: block; line-height: 1.55; margin-bottom: var(--space-3); }
  .article-cta { margin-top: auto; font-size: var(--text-sm); font-weight: 600; color: var(--color-accent); }
  .insights-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
