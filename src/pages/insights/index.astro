---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadCapture from '@components/LeadCapture.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort((a, b) => {
  const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).valueOf() : 0;
  const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).valueOf() : 0;
  return dateB - dateA;
});

const site = "https://vnmarketinsights.com";
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Vietnam Market Insights — Articles",
  "numberOfItems": articles.length,
  "itemListElement": articles.map((entry, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `${site}/insights/${entry.slug}/`,
    "name": entry.data.title,
  })),
};
---

<BaseLayout
  title="Articles & Insights"
  description="In-depth articles on Vietnam's digital economy, ecommerce, fintech, logistics, and market structure."
  canonicalURL="https://vnmarketinsights.com/insights/"
  pageType="CollectionPage"
  structuredData={itemListSchema}
  mainClass="container-wide"
>
  <article class="insights-page">
    <header class="insights-header">
      <h1>Articles & Insights</h1>
      <p class="insights-lead">In-depth reference articles on Vietnam's market: digital economy, ecommerce, fintech, logistics, and regulations.</p>
    </header>

    <section class="insights-list">
      <ul class="article-grid">
        {articles.map((entry) => (
          <li class="article-card-item">
            <a href={`/insights/${entry.slug}`} class="article-card" data-track-event="insight_click" data-track-category="acquisition" data-track-label={entry.slug}>
              {entry.data.publishedDate && (
                <time class="article-date" datetime={new Date(entry.data.publishedDate).toISOString()}>
                  {new Date(entry.data.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              )}
              <span class="article-title">{entry.data.title}</span>
              {entry.data.description && <span class="article-desc">{entry.data.description}</span>}
              <span class="article-cta">Read article →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <p class="insights-footer">
      <a href="/topics">Topics</a> · <a href="/">Home</a>
    </p>
    <LeadCapture
      source="insights_hub"
      title="Get new insights each week"
      description="Get one practical market brief with links to new articles and datasets."
    />
  </article>
</BaseLayout>

<style>
  .insights-page { }
  .insights-header { margin-bottom: var(--space-10); }
  .insights-header h1 { margin-bottom: var(--space-3); border: none; }
  .insights-lead { color: var(--color-text-muted); font-size: var(--text-lg); max-width: 640px; }
  .insights-list { margin: var(--space-8) 0; }
  .article-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }
  .article-card-item { margin: 0; }
  .article-card {
    display: flex; flex-direction: column; height: 100%;
    padding: var(--space-5);
    border: 1px solid var(--color-border-light); border-radius: 12px;
    background: var(--color-bg); text-decoration: none; color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .article-card:hover {
    text-decoration: none; color: inherit;
    transform: translateY(-3px);
    border-color: var(--color-accent);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }
  .article-date { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-light); margin-bottom: var(--space-2); }
  .article-title { font-weight: 700; font-size: var(--text-lg); line-height: 1.3; color: var(--color-text); display: block; margin-bottom: var(--space-2); }
  .article-desc { font-size: var(--text-sm); color: var(--color-text-muted); display: block; line-height: 1.55; margin-bottom: var(--space-3); }
  .article-cta { margin-top: auto; font-size: var(--text-sm); font-weight: 600; color: var(--color-accent); }
  .insights-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
