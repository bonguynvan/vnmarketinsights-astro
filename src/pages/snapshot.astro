---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadCapture from '@components/LeadCapture.astro';
---

<BaseLayout
  title="Vietnam Website Snapshot - Mini BuiltWith & SEO Scan"
  description="Analyze any Vietnamese website tech stack, SEO score, and mobile-friendliness instantly."
  canonicalURL="https://vnmarketinsights.com/snapshot/"
  mainClass="container-wide"
>
  <div class="snapshot-page text-slate-900">
    <div class="header-section">
      <h1 class="title">Vietnam Website Snapshot</h1>
      <p class="subtitle">Enter a domain to detect its technology stack and SEO performance.</p>
    </div>

    <div class="analyzer-card">
      <div class="input-group">
        <input 
          type="text" 
          id="domain-input" 
          placeholder="e.g. shopee.vn, tiki.vn, yoursite.com" 
          class="url-input"
        />
        <button id="analyze-btn" class="analyze-btn">
          <span class="btn-text">Analyze Website</span>
          <div class="btn-loader hidden"></div>
        </button>
      </div>
      <p class="input-note">We only analyze public HTML. No private data is accessed.</p>
      <div class="example-domains">
        <span>Try an example:</span>
        <button type="button" class="example-chip" data-domain="shopee.vn">shopee.vn</button>
        <button type="button" class="example-chip" data-domain="tiki.vn">tiki.vn</button>
        <button type="button" class="example-chip" data-domain="thegioididong.com">thegioididong.com</button>
      </div>
    </div>

    <div id="results-container" class="results-container hidden">
      <div class="results-grid">
        <!-- Tech Stack Column -->
        <div class="card">
          <div class="card-header">
            <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
            <h2>Technology Stack</h2>
          </div>
          <div id="tech-list" class="tech-list"></div>
        </div>

        <!-- SEO Score Column -->
        <div class="card">
          <div class="card-header">
            <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <h2>SEO Audit</h2>
          </div>
          <div class="seo-content">
            <div class="score-circle">
              <span id="seo-score-val">0</span>
              <span class="score-label">SEO Score</span>
            </div>
            <div id="seo-details" class="seo-details"></div>
          </div>
        </div>

        <!-- Metrics Column -->
        <div class="card">
          <div class="card-header">
            <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            <h2>Market Metrics</h2>
          </div>
          <div id="metrics-list" class="metrics-list"></div>
        </div>
      </div>

      <div class="raw-data-section">
        <details>
          <summary>View Meta Tags Found</summary>
          <pre id="meta-raw" class="raw-code"></pre>
        </details>
      </div>

      <div class="result-next-step">
        <p>Want to turn this into content opportunities?</p>
        <a href="/keywords" data-track-event="snapshot_next_step_click" data-track-category="acquisition" data-track-label="to_keywords">Go to Keyword Miner</a>
        <button type="button" id="snapshot-share-btn" class="share-result-btn">Share this tool</button>
        <button type="button" id="snapshot-save-goal-btn" class="share-result-btn">Save as goal</button>
      </div>
      <div id="snapshot-replay-status" class="replay-status"></div>
    </div>

    <div id="error-message" class="error-panel hidden"></div>
    <section class="saved-results">
      <div class="saved-results__header">
        <h2>Recent analyses on this device</h2>
      </div>
      <ul id="snapshot-saved-list" class="saved-results__list"></ul>
    </section>
    <LeadCapture
      source="snapshot_page"
      title="Get weekly website intelligence tips"
      description="Receive concise updates and market examples built from Snapshot use cases."
    />
  </div>

  <script is:inline>
    const input = document.getElementById('domain-input');
    const btn = document.getElementById('analyze-btn');
    const btnText = btn.querySelector('.btn-text');
    const btnLoader = btn.querySelector('.btn-loader');
    const resultsContainer = document.getElementById('results-container');
    const errorMessage = document.getElementById('error-message');
    const exampleButtons = document.querySelectorAll('.example-chip');
    const shareButton = document.getElementById('snapshot-share-btn');
    const saveGoalButton = document.getElementById('snapshot-save-goal-btn');
    const replayStatus = document.getElementById('snapshot-replay-status');
    const savedList = document.getElementById('snapshot-saved-list');
    const savedStorageKey = 'vmi_snapshot_saved_results';
    const replayQueueKey = 'vmi_replay_snapshot_queue';
    const replayAutoKey = 'vmi_replay_auto_snapshot';
    const replaySummariesKey = 'vmi_replay_batch_summaries';
    let replayNavigateLocked = false;
    let latestAnalyzedDomain = '';
    let started = false;

    const track = (eventName, params = {}) => {
      if (typeof window.vmiTrack === 'function') {
        window.vmiTrack(eventName, { event_category: 'tools', tool: 'snapshot', ...params });
      }
    };

    btn.addEventListener('click', analyze);
    input.addEventListener('keypress', (e) => { if (e.key === 'Enter') analyze(); });
    input.addEventListener('focus', () => {
      if (started) return;
      started = true;
      track('tool_form_started', { event_label: 'snapshot_domain_input' });
    });
    exampleButtons.forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = chip.dataset.domain || '';
        input.focus();
        track('tool_example_selected', { event_label: chip.dataset.domain || 'unknown' });
      });
    });

    shareButton?.addEventListener('click', async () => {
      const shareUrl = window.vmiGrowthContext?.getShareUrl
        ? window.vmiGrowthContext.getShareUrl('/snapshot')
        : `${window.location.origin}/snapshot`;
      const shareData = {
        title: 'Vietnam Website Snapshot',
        text: 'Analyze website tech stack and SEO in under 2 minutes.',
        url: shareUrl
      };
      try {
        if (navigator.share) {
          await navigator.share(shareData);
        } else if (navigator.clipboard) {
          await navigator.clipboard.writeText(shareUrl);
        }
        track('tool_share_click', { event_label: 'snapshot_tool_share' });
      } catch (error) {
        // ignore cancelled share actions
      }
    });

    function readSavedResults() {
      try {
        const raw = localStorage.getItem(savedStorageKey);
        const parsed = raw ? JSON.parse(raw) : [];
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function writeSavedResults(results) {
      localStorage.setItem(savedStorageKey, JSON.stringify(results.slice(0, 8)));
    }

    function saveResult(data) {
      const item = {
        domain: data.domain,
        seoScore: Number(data.seo.score) || 0,
        analyzedAt: new Date().toISOString()
      };
      const existing = readSavedResults().filter((entry) => entry.domain !== item.domain);
      writeSavedResults([item, ...existing]);
      renderSavedResults();
    }

    function readReplayQueue() {
      try {
        const raw = localStorage.getItem(replayQueueKey);
        const parsed = raw ? JSON.parse(raw) : null;
        if (!parsed || !Array.isArray(parsed.items)) return null;
        return parsed;
      } catch {
        return null;
      }
    }

    function writeReplayQueue(queue) {
      localStorage.setItem(replayQueueKey, JSON.stringify(queue));
    }

    function clearReplayQueue() {
      localStorage.removeItem(replayQueueKey);
    }

    function appendReplaySummary(summary) {
      try {
        const raw = localStorage.getItem(replaySummariesKey);
        const existing = raw ? JSON.parse(raw) : [];
        const normalized = Array.isArray(existing) ? existing : [];
        localStorage.setItem(replaySummariesKey, JSON.stringify([summary, ...normalized].slice(0, 12)));
      } catch {
        // ignore persistence errors
      }
    }

    function isReplayAutoEnabled() {
      const stored = localStorage.getItem(replayAutoKey);
      if (!stored) return true;
      return stored === '1';
    }

    function setReplayAutoEnabled(enabled) {
      localStorage.setItem(replayAutoKey, enabled ? '1' : '0');
    }

    function navigateToReplayDomain(domain, auto = true) {
      if (!domain || replayNavigateLocked) return;
      replayNavigateLocked = true;
      window.location.href = `/snapshot?domain=${encodeURIComponent(domain)}&autorun=1&replay=1${auto ? '&auto=1' : ''}`;
    }

    function renderReplayStatus(currentDomain = '') {
      if (!replayStatus) return;
      const params = new URLSearchParams(window.location.search);
      const replayMode = ['1', 'true', 'yes'].includes((params.get('replay') || '').toLowerCase());
      const queue = readReplayQueue();
      if (!replayMode || !queue?.items?.length) {
        replayStatus.replaceChildren();
        return;
      }

      if (currentDomain) {
        const foundIndex = queue.items.findIndex((item) => item === currentDomain);
        if (foundIndex >= 0) {
          queue.index = foundIndex;
          writeReplayQueue(queue);
        }
      }

      const index = Number(queue.index || 0);
      const total = Number(queue.total || queue.items.length);
      const nextItem = queue.items[index + 1];

      if (!nextItem) {
        replayStatus.replaceChildren();
        const doneText = document.createElement('p');
        doneText.textContent = `Replay queue complete. Processed ${total} domains.`;
        replayStatus.appendChild(doneText);
        const processed = Array.isArray(queue.processed) ? queue.processed : [];
        const avgScore = processed.length
          ? Math.round(processed.reduce((sum, item) => sum + Number(item.seoScore || 0), 0) / processed.length)
          : 0;
        const topDomain = processed.slice().sort((a, b) => Number(b.seoScore || 0) - Number(a.seoScore || 0))[0]?.domain || '';
        appendReplaySummary({
          type: 'snapshot',
          total: processed.length || total,
          avgScore,
          topDomain,
          createdAt: new Date().toISOString()
        });
        track('tool_replay_completed', { event_label: 'snapshot', replay_total: Number(total) || 0 });
        clearReplayQueue();
        return;
      }

      replayStatus.replaceChildren();
      const progressText = document.createElement('p');
      progressText.textContent = `Replay progress: ${Math.min(index + 1, total)}/${total}`;
      const actionWrap = document.createElement('div');
      actionWrap.className = 'replay-actions';
      const nextBtn = document.createElement('button');
      nextBtn.type = 'button';
      nextBtn.id = 'snapshot-replay-next-btn';
      nextBtn.className = 'share-result-btn';
      nextBtn.textContent = `Run next: ${nextItem}`;
      const autoBtn = document.createElement('button');
      autoBtn.type = 'button';
      autoBtn.id = 'snapshot-replay-auto-btn';
      autoBtn.className = 'share-result-btn';
      autoBtn.textContent = isReplayAutoEnabled() ? 'Pause auto-run' : 'Enable auto-run';
      actionWrap.append(nextBtn, autoBtn);
      replayStatus.append(progressText, actionWrap);
      nextBtn?.addEventListener('click', () => {
        track('tool_replay_next_click', { event_label: nextItem });
        navigateToReplayDomain(nextItem, false);
      });
      autoBtn?.addEventListener('click', () => {
        const nextState = !isReplayAutoEnabled();
        setReplayAutoEnabled(nextState);
        track('tool_replay_auto_toggled', { event_label: nextState ? 'enabled' : 'paused' });
        renderReplayStatus(currentDomain);
      });

      if (currentDomain && isReplayAutoEnabled()) {
        window.setTimeout(() => {
          track('tool_replay_auto_advance', { event_label: nextItem });
          navigateToReplayDomain(nextItem, true);
        }, 1200);
      }
    }

    function renderSavedResults() {
      if (!savedList) return;
      const results = readSavedResults();
      if (!results.length) {
        savedList.replaceChildren();
        const emptyItem = document.createElement('li');
        emptyItem.textContent = 'No analyses yet. Run your first domain above.';
        savedList.appendChild(emptyItem);
        return;
      }
      savedList.replaceChildren();
      results.forEach((entry) => {
        const item = document.createElement('li');
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'saved-result-btn';
        button.dataset.domain = entry.domain;
        const title = document.createElement('strong');
        title.textContent = entry.domain;
        const meta = document.createElement('span');
        meta.textContent = `SEO ${entry.seoScore} · ${new Date(entry.analyzedAt).toLocaleDateString('en-US')}`;
        button.append(title, meta);
        button.addEventListener('click', () => {
          input.value = entry.domain || '';
          analyze();
          track('tool_saved_result_reused', { event_label: entry.domain || 'unknown' });
        });
        item.appendChild(button);
        savedList.appendChild(item);
      });
    }

    async function analyze() {
      const rawInput = input.value.trim();
      const url = rawInput.replace(/^https?:\/\//, '').replace(/\/$/, '');
      if (!url) {
        showError('Please enter a domain to analyze.');
        track('tool_submit_blocked', { event_label: 'empty_domain' });
        return;
      }
      if (!/^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(url)) {
        showError('Please enter a valid domain, e.g. shopee.vn');
        track('tool_submit_blocked', { event_label: 'invalid_domain' });
        return;
      }

      // Reset UI
      resultsContainer.classList.add('hidden');
      errorMessage.classList.add('hidden');
      btn.disabled = true;
      btnText.classList.add('hidden');
      btnLoader.classList.remove('hidden');
      btnText.textContent = 'Analyzing...';
      track('tool_submitted', { event_label: 'snapshot_analyze_click', input_length: url.length });

      try {
        const response = await fetch(`/api/analyze/?url=${encodeURIComponent(url)}`);
        const result = await response.json();

        if (result.success) {
          renderResults(result.data);
          resultsContainer.classList.remove('hidden');
          latestAnalyzedDomain = result.data.domain;
          saveResult(result.data);
          window.vmiGrowthContext?.setMilestone?.('snapshot_first_value', true);
          window.vmiGrowthContext?.recordRecentAction?.({
            label: `Snapshot analyzed: ${result.data.domain}`,
            href: '/snapshot'
          });
          track('tool_success', {
            event_label: result.data.domain,
            seo_score: Number(result.data.seo.score) || 0,
            tech_count: result.data.techStack.length
          });
          track('first_value_received', { event_label: 'snapshot_result' });

          const queue = readReplayQueue();
          if (queue?.items?.length) {
            const processed = Array.isArray(queue.processed) ? queue.processed : [];
            const hasDomain = processed.some((item) => item.domain === result.data.domain);
            if (!hasDomain) {
              processed.push({
                domain: result.data.domain,
                seoScore: Number(result.data.seo.score) || 0
              });
            }
            queue.processed = processed;
            writeReplayQueue(queue);
          }

          renderReplayStatus(result.data.domain);
          if (window.location.search.includes('replay=1')) {
            track('tool_replay_item_success', { event_label: result.data.domain });
          }
        } else {
          showError(result.error);
          track('tool_error', { event_label: 'api_error' });
          if (window.location.search.includes('replay=1')) {
            track('tool_replay_item_error', { event_label: url });
          }
        }
      } catch (err) {
        showError('Could not connect to analysis engine. Please try again.');
        track('tool_error', { event_label: 'network_error' });
        if (window.location.search.includes('replay=1')) {
          track('tool_replay_item_error', { event_label: url });
        }
      } finally {
        btn.disabled = false;
        btnText.textContent = 'Analyze Website';
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
      }
    }

    function renderResults(data) {
      // Tech Stack
      const techList = document.getElementById('tech-list');
      techList.replaceChildren();
      if (data.techStack.length > 0) {
        data.techStack.forEach((tech) => {
          const row = document.createElement('div');
          row.className = 'tech-item';
          const name = document.createElement('span');
          name.className = 'tech-name';
          name.textContent = String(tech.name || '');
          const category = document.createElement('span');
          category.className = 'tech-cat';
          category.textContent = String(tech.category || '');
          row.append(name, category);
          techList.appendChild(row);
        });
      } else {
        const empty = document.createElement('p');
        empty.className = 'text-muted';
        empty.textContent = 'No specific tech signatures detected.';
        techList.appendChild(empty);
      }

      // SEO
      document.getElementById('seo-score-val').textContent = data.seo.score;
      const seoDetails = document.getElementById('seo-details');
      seoDetails.replaceChildren();
      const seoStat = document.createElement('div');
      seoStat.className = 'seo-stat';
      const seoStrong = document.createElement('strong');
      seoStrong.textContent = 'Title:';
      seoStat.append(seoStrong, document.createTextNode(` ${data.seo.title || 'N/A'}`));
      const issueWrap = document.createElement('div');
      issueWrap.className = 'seo-issues';
      if (Array.isArray(data.seo.issues) && data.seo.issues.length) {
        data.seo.issues.forEach((issue) => {
          const pill = document.createElement('div');
          pill.className = 'issue-pill';
          pill.textContent = `× ${issue}`;
          issueWrap.appendChild(pill);
        });
      } else {
        const success = document.createElement('div');
        success.className = 'success-pill';
        success.textContent = '✓ No major issues found';
        issueWrap.appendChild(success);
      }
      seoDetails.append(seoStat, issueWrap);

      // Metrics
      const metricsList = document.getElementById('metrics-list');
      metricsList.replaceChildren();
      const metricRows = [
        ['Estimated Traffic:', data.metrics.trafficTier],
        ['Page Size:', data.metrics.pageSize],
        ['Mobile Friendly:', data.metrics.isMobileFriendly ? 'Yes ✓' : 'No ×']
      ];
      metricRows.forEach(([label, value]) => {
        const row = document.createElement('div');
        row.className = 'metric-row';
        const left = document.createElement('span');
        left.textContent = String(label);
        const right = document.createElement('strong');
        right.textContent = String(value);
        row.append(left, right);
        metricsList.appendChild(row);
      });

      // Raw
      document.getElementById('meta-raw').textContent = `Title: ${data.seo.title}\nDescription: ${data.seo.description}\nHeadings: ${data.seo.h1Count} (H1)`;
    }

    function showError(msg) {
      errorMessage.textContent = msg;
      errorMessage.classList.remove('hidden');
    }

    function applyAutoRunFromQuery() {
      const params = new URLSearchParams(window.location.search);
      const domain = params.get('domain')?.trim();
      const autorun = ['1', 'true', 'yes'].includes((params.get('autorun') || '').toLowerCase());
      if (!domain) return;
      input.value = domain;
      if (autorun) {
        analyze();
        track('tool_autorun_from_workspace', { event_label: domain });
      }
    }

    saveGoalButton?.addEventListener('click', () => {
      if (!latestAnalyzedDomain) {
        if (replayStatus) replayStatus.innerHTML = '<p>Run one analysis first, then save it as a goal.</p>';
        return;
      }
      const result = window.vmiGrowthContext?.addWorkspaceGoal?.({
        text: `Review SEO improvement opportunities for ${latestAnalyzedDomain}`,
        dueInDays: 3
      });
      track('tool_goal_saved', { event_label: latestAnalyzedDomain });
      if (replayStatus) {
        replayStatus.innerHTML = `<p>${result?.status === 'exists' ? 'Goal already exists.' : 'Goal added to workspace.'}</p>`;
      }
    });

    renderSavedResults();
    renderReplayStatus();
    applyAutoRunFromQuery();
  </script>

  <style is:global>
    .snapshot-page {
      width: 100%;
      margin: 0 auto;
      padding: 4rem 0;
    }

    .header-section { text-align: center; margin-bottom: 3rem; }
    .title { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
    .subtitle { color: #666; font-size: 1.125rem; }

    .analyzer-card {
      background: white;
      border: 1px solid #f0f0f0;
      border-radius: 20px;
      padding: 2.5rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);
      margin-bottom: 3rem;
    }

    .input-group { display: flex; gap: 1rem; margin-bottom: 1rem; }
    .url-input { 
      flex: 1; 
      padding: 1rem 1.5rem; 
      border: 2px solid #f0f0f0; 
      border-radius: 12px; 
      font-size: 1rem;
      transition: border-color 0.2s;
    }
    .url-input:focus { border-color: #0066ff; outline: none; }

    .analyze-btn {
      padding: 0 2rem;
      background: #0066ff;
      color: white;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
      min-width: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .analyze-btn:hover { background: #0052cc; }
    .analyze-btn:disabled { background: #ccc; cursor: not-allowed; }
    .example-domains { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; font-size: 0.875rem; color: #666; }
    .example-chip {
      border: 1px solid #ddd;
      background: #fafafa;
      border-radius: 999px;
      padding: 0.3rem 0.75rem;
      font-size: 0.8125rem;
      cursor: pointer;
      color: #333;
    }
    .example-chip:hover { border-color: #999; background: #f4f4f4; }

    .btn-loader {
      width: 20px;
      height: 20px;
      border: 3px solid rgba(255,255,255,0.3);
      border-top-color: white;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    .results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    .card { background: white; border: 1px solid #f0f0f0; border-radius: 16px; padding: 1.5rem; }
    .card-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #f8f8f8; }
    .card-header h2 { font-size: 1rem; font-weight: 700; margin: 0; }
    .icon { width: 20px; height: 20px; color: #0066ff; }

    .tech-item { display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #fafafa; }
    .tech-name { font-weight: 600; }
    .tech-cat { font-size: 0.75rem; color: #888; background: #f5f5f5; padding: 2px 8px; border-radius: 4px; }

    .score-circle { 
      width: 80px; height: 80px; border: 6px solid #eef2ff; border-radius: 50%; 
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem;
    }
    #seo-score-val { font-size: 1.5rem; font-weight: 800; color: #0066ff; line-height: 1; }
    .score-label { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; color: #888; }

    .issue-pill { font-size: 0.75rem; color: #e11d48; background: #fff1f2; padding: 4px 10px; border-radius: 6px; margin-bottom: 0.5rem; }
    .success-pill { font-size: 0.75rem; color: #059669; background: #ecfdf5; padding: 4px 10px; border-radius: 6px; }

    .metric-row { display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.9rem; }
    .error-panel { background: #fff1f2; color: #e11d48; padding: 1rem; border-radius: 12px; border: 1px solid #fda4af; text-align: center; }
    .saved-results { margin-top: 2rem; padding: 1.25rem; border: 1px solid #e2e8f0; border-radius: 12px; background: #fff; }
    .saved-results__header h2 { margin: 0 0 0.75rem 0; border: none; font-size: 1rem; }
    .saved-results__list { margin: 0; padding-left: 1rem; }
    .saved-results__list li { margin-bottom: 0.5rem; }
    .saved-result-btn {
      width: 100%;
