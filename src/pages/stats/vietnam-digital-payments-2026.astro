---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Vietnam Digital Payments Statistics 2026 — E-Wallets, QR, Mobile & Gateway Data";
const description = "A curated roundup of Vietnam digital & mobile payments statistics for 2026: e-wallet users, MoMo/ZaloPay share, QR adoption, payment gateways, cashless growth, BNPL, and fintech market size — with sources.";
const canonical = "https://vnmarketinsights.com/stats/vietnam-digital-payments-2026/";

type Stat = { value: string; label: string; note?: string; source?: string };
type Group = { heading: string; intro: string; stats: Stat[] };

const groups: Group[] = [
  {
    heading: 'Cashless payments & scale',
    intro: 'Vietnam\'s cashless transition accelerated sharply in 2025. Full-year figures come from the State Bank of Vietnam\'s (SBV) review of the 2021–2025 non-cash payment program, released February 2026.',
    stats: [
      { value: '~28×', label: 'Cashless payment value vs GDP (2025)', note: 'Far exceeded the 2021–25 target; the 2030 goal is 30× GDP.', source: 'SBV, 2025' },
      { value: '+42.2%', label: 'Non-cash transaction volume (2025 YoY)', note: 'Value +22.7%; a broad shift from cash to electronic payments.', source: 'SBV, 2025' },
      { value: '+124.1%', label: 'QR payment value growth (2025 YoY)', note: 'Volume +50.9% — the single fastest-growing rail.', source: 'SBV, 2025' },
      { value: '+54.0%', label: 'Internet payment volume (2025 YoY)', note: 'Value +35.8%.', source: 'SBV, 2025' },
      { value: '+36.6%', label: 'Mobile payment volume (2025 YoY)', note: 'Value +20.1%.', source: 'SBV, 2025' },
    ],
  },
  {
    heading: 'Accounts, cards & infrastructure',
    intro: 'Account ownership and merchant acceptance underpin the wallet and QR boom — while cash-out infrastructure shrinks.',
    stats: [
      { value: '232M+', label: 'Individual payment accounts (Dec 2025)', note: 'Up 13.7% year on year.', source: 'SBV, 2025' },
      { value: '164M+', label: 'Bank cards in circulation (Dec 2025)', note: 'Up 5.3% year on year.', source: 'SBV, 2025' },
      { value: '87.0%', label: 'Adults 15+ with a bank account (2024)', note: 'Financial inclusion; 2030 target is 95%.', source: 'SBV, 2024' },
      { value: '+19.9%', label: 'POS terminals (2025)', note: 'ATMs fell 1.1% — acceptance is going cardless.', source: 'SBV, 2025' },
      { value: '−17.3%', label: 'ATM transaction volume (2025)', note: 'Value −6.0%; cash withdrawals in structural decline.', source: 'SBV, 2025' },
    ],
  },
  {
    heading: 'E-wallets & Mobile Money',
    intro: 'E-wallets are the front door to cashless payments; Mobile Money extends reach into rural and underserved areas.',
    stats: [
      { value: '30.3M', label: 'Active e-wallet accounts (2025)', note: '65.8% of 46.0M activated; 49 licensed e-wallet providers (53 payment intermediaries).', source: 'SBV, 2025' },
      { value: '~68%', label: 'MoMo share of e-wallet users', note: 'Most-used wallet in consumer surveys.', source: 'Decision Lab, 2024' },
      { value: '10.9M', label: 'Mobile Money accounts (Sep 2025)', note: '~70% in rural, mountainous, border and island areas.', source: 'SBV, 2025' },
      { value: '290M+', label: 'Mobile Money transactions (9M 2025)', note: '~VND 8.5tn (~$323M) moved via Mobile Money.', source: 'SBV, 2025' },
      { value: '$46.6B', label: 'Mobile payments market size (2025)', note: 'Projected to reach ~$83B by 2031.', source: 'Mordor Intelligence, 2025' },
    ],
  },
  {
    heading: 'NAPAS & QR rails',
    intro: 'NAPAS runs the national retail switch behind VietQR and instant transfers, and is extending it across borders.',
    stats: [
      { value: '32M+', label: 'NAPAS transactions per day (avg 2025)', note: 'System volume +23.7% YoY; 99.997% uptime.', source: 'NAPAS, 2025' },
      { value: '~90M', label: 'Accounts scanning VietQR (Oct 2025)', note: 'VietQR transactions +52% volume / +85% value (10M 2025 YoY).', source: 'NAPAS, 2025' },
      { value: '+27%', label: 'NAPAS247 instant-transfer volume (2025)', note: 'Real-time account-to-account, the backbone of app transfers.', source: 'NAPAS, 2025' },
      { value: '4 countries', label: 'Cross-border QR (2025)', note: 'Thailand, Cambodia and Laos live; China via UnionPay from Dec 2025.', source: 'NAPAS, 2025' },
      { value: 'Tap & Pay', label: 'Contactless rollout (2025)', note: 'NAPAS Tap & Pay on Android plus Apple Pay on iOS.', source: 'NAPAS, 2025' },
    ],
  },
  {
    heading: 'Security, fraud & e-commerce',
    intro: 'Biometric verification and shared fraud-monitoring now sit under the payment system, while online checkout keeps shifting off cash-on-delivery.',
    stats: [
      { value: '146M+', label: 'Customer records biometrically verified (Jan 2026)', note: 'Via chip ID / VNeID; ~100% coverage of active digital accounts.', source: 'SBV, 2026' },
      { value: '2.6M', label: 'Fraud alerts to customers (SIMO, 2025)', note: '831k+ transactions halted; ~VND 3tn protected.', source: 'SBV, 2025' },
      { value: '3.4M', label: 'NAPAS suspicious-transaction alerts (2025)', note: 'Anti-fraud handbook deployed at 47 banks.', source: 'NAPAS, 2025' },
      { value: 'Declining', label: 'Cash-on-delivery (COD) share of e-commerce', note: 'Shifting to wallets, cards and QR at checkout.' },
    ],
  },
];

const allStats = groups.flatMap(g => g.stats);

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Vietnam Digital Payments Statistics 2026",
  "description": description,
  "url": canonical,
  "keywords": ["Vietnam digital payments", "e-wallet", "MoMo", "QR payment", "fintech", "cashless", "BNPL"],
  "creator": {
    "@type": "Organization",
    "name": "VN Market Insights",
    "url": "https://vnmarketinsights.com/"
  },
  "isAccessibleForFree": true,
  "license": "https://vnmarketinsights.com/sources/",
  "variableMeasured": allStats.map(s => s.label)
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Statistics"
  publishedDate="2026-05-30"
  lastUpdated="2026-07-10"
  structuredData={datasetSchema}
  mainClass="container"
>
  <article class="stats-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/payments/">Payments</a>
      <span aria-hidden="true">/</span>
      <span>Digital Payments Statistics 2026</span>
    </nav>

    <header class="stats-header">
      <h1>{title}</h1>
      <p class="stats-lead">
        A curated roundup of the numbers behind Vietnam's cashless transition in 2026 — e-wallet
        adoption, QR payments, banking infrastructure, fintech, and how online checkout is moving
        away from cash. Figures are reference estimates compiled from public industry reports and
        primary sources; ranges reflect differences across analysts. See
        <a href="/sources/">our sources</a> for methodology and citations.
      </p>
    </header>

    {groups.map(group => (
      <section class="stats-section">
        <h2>{group.heading}</h2>
        <p class="stats-section-intro">{group.intro}</p>
        <div class="stats-grid">
          {group.stats.map(stat => (
            <div class="stat-card">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
              {stat.note && <div class="stat-note">{stat.note}</div>}
              {stat.source && <div class="stat-source">{stat.source}</div>}
            </div>
          ))}
        </div>
      </section>
    ))}

    <section class="stats-section">
      <h2>Notes on methodology</h2>
      <p>
        These figures are compiled from official sources to give a current, sourced picture of
        Vietnam's digital payments market. Growth rates are full-year 2025 versus 2024 unless noted.
        For definitions of terms like e-wallet, QR payment, and BNPL, see our <a href="/glossary/">glossary</a>.
      </p>
      <p>
        <strong>Primary sources:</strong> State Bank of Vietnam (SBV) review of the 2021–2025
        non-cash payment program (released February 2026) and monthly payment reports; National
        Payment Corporation of Vietnam (NAPAS) 2025 results; Decision Lab (Connected Consumer
        surveys); Mordor Intelligence (market sizing). Each figure is labelled with its source and
        year; cross-check against the primary source before relying on a specific number.
      </p>
    </section>

    <section class="stats-section">
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/payments/">Digital Payments &amp; Fintech — full overview</a></li>
        <li><a href="/compare/momo-vs-zalopay-vs-viettelpay/">MoMo vs ZaloPay vs ViettelPay — wallet comparison</a></li>
        <li><a href="/stats/vietnam-ecommerce-2026/">Vietnam E-commerce Statistics 2026</a> · <a href="/stats/vietnam-logistics-2026/">Logistics Statistics 2026</a></li>
        <li><a href="/glossary/e-wallet/">E-wallet (glossary)</a> · <a href="/glossary/vietqr/">VietQR (glossary)</a> · <a href="/glossary/fintech/">Fintech (glossary)</a> · <a href="/glossary/bnpl/">BNPL (glossary)</a></li>
        <li><a href="/sources/">Data sources &amp; methodology</a></li>
      </ul>
    </section>

    <p class="stats-footer">
      <a href="/payments/">← Payments overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .stats-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .stats-header { margin-bottom: var(--space-8); }
  .stats-header h1 { border: none; margin-bottom: var(--space-3); }
  .stats-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .stats-lead a { color: var(--color-accent); }
  .stats-section { margin-bottom: var(--space-10); }
  .stats-section-intro { color: var(--color-text-muted); margin-bottom: var(--space-4); line-height: 1.55; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4); }
  .stat-card { border: 1px solid var(--color-border-light); border-radius: 2px; padding: var(--space-4); background: var(--color-bg-subtle); }
  .stat-value { font-size: var(--text-2xl); font-weight: 700; color: var(--color-accent); line-height: 1.1; margin-bottom: var(--space-2); }
  .stat-label { font-weight: 600; color: var(--color-text); line-height: 1.4; margin-bottom: var(--space-2); }
  .stat-note { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.5; }
  .stat-source { margin-top: var(--space-2); font-size: var(--text-xs); color: var(--color-text-light, var(--color-text-muted)); font-style: italic; }
  .stats-section p a { color: var(--color-accent); }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .stats-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .stats-footer a { color: var(--color-text-muted); }
  .stats-footer a:hover { color: var(--color-accent); }
</style>
