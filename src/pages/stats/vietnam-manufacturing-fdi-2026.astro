---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Vietnam Manufacturing & FDI Statistics 2026 — Industry & Investment Data";
const description = "A curated roundup of Vietnam manufacturing and FDI statistics for 2026: foreign investment, key export sectors, trade agreements, industrial clusters, and the 'China + 1' shift — with sources.";
const canonical = "https://vnmarketinsights.com/stats/vietnam-manufacturing-fdi-2026/";

type Stat = { value: string; label: string; note?: string; source?: string };
type Group = { heading: string; intro: string; stats: Stat[] };

const groups: Group[] = [
  {
    heading: 'Foreign direct investment (2025)',
    intro: 'FDI is the engine of Vietnam’s manufacturing rise — disbursement hit a record in 2025 even as global flows softened.',
    stats: [
      { value: '~$38.4B', label: 'Registered FDI (2025)', note: 'Newly registered, adjusted, and capital contributions.', source: 'GSO / MPI / FIA, 2025' },
      { value: '~$27.6B', label: 'Disbursed FDI (2025)', note: 'Record high; +9% YoY — the most in five years.', source: 'GSO / MPI / FIA, 2025' },
      { value: '~60%+', label: 'Manufacturing share of FDI', note: 'Processing & manufacturing dominate inflows.', source: 'MPI / FIA, 2025' },
      { value: 'HCMC · Bac Ninh · Hanoi', label: 'Top FDI destinations (2025)', note: '~$7.1B · $5.7B · $4.3B registered.', source: 'FIA / MoF, 2025' },
      { value: 'KR · SG · CN · JP', label: 'Top source economies', note: 'Korea, Singapore, China, Japan; plus Taiwan.', source: 'FIA, 2025' },
    ],
  },
  {
    heading: 'Industrial output (2025)',
    intro: 'Industrial production grew at its fastest pace in seven years, led by the processing-and-manufacturing pillar.',
    stats: [
      { value: '+9.2%', label: 'Industrial production index (IIP, 2025)', note: 'Highest since 2019; up from +8.2% in 2024.', source: 'GSO / NSO, 2025' },
      { value: '+10.5%', label: 'Processing & manufacturing (2025)', note: 'Contributed 8.4pp of IIP growth; highest 2019–2025.', source: 'GSO / NSO, 2025' },
      { value: '53.0', label: 'S&P Global Manufacturing PMI (Dec 2025)', note: 'Eighth straight month of expansion; 21-month-high confidence.', source: 'S&P Global, 2025' },
      { value: '+22%', label: 'Motor-vehicle manufacturing (2025)', note: 'Led sub-sectors; autos output +39.1%.', source: 'GSO / NSO, 2025' },
      { value: '+6.7%', label: 'Industrial output forecast (2026)', note: 'S&P Global projection for the year ahead.', source: 'S&P Global, 2026F' },
    ],
  },
  {
    heading: 'Key export sectors (2025)',
    intro: 'A handful of manufacturing sectors account for the bulk of a record $475B export haul.',
    stats: [
      { value: '$106B', label: 'Computers, electronics & components', note: 'First-ever $100B group; +46% YoY, 22.5% of exports.', source: 'GSO / Customs, 2025' },
      { value: '$58.4B', label: 'Machinery & equipment', note: 'Up ~11.9% YoY.', source: 'GSO / Customs, 2025' },
      { value: '$57.6B', label: 'Phones & accessories', note: 'Up ~6.9% YoY.', source: 'GSO / Customs, 2025' },
      { value: '$39.3B', label: 'Textiles & garments', note: 'Up ~6.1% YoY; a major employer.', source: 'GSO / Customs, 2025' },
      { value: '$24.0B', label: 'Footwear', note: 'Up ~4.8% YoY; a global production hub.', source: 'GSO / Customs, 2025' },
    ],
  },
  {
    heading: 'Trade & market access (2025)',
    intro: 'A dense web of trade agreements underpins Vietnam’s export competitiveness and a tenth straight goods surplus.',
    stats: [
      { value: '~$475B', label: 'Total exports (2025)', note: 'Up ~17% YoY; 36 products each topped $1B.', source: 'GSO / NSO, 2025' },
      { value: '~$20B', label: 'Goods trade surplus (2025)', note: 'Tenth consecutive annual surplus.', source: 'GSO / NSO, 2025' },
      { value: '16+', label: 'Free trade agreements', note: 'Incl. CPTPP, EVFTA (since 2020), RCEP.', source: 'MoIT' },
      { value: 'US / China / EU', label: 'Largest trade partners', note: 'US is the top export market; China the top import source.', source: 'GSO, 2025' },
      { value: 'China + 1', label: 'Key structural driver', note: 'Supply-chain diversification into Vietnam.' },
    ],
  },
  {
    heading: 'Industrial base & clusters',
    intro: 'Production concentrates in northern and southern industrial corridors built around export-oriented FDI.',
    stats: [
      { value: 'Bac Ninh · Hai Phong', label: 'Northern electronics cluster', note: 'Samsung, Foxconn, LG and suppliers.' },
      { value: 'Binh Duong · Dong Nai', label: 'Southern industrial belt', note: 'Diverse manufacturing around HCMC.' },
      { value: 'Industrial parks', label: 'Primary FDI vehicle', note: 'Zoned sites with tax and infrastructure incentives.' },
      { value: 'Lower vs China', label: 'Labor-cost advantage', note: 'A core draw for "+1" investment, though wages are rising.' },
    ],
  },
];

const allStats = groups.flatMap(g => g.stats);

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Vietnam Manufacturing & FDI Statistics 2026",
  "description": description,
  "url": canonical,
  "keywords": ["Vietnam manufacturing", "FDI", "foreign direct investment", "China + 1", "exports", "CPTPP", "EVFTA", "industrial parks"],
  "creator": {
    "@type": "Organization",
    "name": "VN Market Insights",
    "url": "https://vnmarketinsights.com/"
  },
  "isAccessibleForFree": true,
  "license": "https://vnmarketinsights.com/sources/",
  "variableMeasured": allStats.map(s => s.label)
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Statistics"
  publishedDate="2026-05-31"
  lastUpdated="2026-07-16"
  structuredData={datasetSchema}
  mainClass="container"
>
  <article class="stats-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/regulations/">Regulations</a>
      <span aria-hidden="true">/</span>
      <span>Manufacturing &amp; FDI Statistics 2026</span>
    </nav>

    <header class="stats-header">
      <h1>{title}</h1>
      <p class="stats-lead">
        A curated roundup of the numbers behind Vietnam's manufacturing boom and foreign investment
        in 2026 — FDI inflows, key export sectors, trade agreements, industrial clusters, and the
        "China + 1" shift. Figures are reference estimates and qualitative descriptors compiled from
        public sources; values vary across analysts and periods. See
        <a href="/sources/">our sources</a> for methodology and citations.
      </p>
    </header>

    {groups.map(group => (
      <section class="stats-section">
        <h2>{group.heading}</h2>
        <p class="stats-section-intro">{group.intro}</p>
        <div class="stats-grid">
          {group.stats.map(stat => (
            <div class="stat-card">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
              {stat.note && <div class="stat-note">{stat.note}</div>}
              {stat.source && <div class="stat-source">{stat.source}</div>}
            </div>
          ))}
        </div>
      </section>
    ))}

    <section class="stats-section">
      <h2>Notes on methodology</h2>
      <p>
        These statistics are reference points intended to give a directional picture of Vietnam's
        manufacturing and FDI landscape. Where hard figures vary across analysts and reporting
        periods, we use qualitative descriptors rather than spurious precision. For definitions of
        terms like FDI, China + 1, CPTPP, and EVFTA, see our <a href="/glossary/">glossary</a>.
      </p>
      <p>
        <strong>Primary sources:</strong> General Statistics Office / National Statistics Office
        (GSO/NSO — 2025 socio-economic data, IIP); Ministry of Planning and Investment / Foreign
        Investment Agency (MPI/FIA); Vietnam Customs (export data); S&amp;P Global (Vietnam
        Manufacturing PMI); Ministry of Industry and Trade (MoIT). Figures are full-year 2025 unless
        noted; cross-check the primary source before relying on a specific number.
      </p>
    </section>

    <section class="stats-section">
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/regulations/">Regulatory environment — full overview</a></li>
        <li><a href="/compare/vietnam-vs-china-manufacturing/">Vietnam vs China manufacturing — comparison</a></li>
        <li><a href="/guides/how-to-source-manufacturing-from-vietnam/">How to source manufacturing from Vietnam</a> · <a href="/guides/vietnam-market-entry-guide/">Market entry guide</a></li>
        <li><a href="/stats/vietnam-ecommerce-2026/">E-commerce</a> · <a href="/stats/vietnam-stock-market-2026/">Stock Market</a> statistics</li>
        <li><a href="/glossary/fdi/">FDI</a> · <a href="/glossary/china-1/">China + 1</a> · <a href="/glossary/cptpp/">CPTPP</a> · <a href="/glossary/evfta/">EVFTA</a> (glossary)</li>
        <li><a href="/sources/">Data sources &amp; methodology</a></li>
      </ul>
    </section>

    <p class="stats-footer">
      <a href="/regulations/">← Regulations overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .stats-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .stats-header { margin-bottom: var(--space-8); }
  .stats-header h1 { border: none; margin-bottom: var(--space-3); }
  .stats-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .stats-lead a { color: var(--color-accent); }
  .stats-section { margin-bottom: var(--space-10); }
  .stats-section-intro { color: var(--color-text-muted); margin-bottom: var(--space-4); line-height: 1.55; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4); }
  .stat-card { border: 1px solid var(--color-border-light); border-radius: 2px; padding: var(--space-4); background: var(--color-bg-subtle); }
  .stat-value { font-size: var(--text-2xl); font-weight: 700; color: var(--color-accent); line-height: 1.1; margin-bottom: var(--space-2); }
  .stat-label { font-weight: 600; color: var(--color-text); line-height: 1.4; margin-bottom: var(--space-2); }
  .stat-note { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.5; }
  .stat-source { margin-top: var(--space-2); font-size: var(--text-xs); color: var(--color-text-light, var(--color-text-muted)); font-style: italic; }
  .stats-section p a { color: var(--color-accent); }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .stats-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .stats-footer a { color: var(--color-text-muted); }
  .stats-footer a:hover { color: var(--color-accent); }
</style>
