---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Vietnam Consumer & Internet Statistics 2026 — Digital Behavior Data";
const description = "A curated roundup of Vietnam consumer and internet statistics for 2026: population, internet and smartphone penetration, social media, online shopping behavior, and demographics — with sources.";
const canonical = "https://vnmarketinsights.com/stats/vietnam-consumer-internet-2026/";

type Stat = { value: string; label: string; note?: string; source?: string };
type Group = { heading: string; intro: string; stats: Stat[] };

const groups: Group[] = [
  {
    heading: 'Population & demographics',
    intro: 'A large, young population is the foundation of Vietnam\'s consumer and digital growth.',
    stats: [
      { value: '~101.3M', label: 'Total population (2025)', note: '15th most populous country.', source: 'GSO, 2025' },
      { value: '~33', label: 'Median age', note: 'Young, working-age-heavy.', source: 'UN / GSO est.' },
      { value: '72.5%', label: 'Online shoppers who are Gen Z / Millennial', note: 'Brand-curious and mobile-first.', source: 'Industry, 2025' },
      { value: 'Urbanizing', label: 'Population trend', note: 'Growing urban middle class.' },
      { value: 'Tier-2/3', label: 'Next wave of demand', note: 'Rising provincial consumption.' },
    ],
  },
  {
    heading: 'Internet & connectivity',
    intro: 'Connectivity is high, fast-improving, and overwhelmingly mobile — shaping how Vietnamese consume and shop.',
    stats: [
      { value: '85.6M', label: 'Internet users (late 2025)', note: 'Up from 79.8M at the start of 2025.', source: 'DataReportal, 2026' },
      { value: '84.2%', label: 'Internet penetration', note: '16.1M people (15.9%) remained offline.', source: 'DataReportal, 2026' },
      { value: '137M', label: 'Mobile connections', note: '134% of population — multiple SIMs per person is the norm.', source: 'DataReportal / GSMA, 2026' },
      { value: '84.4%', label: 'Smartphone penetration', note: 'Well above the ~63% global average.', source: 'We Are Social / Meltwater, 2025' },
      { value: '152 Mbps', label: 'Median mobile download speed', note: 'Up ~167% year on year.', source: 'DataReportal, 2026' },
    ],
  },
  {
    heading: 'Social media & content',
    intro: 'Vietnamese consumers are heavy social and short-video users, driving social commerce.',
    stats: [
      { value: '79.0M', label: 'Social media identities (late 2025)', note: '77.6% of population; +7.2% YoY.', source: 'DataReportal, 2026' },
      { value: '89.6%', label: 'Facebook reach of internet users', note: 'Still the most-used platform.', source: 'DataReportal, 2026' },
      { value: '86.6%', label: 'Zalo penetration among internet users', note: 'Homegrown super-app: chat, pay, news, commerce.', source: 'DataReportal, 2026' },
      { value: '76.1M', label: 'TikTok users 18+ (late 2025)', note: '80.9% reach; 80%+ of Gen Z active.', source: 'DataReportal, 2026' },
      { value: '62.1M', label: 'YouTube users', note: 'Long-form and short-form video at scale.', source: 'DataReportal, 2026' },
    ],
  },
  {
    heading: 'Online shopping behavior',
    intro: 'Online shopping is mainstream, mobile-first, social-influenced, and increasingly cashless.',
    stats: [
      { value: '92%', label: 'Shop primarily on smartphones', note: 'Mobile-first commerce at scale.', source: 'Industry, 2025' },
      { value: '~50%', label: 'Buy online at least weekly', note: 'Habitual, not occasional.', source: 'Industry, 2025' },
      { value: '$16B', label: 'Spent via top-4 platforms (2025)', note: 'VND 429.7tn across Shopee, TikTok Shop, Lazada, Tiki; +35%.', source: 'Metric, 2025' },
      { value: 'Social-first', label: 'Discovery channel', note: 'Shopping often starts on social feeds.' },
      { value: 'Declining COD', label: 'Payment trend', note: 'Shift toward wallets and QR at checkout.' },
    ],
  },
  {
    heading: 'Spending & economy',
    intro: 'Rising incomes and a growing middle class expand the addressable consumer market.',
    stats: [
      { value: '$5,026', label: 'GDP per capita (2025)', note: 'Up from ~$4,700 in 2024; rising discretionary spend.', source: 'GSO, 2025' },
      { value: '8.02%', label: 'GDP growth (2025)', note: 'Among Asia\'s fastest-growing economies.', source: 'GSO, 2025' },
      { value: '$269B', label: 'Total retail sales (2025)', note: '+9–10% YoY — a five-year high.', source: 'MoIT, 2025' },
      { value: 'Growing', label: 'Middle class', note: 'Expanding consumption and premiumization.' },
    ],
  },
];

const allStats = groups.flatMap(g => g.stats);

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Vietnam Consumer & Internet Statistics 2026",
  "description": description,
  "url": canonical,
  "keywords": ["Vietnam consumers", "internet penetration", "smartphone", "social media", "online shopping", "demographics", "Gen Z"],
  "creator": {
    "@type": "Organization",
    "name": "VN Market Insights",
    "url": "https://vnmarketinsights.com/"
  },
  "isAccessibleForFree": true,
  "license": "https://vnmarketinsights.com/sources/",
  "variableMeasured": allStats.map(s => s.label)
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Statistics"
  publishedDate="2026-05-30"
  lastUpdated="2026-07-16"
  structuredData={datasetSchema}
  mainClass="container"
>
  <article class="stats-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/consumers/">Consumers</a>
      <span aria-hidden="true">/</span>
      <span>Consumer &amp; Internet Statistics 2026</span>
    </nav>

    <header class="stats-header">
      <h1>{title}</h1>
      <p class="stats-lead">
        A curated roundup of the numbers behind Vietnam's digital consumer in 2026 — population and
        demographics, internet and smartphone penetration, social media, online shopping behavior,
        and spending. Figures are reference estimates compiled from public industry reports and
        primary sources; ranges and qualitative descriptors reflect differences across analysts.
        See <a href="/sources/">our sources</a> for methodology and citations.
      </p>
    </header>

    {groups.map(group => (
      <section class="stats-section">
        <h2>{group.heading}</h2>
        <p class="stats-section-intro">{group.intro}</p>
        <div class="stats-grid">
          {group.stats.map(stat => (
            <div class="stat-card">
              <div class="stat-value">{stat.value}</div>
              <div class="stat-label">{stat.label}</div>
              {stat.note && <div class="stat-note">{stat.note}</div>}
              {stat.source && <div class="stat-source">{stat.source}</div>}
            </div>
          ))}
        </div>
      </section>
    ))}

    <section class="stats-section">
      <h2>Notes on methodology</h2>
      <p>
        These statistics are reference estimates intended to give a directional picture of
        Vietnam's digital consumer. Where hard figures vary across analysts, we use ranges or
        qualitative descriptors rather than spurious precision. For definitions of terms like
        super-app, social commerce, and live commerce, see our <a href="/glossary/">glossary</a>.
      </p>
      <p>
        <strong>Primary sources:</strong> DataReportal "Digital 2026: Vietnam" (We Are Social ·
        Meltwater · GSMA Intelligence · Kepios, data as of late 2025); General Statistics Office
        (GSO); Metric (E-commerce Report 2025); MoIT. Each figure is labelled with its year;
        cross-check the primary source before relying on a specific number.
      </p>
    </section>

    <section class="stats-section">
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/consumers/">Vietnam Consumers &amp; Demographics — full overview</a></li>
        <li><a href="/insights/consumer-internet-penetration/">Consumer internet penetration — insights article</a> · <a href="/insights/mobile-first-behavior/">Mobile-first behavior</a></li>
        <li><a href="/stats/vietnam-ecommerce-2026/">E-commerce Statistics 2026</a> · <a href="/stats/vietnam-digital-payments-2026/">Digital Payments Statistics 2026</a> · <a href="/stats/vietnam-logistics-2026/">Logistics Statistics 2026</a></li>
        <li><a href="/glossary/super-app/">Super-app (glossary)</a> · <a href="/glossary/live-commerce/">Live commerce (glossary)</a> · <a href="/glossary/gen-z-gen-y/">Gen Z / Gen Y (glossary)</a></li>
        <li><a href="/sources/">Data sources &amp; methodology</a></li>
      </ul>
    </section>

    <p class="stats-footer">
      <a href="/consumers/">← Consumers overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .stats-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .stats-header { margin-bottom: var(--space-8); }
  .stats-header h1 { border: none; margin-bottom: var(--space-3); }
  .stats-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .stats-lead a { color: var(--color-accent); }
  .stats-section { margin-bottom: var(--space-10); }
  .stats-section-intro { color: var(--color-text-muted); margin-bottom: var(--space-4); line-height: 1.55; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-4); }
  .stat-card { border: 1px solid var(--color-border-light); border-radius: 2px; padding: var(--space-4); background: var(--color-bg-subtle); }
  .stat-value { font-size: var(--text-2xl); font-weight: 700; color: var(--color-accent); line-height: 1.1; margin-bottom: var(--space-2); }
  .stat-label { font-weight: 600; color: var(--color-text); line-height: 1.4; margin-bottom: var(--space-2); }
  .stat-note { font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.5; }
  .stat-source { margin-top: var(--space-2); font-size: var(--text-xs); color: var(--color-text-light, var(--color-text-muted)); font-style: italic; }
  .stats-section p a { color: var(--color-accent); }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .stats-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .stats-footer a { color: var(--color-text-muted); }
  .stats-footer a:hover { color: var(--color-accent); }
</style>
