---
import BaseLayout from '@layouts/BaseLayout.astro';
import { calculateSignal, calculateShortTerm } from '@utils/stockSignals';
import {
  SAMPLE_TICKER,
  SAMPLE_BARS,
  SAMPLE_FUNDAMENTALS,
} from '../../data/sampleSignalExample';

const title = "Stock Signal Scoring — A Worked Example (2026)";
const description = "A concrete, worked example of the VN Market stock-signal methodology: an illustrative price series scored 0–100 by the live engine, with every fundamental and technical reason shown and the short-term signal bias explained.";
const canonical = "https://vnmarketinsights.com/guides/stock-signal-worked-example/";

// Run the actual ported engine at build time over an illustrative series.
const signal = calculateSignal(SAMPLE_TICKER, SAMPLE_FUNDAMENTALS, SAMPLE_BARS);
const shortTerm = calculateShortTerm(SAMPLE_TICKER, SAMPLE_BARS);

const verdictColorHex: Record<string, string> = {
  green: '#16a34a',
  yellow: '#ca8a04',
  orange: '#ea580c',
  red: '#c8102e',
};
const verdictHex = verdictColorHex[signal.verdictColor] ?? '#666';

const lastBar = SAMPLE_BARS[SAMPLE_BARS.length - 1];
const firstBar = SAMPLE_BARS[0];
const periodChangePct = ((lastBar.c - firstBar.c) / firstBar.c) * 100;

const fundamentalRows = [
  { label: 'P/E', value: `${SAMPLE_FUNDAMENTALS.pe.toFixed(1)}×` },
  { label: 'ROE', value: `${SAMPLE_FUNDAMENTALS.roe.toFixed(1)}%` },
  { label: 'Debt / Equity', value: `${SAMPLE_FUNDAMENTALS.debtToEquity.toFixed(2)}×` },
  { label: 'Profit growth (YoY)', value: `${SAMPLE_FUNDAMENTALS.epsGrowth.toFixed(1)}%` },
  { label: 'Dividend yield', value: `${SAMPLE_FUNDAMENTALS.divYield.toFixed(1)}%` },
];

const faqs = [
  {
    question: "Is this a real stock or live data?",
    answer: "No. This page uses a deterministic, synthetic price series labeled DEMO purely to demonstrate the scoring methodology. It is not a real ticker, not live market data, and not a recommendation. The point is to show what the engine outputs when fed a realistic series."
  },
  {
    question: "How was the 0–100 score produced?",
    answer: "The same rules-based engine documented in 'How stock signals are scored' runs over the example: five fundamental metrics contribute up to 50 points and four technical checks contribute up to 50, summed into the composite and mapped to a verdict. Every line in the breakdown below is the engine's own generated reason."
  },
  {
    question: "Can this show a real Vietnamese stock?",
    answer: "Yes — the engine is data-source agnostic. Feeding it a real OHLCV history and the company's fundamentals produces a real technical-and-fundamental outlook the same way. The worked example simply uses an illustrative series so the methodology is reproducible and free of live-data dependencies."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Guide"
  publishedDate="2026-06-27"
  lastUpdated="2026-06-27"
  structuredData={faqSchema}
  mainClass="container"
>
  <article class="guide-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/guides/">Guides</a>
      <span aria-hidden="true">/</span>
      <span>Stock Signal — Worked Example</span>
    </nav>

    <header class="guide-header">
      <h1>{title}</h1>
      <p class="guide-lead">
        This is the <a href="/guides/how-stock-signals-are-scored/">scoring methodology</a> made
        concrete. The engine below is fed an illustrative price series and a set of fundamentals,
        then produces a 0–100 score, a verdict, and the exact reasons behind it — the same output
        a real Vietnamese stock would generate.
      </p>
      <p class="disclaimer">
        ⚠️ <strong>Illustrative only.</strong> “DEMO” is a synthetic, deterministic series — not a
        real ticker, not live data, and not investment advice.
      </p>
    </header>

    <section>
      <div class="score-hero" style={`--verdict: ${verdictHex}`}>
        <div class="score-dial">
          <span class="score-num">{signal.score}</span>
          <span class="score-den">/ 100</span>
        </div>
        <div class="score-meta">
          <span class="score-verdict">{signal.verdict}</span>
          <span class="score-sub">{SAMPLE_TICKER} · illustrative</span>
          <div class="score-split">
            <span>Fundamental <strong>{signal.fundamentalScore}</strong>/50</span>
            <span>Technical <strong>{signal.technicalScore}</strong>/50</span>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2>The inputs</h2>
      <div class="inputs-grid">
        <div class="input-block">
          <h3>Fundamentals</h3>
          <table class="kv-table">
            <tbody>
              {fundamentalRows.map((r) => (
                <tr><td>{r.label}</td><td class="num">{r.value}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="input-block">
          <h3>Price series</h3>
          <table class="kv-table">
            <tbody>
              <tr><td>Sessions</td><td class="num">{SAMPLE_BARS.length}</td></tr>
              <tr><td>Last close</td><td class="num">{lastBar.c.toFixed(2)}</td></tr>
              <tr><td>Period change</td><td class="num">{periodChangePct > 0 ? '+' : ''}{periodChangePct.toFixed(1)}%</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section>
      <h2>Why it scored {signal.score}</h2>
      <p>Every line below is generated by the engine — the audit trail behind the number:</p>
      <ul class="reason-list">
        {signal.reasons.map((r) => (
          <li>{r}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Short-term signals</h2>
      <p>
        Separate from the long-term score, the engine scans for short-term trading signals and tallies
        a bias. For this series:
        <span class={`bias-pill bias-${shortTerm.biasColor}`}>{shortTerm.bias}</span>
        (bullish strength {shortTerm.bullCount} vs bearish {shortTerm.bearCount}).
      </p>
      {shortTerm.signals.length > 0 ? (
        <ul class="signal-list">
          {shortTerm.signals.map((s) => (
            <li class={`signal-item dir-${s.direction}`}>
              <div class="signal-head">
                <span class="signal-label">{s.label}</span>
                <span class="signal-tf">{s.timeframe} · strength {s.strength}</span>
              </div>
              <p class="signal-detail">{s.detail}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="note">No short-term signals are firing on this series right now.</p>
      )}
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer-container">
              <p class="faq-answer">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/guides/how-stock-signals-are-scored/">How stock signals are scored — full methodology</a></li>
        <li><a href="/guides/how-to-invest-in-vietnam-stock-market/">How to invest in the Vietnam stock market</a></li>
        <li><a href="/compare/vn-index-vs-vn30/">VN-Index vs VN30 compared</a></li>
        <li>
          Glossary: <a href="/glossary/moving-average/">Moving average</a> ·
          <a href="/glossary/rsi/">RSI</a> · <a href="/glossary/macd/">MACD</a> ·
          <a href="/glossary/golden-cross/">Golden Cross</a> ·
          <a href="/glossary/bollinger-bands/">Bollinger Bands</a>
        </li>
      </ul>
    </section>

    <p class="guide-footer">
      <a href="/guides/">← All guides</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .guide-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .guide-header { margin-bottom: var(--space-6); }
  .guide-header h1 { border: none; margin-bottom: var(--space-3); }
  .guide-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .guide-lead a { color: var(--color-accent); }
  .disclaimer { font-size: var(--text-sm); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent) 7%, transparent); border-left: 3px solid var(--color-accent); padding: var(--space-2) var(--space-3); border-radius: 2px; margin-top: var(--space-3); }

  .score-hero { display: flex; gap: var(--space-6); align-items: center; flex-wrap: wrap; border: 1px solid var(--color-border-light); border-top: 4px solid var(--verdict); border-radius: 4px; padding: var(--space-5) var(--space-6); background: var(--color-bg-subtle); }
  .score-dial { display: flex; align-items: baseline; gap: 0.25rem; }
  .score-num { font-family: var(--font-serif, Georgia, serif); font-size: 3.5rem; font-weight: 700; line-height: 1; color: var(--verdict); font-variant-numeric: tabular-nums; }
  .score-den { font-size: var(--text-lg); color: var(--color-text-muted); }
  .score-meta { display: flex; flex-direction: column; gap: 0.35rem; }
  .score-verdict { font-size: var(--text-xl); font-weight: 700; color: var(--verdict); }
  .score-sub { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); }
  .score-split { display: flex; gap: var(--space-4); margin-top: 0.25rem; font-size: var(--text-sm); color: var(--color-text-muted); }
  .score-split strong { color: var(--color-text); }

  .inputs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-4); }
  .input-block h3 { font-size: var(--text-base); margin: 0 0 var(--space-2); }
  .kv-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .kv-table td { padding: var(--space-2) var(--space-3); border-bottom: 1px solid var(--color-border-light); }
  .kv-table td.num { text-align: right; font-weight: 600; font-variant-numeric: tabular-nums; }

  .reason-list { list-style: none; padding: 0; margin: var(--space-4) 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .reason-list li { padding: var(--space-2) var(--space-3); background: var(--color-bg-subtle); border: 1px solid var(--color-border-light); border-radius: 2px; line-height: 1.5; font-size: var(--text-sm); }

  .bias-pill { display: inline-block; margin: 0 0.35rem; padding: 0.1rem 0.6rem; border-radius: 999px; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .bias-green { background: color-mix(in srgb, #16a34a 18%, transparent); color: #15803d; }
  .bias-red { background: color-mix(in srgb, var(--color-accent) 18%, transparent); color: var(--color-accent); }
  .bias-gray { background: var(--color-border-light); color: var(--color-text-muted); }

  .signal-list { list-style: none; padding: 0; margin: var(--space-4) 0; display: flex; flex-direction: column; gap: var(--space-3); }
  .signal-item { border: 1px solid var(--color-border-light); border-left-width: 4px; border-radius: 2px; padding: var(--space-3) var(--space-4); background: var(--color-bg-subtle); }
  .signal-item.dir-bullish { border-left-color: #16a34a; }
  .signal-item.dir-bearish { border-left-color: var(--color-accent); }
  .signal-head { display: flex; justify-content: space-between; gap: var(--space-3); flex-wrap: wrap; }
  .signal-label { font-weight: 700; }
  .signal-tf { font-size: var(--text-xs); color: var(--color-text-muted); white-space: nowrap; }
  .signal-detail { margin: 0.4rem 0 0; font-size: var(--text-sm); color: var(--color-text-muted); line-height: 1.5; }

  .note { font-size: var(--text-sm); color: var(--color-text-muted); }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .guide-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .guide-footer a { color: var(--color-text-muted); }
  .guide-footer a:hover { color: var(--color-accent); }
</style>
