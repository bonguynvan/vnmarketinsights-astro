---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Shopee vs Lazada vs TikTok Shop — Vietnam E-Commerce Platform Comparison (2026)";
const description = "Side-by-side comparison of Shopee, Lazada, and TikTok Shop in Vietnam. Market share, GMV, seller economics, logistics integration, live commerce, and which platform to prioritize.";
const canonical = "https://vnmarketinsights.com/compare/shopee-vs-lazada-vs-tiktok-shop/";

const platforms = [
  {
    name: 'Shopee',
    parent: 'Sea Group (Singapore)',
    launched: '2016 (Vietnam)',
    share: '~56% of marketplace GMV (2025)',
    sellers: '~210,000 active sellers (2025)',
    primaryStrength: 'Largest user base, deep promotion engine, integrated SPX logistics',
    bestFor: 'General merchandise sellers chasing reach; high-velocity discounted SKUs',
  },
  {
    name: 'Lazada',
    parent: 'Alibaba Group (China)',
    launched: '2012 (Vietnam)',
    share: '~2–3% of marketplace GMV (2025, with Tiki)',
    sellers: 'Smaller but more curated seller base',
    primaryStrength: 'LazMall verified brand channel, strong cross-border infrastructure',
    bestFor: 'Authorized brands, mid-premium positioning, cross-border from China',
  },
  {
    name: 'TikTok Shop',
    parent: 'ByteDance (China)',
    launched: '2022 (Vietnam)',
    share: '~41% of marketplace GMV (2025), up from ~29% in 2024',
    sellers: '~267,000 sellers (H1 2025, +96% YoY)',
    primaryStrength: 'Native live commerce, short-video product discovery',
    bestFor: 'Fashion, beauty, FMCG with livestream-friendly demos',
  },
];

const faqs = [
  {
    question: "Which is the biggest e-commerce platform in Vietnam?",
    answer: "Shopee is the largest by gross merchandise value (GMV) at about 56% of Vietnam's four-platform marketplace GMV in 2025 (Metric). TikTok Shop is now a clear second at about 41% — up from roughly 29% in 2024 — having overtaken Lazada. Lazada and Tiki together hold only about 3%. Combined 2025 GMV across the four platforms was about VND 429.7 trillion (~$16.4B), up ~35% year on year on 3.94 billion products sold."
  },
  {
    question: "What is the difference between Shopee and Lazada in Vietnam?",
    answer: "Shopee runs an aggressive promotion engine (free-shipping subsidies, gamified daily campaigns, low-friction signups) and dominates value-conscious mass-market segments. Lazada positions higher with LazMall — a verified-brand channel for authorized sellers — and leans on Alibaba's cross-border infrastructure for imports from China. Shopee's seller pool is broader; Lazada's is more curated."
  },
  {
    question: "How big is TikTok Shop in Vietnam?",
    answer: "Very big now. TikTok Shop reached about 41% of Vietnam's marketplace GMV in 2025 — up from roughly 29% in 2024 — a clear second behind Shopee and well ahead of Lazada. Its growth is driven by livestream commerce and short-video product discovery, with fashion, beauty, and FMCG over-indexing; active sellers surged about 96% to roughly 267,000 in the first half of 2025."
  },
  {
    question: "Which platform should a new seller in Vietnam start with?",
    answer: "For volume and general merchandise, Shopee is the typical first listing — onboarding is fast and reach is widest. For authorized brands wanting authenticity signals, LazMall on Lazada is the higher-quality channel. For categories that demonstrate well on video (fashion, beauty, accessories, FMCG novelties), TikTok Shop offers the lowest-cost path to demand creation via livestreams."
  },
  {
    question: "What are platform fees on Shopee, Lazada, and TikTok Shop in Vietnam?",
    answer: "All three platforms charge a combination of commission (typically 2–5% depending on category), payment-processing fees, and optional promotional / advertising fees. Total take rate after voucher subsidies and ad spend is meaningfully higher than headline commission — typically 8–15% for sellers running on-platform ads."
  },
  {
    question: "Do these platforms handle logistics?",
    answer: "Yes. Shopee operates SPX Express; Lazada has LEX (Lazada eLogistics); TikTok Shop integrates with third-party couriers (GHN, GHTK, J&T, Ninja Van) and TikTok's own fulfillment pilots. Same-day and next-day delivery are standard in Hanoi and HCMC; tier-2/3 cities typically see 2–4 days."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Comparison"
  publishedDate="2026-05-30"
  lastUpdated="2026-07-22"
  structuredData={faqSchema}
  mainClass="container"
>
  <article class="compare-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/ecommerce/">E-commerce</a>
      <span aria-hidden="true">/</span>
      <span>Platform Comparison</span>
    </nav>

    <header class="compare-header">
      <h1>{title}</h1>
      <p class="compare-lead">
        Shopee, Lazada, and TikTok Shop are the three e-commerce platforms that own most of Vietnam's
        online retail GMV. This page compares them on market share, seller economics, logistics, and
        the situations in which each platform is the right starting point. Marketplace GMV shares
        are full-year 2025 (Metric); precise splits vary across analysts.
      </p>
    </header>

    <section>
      <h2>At a glance</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Dimension</th>
              {platforms.map(p => <th>{p.name}</th>)}
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Parent</th>
              {platforms.map(p => <td>{p.parent}</td>)}
            </tr>
            <tr>
              <th>Launched (VN)</th>
              {platforms.map(p => <td>{p.launched}</td>)}
            </tr>
            <tr>
              <th>Market share (GMV)</th>
              {platforms.map(p => <td>{p.share}</td>)}
            </tr>
            <tr>
              <th>Seller base</th>
              {platforms.map(p => <td>{p.sellers}</td>)}
            </tr>
            <tr>
              <th>Primary strength</th>
              {platforms.map(p => <td>{p.primaryStrength}</td>)}
            </tr>
            <tr>
              <th>Best for</th>
              {platforms.map(p => <td>{p.bestFor}</td>)}
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>Shopee</h2>
      <p>
        Shopee, a Sea Group subsidiary, has been Vietnam's e-commerce market leader since
        roughly 2018, holding about 56% of marketplace GMV in 2025 — a lead that has narrowed as
        TikTok Shop scaled to ~41%. Its dominance rests on three things: a relentless
        free-shipping subsidy program that lowers buyer friction, gamified daily campaigns
        (Shopee Live, vouchers, flash sales) that drive impulse repeat-purchase, and SPX Express
        — its in-house logistics arm that gives Shopee end-to-end control of the fulfillment
        experience in major cities.
      </p>
      <p>
        <strong>Seller economics:</strong> Lowest barrier to onboarding. Headline commission of
        roughly 2–4% per category, plus payment fees and significant ad/voucher spend if you
        want visibility. Total take rate often lands in the 10–15% range for promoted sellers.
      </p>
    </section>

    <section>
      <h2>Lazada</h2>
      <p>
        Lazada (Alibaba) was Vietnam's first major Southeast-Asian marketplace and remains the
        most credible authorized-brand channel. LazMall is its verified-brand storefront —
        sellers must prove brand ownership or distributor authorization, and buyers get a
        100% authentic guarantee. That positioning makes Lazada the preferred venue for global
        brands entering Vietnam directly rather than via gray-market resellers.
      </p>
      <p>
        <strong>Cross-border strength:</strong> Lazada inherits Alibaba's cross-border tooling,
        making imports from Chinese sellers smoother than on most competing platforms. For
        mid-premium categories — beauty, mother-and-baby, branded electronics — Lazada often
        beats Shopee on conversion despite smaller traffic. Note the scale gap, though: Lazada's
        overall marketplace share collapsed to low single digits in 2025 as TikTok Shop absorbed
        most of the mid-market, so treat it as a targeted authorized-brand channel, not a volume play.
      </p>
    </section>

    <section>
      <h2>TikTok Shop</h2>
      <p>
        TikTok Shop launched in Vietnam in mid-2022 and grew faster than any e-commerce
        platform in Vietnamese history. Its native advantage is the for-you feed: product
        discovery happens inside short videos and livestreams, with one-tap checkout. Sellers
        and creators converge — a category influencer can promote a product mid-livestream and
        the viewer buys without leaving TikTok.
      </p>
      <p>
        <strong>What works:</strong> Categories that demonstrate well on video — fashion try-ons,
        beauty swatches, FMCG novelty products, low-ticket impulse buys. <strong>What doesn't (yet):</strong>
        high-consideration purchases, complex configurations, premium electronics where
        comparison shopping matters.
      </p>
    </section>

    <section>
      <h2>How to choose</h2>
      <ul>
        <li><strong>Volume-first general merchandise:</strong> Start with Shopee. The combination of free shipping, daily campaigns, and largest user base is hard to match for SKUs that compete on price.</li>
        <li><strong>Authorized brand entering Vietnam:</strong> Prioritize LazMall on Lazada — the authenticity signal materially affects conversion in beauty, fashion, electronics, and mother-and-baby categories.</li>
        <li><strong>Category demos well on video:</strong> Add TikTok Shop. Even as a secondary channel, livestream commerce can drive disproportionate volume during creator collaborations.</li>
        <li><strong>Realistic answer:</strong> Most serious sellers list on at least two of the three platforms and let the channel mix find its level. Shopee + TikTok Shop is a common pairing for value SKUs; Lazada + TikTok Shop is common for premium positioning.</li>
      </ul>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer-container">
              <p class="faq-answer">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/data/vietnam-ecommerce-platform-shares/">E-commerce platform shares 2025 — the underlying dataset</a></li>
        <li><a href="/compare/tiktok-shop-vs-shopee/">TikTok Shop vs Shopee</a> · <a href="/compare/lazada-vs-shopee/">Lazada vs Shopee</a> (head-to-head)</li>
        <li><a href="/ecommerce/">Vietnam E-commerce Market — full overview</a></li>
        <li><a href="/glossary/marketplace/">Marketplace (glossary)</a> · <a href="/glossary/gmv/">GMV (glossary)</a> · <a href="/glossary/live-commerce/">Live commerce (glossary)</a></li>
        <li><a href="/compare/momo-vs-zalopay-vs-viettelpay/">MoMo vs ZaloPay vs ViettelPay — wallet comparison</a></li>
        <li><a href="/insights/ecommerce-vietnam/">E-commerce in Vietnam — insights article</a></li>
        <li><a href="/insights/social-live-commerce/">Social and live commerce — insights article</a></li>
      </ul>
    </section>

    <p class="compare-footer">
      <a href="/ecommerce/">← E-commerce overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .compare-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .compare-header { margin-bottom: var(--space-8); }
  .compare-header h1 { border: none; margin-bottom: var(--space-3); }
  .compare-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .compare-table-wrap { overflow-x: auto; margin: var(--space-4) 0; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); background: var(--color-bg); }
  .compare-table th, .compare-table td { border: 1px solid var(--color-border-light); padding: var(--space-3) var(--space-4); text-align: left; vertical-align: top; }
  .compare-table thead th { background: var(--color-bg-subtle); font-weight: 600; }
  .compare-table tbody th { background: var(--color-bg-subtle); font-weight: 500; white-space: nowrap; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .compare-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .compare-footer a { color: var(--color-text-muted); }
  .compare-footer a:hover { color: var(--color-accent); }
</style>
