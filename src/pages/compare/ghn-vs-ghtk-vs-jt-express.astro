---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "GHN vs GHTK vs J&T Express — Vietnam Last-Mile Delivery Comparison (2026)";
const description = "Side-by-side comparison of GHN, GHTK, and J&T Express in Vietnam. Ownership, coverage, pricing, delivery speed, COD handling, and which carrier fits which seller.";
const canonical = "https://vnmarketinsights.com/compare/ghn-vs-ghtk-vs-jt-express/";

const carriers = [
  {
    name: 'GHN',
    fullName: 'Giao Hàng Nhanh',
    parent: 'Scommerce (backed by Temasek, others)',
    launched: '2012',
    coverage: 'Nationwide; strong in HCMC, Hanoi metros',
    pricing: 'Weight + zone based; mid-market rates',
    speed: '1–2 days intra-city; 2–4 days inter-region',
    cod: 'Full COD with fast remittance cycles',
    bestFor: 'Mid-to-large sellers wanting balanced speed and reliability',
  },
  {
    name: 'GHTK',
    fullName: 'Giao Hàng Tiết Kiệm',
    parent: 'Independent (VNG, others as investors)',
    launched: '2013',
    coverage: 'Nationwide; deep rural and tier-2/3 reach',
    pricing: 'Flat-rate friendly; among the cheapest for light parcels',
    speed: '2–4 days typical; slower to remote areas',
    cod: 'Full COD; popular with small Facebook/Shopee sellers',
    bestFor: 'Price-sensitive small sellers, light parcels, broad reach',
  },
  {
    name: 'J&T Express',
    fullName: 'J&T Express',
    parent: 'J&T Global (Indonesia/China origin)',
    launched: '2018 (Vietnam)',
    coverage: 'Nationwide; rapid hub expansion',
    pricing: 'Aggressive promotional pricing; competitive on volume',
    speed: '1–3 days metros; 2–5 days inter-region',
    cod: 'Full COD; integrated with major marketplaces',
    bestFor: 'High-volume marketplace sellers chasing low unit cost',
  },
];

const faqs = [
  {
    question: "Which delivery carrier is cheapest in Vietnam?",
    answer: "For light parcels and small sellers, GHTK (Giao Hàng Tiết Kiệm — literally 'economical delivery') is typically the cheapest, with flat-rate-friendly pricing built for low-value e-commerce parcels. J&T Express competes aggressively on price for high-volume marketplace sellers through promotional rates. GHN sits in the mid-market — not the cheapest, but balanced on speed and reliability."
  },
  {
    question: "How fast is GHN delivery?",
    answer: "GHN (Giao Hàng Nhanh — 'fast delivery') typically delivers within 1–2 days inside the same city (HCMC or Hanoi) and 2–4 days between regions. It positions itself on speed and tracking reliability rather than rock-bottom price, which makes it popular with mid-to-large sellers who care about delivery experience."
  },
  {
    question: "Do GHN, GHTK, and J&T all handle cash on delivery (COD)?",
    answer: "Yes. All three carriers offer full cash-on-delivery service, which remains central to Vietnamese e-commerce — a large share of orders are still paid in cash at the door. They differ mainly in COD remittance speed (how quickly the collected cash is paid back to the seller); GHN and J&T generally cycle faster, while GHTK is favored by small sellers for ease of use."
  },
  {
    question: "Which carrier do Shopee and Lazada use in Vietnam?",
    answer: "Shopee primarily routes through its own SPX Express but also integrates GHN, GHTK, and J&T as selectable options. Lazada uses its in-house LEX network plus third-party carriers. TikTok Shop relies heavily on GHN, GHTK, J&T, and Ninja Van. In practice all three carriers in this comparison are integrated across the major marketplaces, so sellers can often choose at checkout or in seller settings."
  },
  {
    question: "What is the difference between GHN and GHTK?",
    answer: "GHN (Giao Hàng Nhanh) optimizes for speed and delivery experience with mid-market pricing, appealing to larger and brand-conscious sellers. GHTK (Giao Hàng Tiết Kiệm) optimizes for cost and rural reach, making it the default for price-sensitive micro-sellers shipping light parcels. The names literally translate to 'fast delivery' versus 'economical delivery,' which captures their positioning."
  },
  {
    question: "Is J&T Express reliable in Vietnam?",
    answer: "J&T Express entered Vietnam in 2018 and scaled rapidly through heavy investment in sorting hubs and marketplace integrations. It is now one of the largest carriers by parcel volume, competitive on price and metro speed. As with any fast-scaling network, service consistency can vary by region and peak season, but it is a mainstream, marketplace-integrated option."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Comparison"
  publishedDate="2026-05-30"
  lastUpdated="2026-05-30"
  structuredData={faqSchema}
  mainClass="container"
>
  <article class="compare-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/logistics/">Logistics</a>
      <span aria-hidden="true">/</span>
      <span>Carrier Comparison</span>
    </nav>

    <header class="compare-header">
      <h1>{title}</h1>
      <p class="compare-lead">
        GHN, GHTK, and J&T Express are three of the largest last-mile delivery carriers powering
        Vietnam's e-commerce boom. This page compares them on ownership, coverage, pricing model,
        delivery speed, and cash-on-delivery handling — and explains which carrier suits which
        type of seller. Figures are 2024–2025 reference estimates; exact rates and SLAs vary by
        route, weight, and contract.
      </p>
    </header>

    <section>
      <h2>At a glance</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Dimension</th>
              {carriers.map(c => <th>{c.name}</th>)}
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Full name</th>
              {carriers.map(c => <td>{c.fullName}</td>)}
            </tr>
            <tr>
              <th>Parent / backing</th>
              {carriers.map(c => <td>{c.parent}</td>)}
            </tr>
            <tr>
              <th>Launched (VN)</th>
              {carriers.map(c => <td>{c.launched}</td>)}
            </tr>
            <tr>
              <th>Coverage</th>
              {carriers.map(c => <td>{c.coverage}</td>)}
            </tr>
            <tr>
              <th>Pricing</th>
              {carriers.map(c => <td>{c.pricing}</td>)}
            </tr>
            <tr>
              <th>Typical speed</th>
              {carriers.map(c => <td>{c.speed}</td>)}
            </tr>
            <tr>
              <th>COD</th>
              {carriers.map(c => <td>{c.cod}</td>)}
            </tr>
            <tr>
              <th>Best for</th>
              {carriers.map(c => <td>{c.bestFor}</td>)}
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>GHN (Giao Hàng Nhanh)</h2>
      <p>
        GHN, part of the Scommerce group, is one of Vietnam's longest-running e-commerce
        couriers, founded in 2012. Its name translates to "fast delivery," and that is the
        positioning: GHN competes on speed, tracking quality, and delivery reliability rather
        than the absolute lowest price. Intra-city deliveries in HCMC and Hanoi typically land
        within 1–2 days, with inter-region shipments at 2–4 days.
      </p>
      <p>
        <strong>Who it fits:</strong> Mid-to-large sellers and brands that treat delivery
        experience as part of their product. GHN's automated sorting and broad metro density
        make it a dependable default for sellers shipping meaningful daily volume who want fewer
        failed deliveries and faster COD remittance cycles.
      </p>
    </section>

    <section>
      <h2>GHTK (Giao Hàng Tiết Kiệm)</h2>
      <p>
        GHTK — "economical delivery" — launched in 2013 and built its business around the
        long tail of Vietnamese e-commerce: individual sellers on Facebook, Shopee, and TikTok
        shipping light, low-value parcels. Its flat-rate-friendly pricing is among the cheapest
        in the market for small packages, and it invested early in rural and tier-2/3 coverage
        that bigger carriers were slower to reach.
      </p>
      <p>
        <strong>Who it fits:</strong> Price-sensitive micro and small sellers, anyone shipping
        light parcels at scale, and merchants serving rural buyers. The trade-off is speed —
        GHTK is generally slower than GHN or J&T in metros, and slower still to remote areas —
        but for cost-led businesses the savings outweigh the extra day.
      </p>
    </section>

    <section>
      <h2>J&T Express</h2>
      <p>
        J&T Express entered Vietnam in 2018 and scaled faster than almost any carrier before it,
        backed by deep capital and an aggressive hub-building strategy across Southeast Asia.
        It competes hard on promotional pricing for high-volume marketplace sellers and has
        deep integrations with Shopee, Lazada, and TikTok Shop. Metro speeds (1–3 days) are
        competitive with GHN.
      </p>
      <p>
        <strong>Who it fits:</strong> High-volume marketplace sellers optimizing for low unit
        shipping cost, especially those already operating inside Shopee or TikTok Shop where
        J&T is a one-click option. As with any rapidly scaled network, regional service
        consistency and peak-season performance are worth monitoring.
      </p>
    </section>

    <section>
      <h2>How to choose</h2>
      <ul>
        <li><strong>Cheapest for light parcels:</strong> GHTK. Its economical flat-rate model and rural reach make it the default for micro-sellers and price-led businesses.</li>
        <li><strong>Best delivery experience:</strong> GHN. If failed deliveries, tracking quality, and fast COD remittance matter to your brand, GHN earns its mid-market premium.</li>
        <li><strong>Lowest cost at high volume:</strong> J&T Express. Promotional volume pricing plus tight marketplace integration suit sellers pushing large daily order counts.</li>
        <li><strong>Realistic answer:</strong> Many sellers split shipments across carriers by route and parcel type — GHTK for cheap light parcels and rural addresses, GHN for time-sensitive or higher-value orders, J&T for marketplace-default volume. Most marketplace seller dashboards let you pick per order.</li>
      </ul>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer-container">
              <p class="faq-answer">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/logistics/">Vietnam Logistics &amp; Delivery — full overview</a></li>
        <li><a href="/glossary/cod/">Cash on Delivery (glossary)</a> · <a href="/glossary/last-mile-delivery/">Last-mile delivery (glossary)</a></li>
        <li><a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">Shopee vs Lazada vs TikTok Shop — platform comparison</a></li>
        <li><a href="/compare/momo-vs-zalopay-vs-viettelpay/">MoMo vs ZaloPay vs ViettelPay — wallet comparison</a></li>
        <li><a href="/insights/logistics-last-mile/">Logistics &amp; last-mile delivery — insights article</a></li>
      </ul>
    </section>

    <p class="compare-footer">
      <a href="/logistics/">← Logistics overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .compare-page { max-width: 860px; }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .compare-header { margin-bottom: var(--space-8); }
  .compare-header h1 { border: none; margin-bottom: var(--space-3); }
  .compare-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .compare-table-wrap { overflow-x: auto; margin: var(--space-4) 0; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); background: var(--color-bg); }
  .compare-table th, .compare-table td { border: 1px solid var(--color-border-light); padding: var(--space-3) var(--space-4); text-align: left; vertical-align: top; }
  .compare-table thead th { background: var(--color-bg-subtle); font-weight: 600; }
  .compare-table tbody th { background: var(--color-bg-subtle); font-weight: 500; white-space: nowrap; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .compare-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .compare-footer a { color: var(--color-text-muted); }
  .compare-footer a:hover { color: var(--color-accent); }
</style>
