---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "Grab vs Be vs Gojek — Vietnam Ride-Hailing & Super-App Comparison (2026)";
const description = "Compare Grab, Be, and Gojek in Vietnam: ownership, services, market position, and why Gojek exited in 2024 — leaving Grab and homegrown Be as the main super-app players.";
const canonical = "https://vnmarketinsights.com/compare/grab-vs-be-vs-gojek/";

const apps = [
  {
    name: 'Grab',
    parent: 'Grab Holdings (Singapore)',
    status: 'Active — market leader',
    services: 'Ride-hailing, food (GrabFood), delivery, GrabPay/Moca wallet, financial services',
    position: 'Dominant regional super-app; widest service breadth and coverage',
    bestFor: 'Users wanting one app for rides, food, and payments nationwide',
  },
  {
    name: 'Be',
    parent: 'Be Group (Vietnam)',
    status: 'Active — strong #2',
    services: 'Ride-hailing, food (beFood), delivery, financial services via partners',
    position: 'Homegrown challenger; nationalist brand appeal and driver-friendly positioning',
    bestFor: 'Users preferring a Vietnamese super-app; competitive ride pricing',
  },
  {
    name: 'Gojek',
    parent: 'GoTo Group (Indonesia)',
    status: 'Exited Vietnam (Sept 2024)',
    services: 'Previously ride-hailing, food, delivery',
    position: 'Withdrew from the Vietnam market in 2024 amid intense competition',
    bestFor: 'No longer operating in Vietnam',
  },
];

const faqs = [
  {
    question: "Is Gojek still available in Vietnam?",
    answer: "No. Gojek (part of Indonesia's GoTo Group) ceased operations in Vietnam in September 2024, exiting the market amid intense competition and a focus on its core markets. Grab and the homegrown app Be are now the main ride-hailing and super-app players in Vietnam."
  },
  {
    question: "Which is the biggest ride-hailing app in Vietnam?",
    answer: "Grab is the market leader in Vietnam, with the widest service breadth (ride-hailing, GrabFood, delivery, and the Moca/GrabPay wallet) and the broadest geographic coverage. Be, a Vietnamese company, is the strong number two, competing on local brand appeal and driver-friendly positioning."
  },
  {
    question: "What is the difference between Grab and Be?",
    answer: "Grab is a Singapore-based regional super-app operating across Southeast Asia, with the deepest feature set and ecosystem in Vietnam. Be is a homegrown Vietnamese super-app that leans on local brand identity, competitive ride pricing, and driver relations. Grab wins on breadth and scale; Be competes on price and national appeal."
  },
  {
    question: "Why did Gojek leave Vietnam?",
    answer: "Gojek exited Vietnam in 2024 after years of intense competition with Grab and Be in a market where achieving profitability proved difficult. The withdrawal reflected a broader strategy by parent GoTo to concentrate resources on its strongest markets, primarily Indonesia."
  },
  {
    question: "Do these apps include digital wallets?",
    answer: "Grab integrates Moca/GrabPay for in-app payments and broader financial services. Be offers financial services through partners. With Gojek's exit, its GoPay-style features are no longer relevant in Vietnam. For dedicated e-wallets, MoMo, ZaloPay, and ViettelPay remain the market leaders."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Comparison"
  publishedDate="2026-05-30"
  lastUpdated="2026-05-30"
  structuredData={faqSchema}
  mainClass="container"
>
  <article class="compare-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/platforms/">Platforms</a>
      <span aria-hidden="true">/</span>
      <span>Super-App Comparison</span>
    </nav>

    <header class="compare-header">
      <h1>{title}</h1>
      <p class="compare-lead">
        Vietnam's ride-hailing and super-app market was long a three-way fight between Grab, the
        homegrown Be, and Indonesia's Gojek — until Gojek exited the market in September 2024. This
        page compares all three on ownership, services, and market position, and explains the
        current landscape: a Grab-versus-Be contest. Details reflect 2024–2025 reference estimates.
      </p>
    </header>

    <section>
      <h2>At a glance</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Dimension</th>
              {apps.map(a => <th>{a.name}</th>)}
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Parent</th>
              {apps.map(a => <td>{a.parent}</td>)}
            </tr>
            <tr>
              <th>Status (2026)</th>
              {apps.map(a => <td>{a.status}</td>)}
            </tr>
            <tr>
              <th>Services</th>
              {apps.map(a => <td>{a.services}</td>)}
            </tr>
            <tr>
              <th>Market position</th>
              {apps.map(a => <td>{a.position}</td>)}
            </tr>
            <tr>
              <th>Best for</th>
              {apps.map(a => <td>{a.bestFor}</td>)}
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>Grab</h2>
      <p>
        Grab is Vietnam's ride-hailing and <a href="/glossary/super-app/">super-app</a> leader,
        part of Singapore-listed Grab Holdings. Beyond rides, it bundles GrabFood, package
        delivery, and the Moca/GrabPay wallet into a single ecosystem — the broadest service set
        and widest coverage in the country. Its scale and cross-service network effects make it the
        default choice for users who want one app for rides, food, and payments.
      </p>
    </section>

    <section>
      <h2>Be</h2>
      <p>
        Be is the homegrown Vietnamese challenger, operated by Be Group. It has built a durable
        number-two position on national brand appeal, competitive ride pricing, and driver-friendly
        positioning, expanding from ride-hailing into food (beFood), delivery, and partner-based
        financial services. For many Vietnamese users, Be is the preferred local alternative to a
        foreign-owned platform.
      </p>
    </section>

    <section>
      <h2>Gojek (exited 2024)</h2>
      <p>
        Gojek, part of Indonesia's GoTo Group, competed in Vietnam for years before ceasing
        operations in September 2024. Despite a recognizable brand and strong home-market
        playbook, sustained competition with Grab and Be made profitability hard, and GoTo
        refocused on its core markets. Gojek is no longer an option for Vietnamese riders or
        merchants — the market is now effectively a Grab-versus-Be contest.
      </p>
    </section>

    <section>
      <h2>How to choose</h2>
      <ul>
        <li><strong>Breadth and coverage:</strong> Grab — the widest service set, nationwide reach, and integrated wallet/financial services.</li>
        <li><strong>Local brand and price:</strong> Be — a homegrown super-app competing on ride pricing and Vietnamese identity.</li>
        <li><strong>Gojek:</strong> No longer operating in Vietnam since 2024; not a current option.</li>
        <li><strong>Reality:</strong> Most active users keep both Grab and Be installed and switch based on price, ETA, and availability for a given trip or order.</li>
      </ul>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer-container">
              <p class="faq-answer">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Related references</h2>
      <ul class="related-list">
        <li><a href="/platforms/">Vietnam digital platforms — overview</a></li>
        <li><a href="/compare/momo-vs-zalopay-vs-viettelpay/">MoMo vs ZaloPay vs ViettelPay — wallet comparison</a></li>
        <li><a href="/glossary/super-app/">Super-app (glossary)</a> · <a href="/glossary/grab/">Grab (glossary)</a> · <a href="/glossary/moca/">Moca (glossary)</a></li>
        <li><a href="/stats/vietnam-digital-payments-2026/">Vietnam Digital Payments Statistics 2026</a></li>
      </ul>
    </section>

    <p class="compare-footer">
      <a href="/platforms/">← Platforms overview</a> · <a href="/sources/">Data sources</a>
    </p>
  </article>
</BaseLayout>

<style>
  .compare-page { max-width: 860px; }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .compare-header { margin-bottom: var(--space-8); }
  .compare-header h1 { border: none; margin-bottom: var(--space-3); }
  .compare-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .compare-table-wrap { overflow-x: auto; margin: var(--space-4) 0; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); background: var(--color-bg); }
  .compare-table th, .compare-table td { border: 1px solid var(--color-border-light); padding: var(--space-3) var(--space-4); text-align: left; vertical-align: top; }
  .compare-table thead th { background: var(--color-bg-subtle); font-weight: 600; }
  .compare-table tbody th { background: var(--color-bg-subtle); font-weight: 500; white-space: nowrap; }
  section p a { color: var(--color-accent); }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .compare-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .compare-footer a { color: var(--color-text-muted); }
  .compare-footer a:hover { color: var(--color-accent); }
</style>
