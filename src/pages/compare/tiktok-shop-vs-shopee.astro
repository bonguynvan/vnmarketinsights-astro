---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = "TikTok Shop vs Shopee in Vietnam (2026) — Which to Sell On?";
const description = "TikTok Shop vs Shopee in Vietnam: market share, content vs search-driven selling, seller economics, live commerce, logistics, and which platform fits your products.";
const canonical = "https://vnmarketinsights.com/compare/tiktok-shop-vs-shopee/";

const rows = [
  ['Parent', 'ByteDance (China)', 'Sea Group (Singapore)'],
  ['Launched (VN)', '2022', '2016'],
  ['Model', 'Content & livestream-driven discovery', 'Search & promotion-driven marketplace'],
  ['Market share (GMV)', 'Fast-growing (~28% → ~41% in 2025)', 'Leader (~65% → ~56% in 2025)'],
  ['Strength', 'Short-video + live commerce, creators', 'Reach, intent-driven search, SPX logistics'],
  ['Best for', 'Fashion, beauty, FMCG that demo on video', 'Broad catalog, repeat & considered purchases'],
];

const faqs = [
  {
    question: "Is TikTok Shop bigger than Shopee in Vietnam?",
    answer: "Not yet, but the gap is closing fast. Shopee remains the largest marketplace, though its share eased toward ~56% in 2025 while TikTok Shop surged toward ~41% (up roughly 69% year on year, by Metric estimates). TikTok Shop has overtaken Lazada and is now Shopee's main challenger.",
  },
  {
    question: "What is the difference between TikTok Shop and Shopee?",
    answer: "Shopee is a search- and promotion-driven marketplace: buyers arrive with intent and compare on price and vouchers. TikTok Shop is content-driven: demand is created in-feed through short videos and livestreams, often impulse-led. Shopee rewards catalog breadth and ad/voucher spend; TikTok Shop rewards creative, creators, and livestream operations.",
  },
  {
    question: "Which is better for new sellers in Vietnam?",
    answer: "It depends on the product. Visual, demo-friendly categories (fashion, beauty, accessories, FMCG novelties) often find the cheapest demand on TikTok Shop via livestreams and creator affiliates. Broad or considered-purchase catalogs usually do better on Shopee's high-intent search. Many sellers run both and route each SKU to where it converts.",
  },
  {
    question: "Do TikTok Shop and Shopee handle logistics?",
    answer: "Shopee operates its own SPX Express network plus integrated carriers. TikTok Shop integrates third-party couriers (GHN, GHTK, J&T, Ninja Van) and is expanding fulfillment support. Same-day and next-day delivery are standard in Hanoi and HCMC; tier-2/3 cities typically see 2–4 days on both.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer } })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonical}
  pageType="Article"
  articleSection="Comparison"
  publishedDate="2026-06-22"
  lastUpdated="2026-06-22"
  structuredData={faqSchema}
  mainClass="container"
>
  <article class="compare-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> <span aria-hidden="true">/</span>
      <a href="/ecommerce/">E-commerce</a> <span aria-hidden="true">/</span>
      <span>TikTok Shop vs Shopee</span>
    </nav>

    <header class="compare-header">
      <span class="kicker">Comparison · 2026</span>
      <h1>{title}</h1>
      <p class="compare-lead">
        Shopee is Vietnam's marketplace leader; TikTok Shop is its fastest-growing challenger. The
        core difference is how demand is created — search and promotions versus short-video and
        livestreams. Here's how they compare and which fits your products. Figures are 2024–2025
        reference estimates. For the three-way picture, see
        <a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">Shopee vs Lazada vs TikTok Shop</a>.
      </p>
    </header>

    <section>
      <h2>At a glance</h2>
      <div class="compare-table-wrap">
        <table class="compare-table">
          <thead><tr><th>Dimension</th><th>TikTok Shop</th><th>Shopee</th></tr></thead>
          <tbody>
            {rows.map(([dim, tt, sp]) => (
              <tr><th>{dim}</th><td>{tt}</td><td>{sp}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>Shopee — intent-driven scale</h2>
      <p>
        Shopee (Sea Group) is where buyers go with purchase intent, comparing on price, reviews, and
        vouchers. Its promotion engine and SPX Express logistics make it the default for broad
        catalogs and repeat purchases — but visibility increasingly requires ad and voucher spend.
      </p>
    </section>

    <section>
      <h2>TikTok Shop — content-driven demand</h2>
      <p>
        TikTok Shop (ByteDance) creates demand inside the feed: creators and livestreams turn
        discovery into impulse purchases. It over-indexes on fashion, beauty, and FMCG, and offers
        the lowest-cost path to demand for products that demonstrate well on video — provided you can
        run creative and livestream operations.
      </p>
    </section>

    <section>
      <h2>Which should you choose?</h2>
      <ul class="related-list">
        <li><strong>Pick TikTok Shop</strong> for visual, demo-friendly products and creator/livestream selling.</li>
        <li><strong>Pick Shopee</strong> for broad catalogs and high-intent, considered purchases.</li>
        <li><strong>Run both</strong> and route each SKU to the channel where it converts best.</li>
      </ul>
    </section>

    <section>
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-question">{f.question}</summary>
            <div class="faq-answer-container"><p class="faq-answer">{f.answer}</p></div>
          </details>
        ))}
      </div>
    </section>

    <section>
      <h2>Related</h2>
      <ul class="related-list">
        <li><a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">Shopee vs Lazada vs TikTok Shop (3-way)</a></li>
        <li><a href="/guides/how-to-sell-on-tiktok-shop-vietnam/">How to sell on TikTok Shop Vietnam</a> · <a href="/guides/top-affiliate-niches-vietnam/">Top affiliate niches</a></li>
      </ul>
    </section>

    <p class="compare-footer"><a href="/compare/shopee-vs-lazada-vs-tiktok-shop/">← All platform comparisons</a></p>
  </article>
</BaseLayout>

<style>
  .compare-page { max-width: var(--reading-width); }
  .breadcrumb { display: flex; gap: var(--space-2); align-items: center; flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); text-decoration: underline; }
  .compare-header { margin-bottom: var(--space-8); }
  .compare-header h1 { border: none; margin: var(--space-2) 0 var(--space-3); }
  .compare-lead { font-size: var(--text-lg); line-height: 1.6; color: var(--color-text); }
  .compare-table-wrap { overflow-x: auto; margin: var(--space-4) 0; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); background: var(--color-bg); }
  .compare-table th, .compare-table td { border: 1px solid var(--color-border-light); padding: var(--space-3) var(--space-4); text-align: left; vertical-align: top; }
  .compare-table thead th { background: var(--color-bg-subtle); font-weight: 600; }
  .compare-table tbody th { background: var(--color-bg-subtle); font-weight: 500; white-space: nowrap; }
  .faq-list { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-bg-subtle); }
  .faq-question { cursor: pointer; padding: 1rem 1.25rem; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; float: right; color: var(--color-text-muted); }
  .faq-item[open] .faq-question::after { content: '−'; }
  .faq-answer-container { padding: 0 1.25rem 1rem; border-top: 1px solid var(--color-border-light); }
  .faq-answer { margin: 1rem 0 0; color: var(--color-text); line-height: 1.65; }
  .related-list { list-style: none; padding: 0; margin: var(--space-4) 0; }
  .related-list li { margin-bottom: var(--space-2); line-height: 1.55; }
  .related-list a { color: var(--color-accent); text-decoration: none; }
  .related-list a:hover { text-decoration: underline; }
  .compare-footer { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
  .compare-footer a { color: var(--color-text-muted); }
  .compare-footer a:hover { color: var(--color-accent); }
</style>
