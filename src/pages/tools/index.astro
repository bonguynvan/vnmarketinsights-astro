---
import BaseLayout from '@layouts/BaseLayout.astro';
import GrowthJourneyPanel from '@components/GrowthJourneyPanel.astro';
import Icon from '@components/Icon.astro';

const tools = [
  { href: '/snapshot', icon: 'camera', title: 'Website Snapshot', description: 'Detect tech stack and SEO score for any Vietnamese domain.' },
  { href: '/research', icon: 'cpu', title: 'Market Research', description: 'Ask a question about Vietnam’s market and get a concise, cited answer.' },
  { href: '/data', icon: 'database', title: 'Data & Benchmarks', description: 'Free, sourced, date-stamped datasets — e-commerce platform shares, with more to come.' },
  { href: '/markets', icon: 'bar-chart', title: 'Stock Outlook Board', description: 'Rules-based technical outlook for 20 large-cap Vietnamese stocks.' },
  { href: '/trends', icon: 'trending-up', title: 'Trend Radar', description: 'Topic momentum across Vietnam market news — weekly mention volume, growth, and sentiment.' },
  { href: '/keywords', icon: 'search', title: 'Keyword Miner', description: 'Explore related search terms from a seed keyword. Illustrative demo data for now — real keyword API coming.' },
];
---

<BaseLayout
  title="Tools & Data"
  description="Free tools and datasets for Vietnam market: website snapshot, market research, stock board, trend radar, keyword miner, and sourced benchmark datasets."
  canonicalURL="https://vnmarketinsights.com/tools/"
  mainClass="container-wide"
>
  <article class="tools-page">
    <GrowthJourneyPanel title="Your tool adoption progress" />
    <header class="tools-header">
      <h1>Market Tools &amp; Data</h1>
      <p class="tools-lead">Analyze sites, research the market, track stocks and trends, and pull sourced benchmark datasets. All tools are free; we're adding more over time.</p>
      <a href="/snapshot" class="tools-primary-cta" data-track-event="tools_primary_cta_click" data-track-category="acquisition" data-track-label="start_snapshot">Start with Website Snapshot</a>
      <p class="tools-sublead">No signup required. Typical time-to-first-result: under 2 minutes.</p>
    </header>

    <section class="tools-grid-section">
      <div class="tools-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card" data-track-event="tools_hub_click" data-track-category="acquisition" data-track-label={tool.href}>
            <div class="tool-icon"><Icon name={tool.icon} size={28} /></div>
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="tools-cross-links">
      <h2>Need market context before using tools?</h2>
      <p>Use reference pages first, then come back with better hypotheses.</p>
      <div class="tools-cross-links__actions">
        <a href="/topics" data-track-event="tools_crosslink_click" data-track-label="topics">Explore topics</a>
        <a href="/insights" data-track-event="tools_crosslink_click" data-track-label="insights">Read insights</a>
        <a href="/start" data-track-event="tools_crosslink_click" data-track-label="starter_flows">Open starter flows</a>
        <a href="/workspace" data-track-event="tools_crosslink_click" data-track-label="workspace">Open workspace</a>
      </div>
    </section>

    <p class="tools-footer-note">
      <a href="/" data-track-event="tools_footer_click" data-track-label="home">Home</a> · <a href="/topics" data-track-event="tools_footer_click" data-track-label="topics">Topics</a>
    </p>
  </article>
</BaseLayout>

<style>
  .tools-page { }
  .tools-header { margin-bottom: var(--space-10); }
  .tools-header h1 { margin-bottom: var(--space-3); border: none; }
  .tools-lead { color: var(--color-text-muted); font-size: var(--text-lg); max-width: 640px; }
  .tools-primary-cta {
    display: inline-flex;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-5);
    border-radius: 999px;
    background: #1a1a1a;
    color: white;
    text-decoration: none;
    font-weight: 600;
  }
  .tools-primary-cta:hover { color: white; text-decoration: none; background: #000; }
  .tools-sublead { margin-top: var(--space-3); color: var(--color-text-light); font-size: var(--text-sm); }
  .tools-grid-section { margin: var(--space-8) 0; }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-top: 2px solid var(--color-ink);
    border-radius: 2px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease;
  }
  .tool-card:hover {
    border-color: var(--color-accent);
    border-top-color: var(--color-accent);
  }
  .tool-icon {
    width: 50px;
    height: 50px;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    background: var(--color-bg-subtle);
  }
  .tool-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .tool-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .tools-cross-links { margin-top: var(--space-10); padding: var(--space-6); border-radius: 2px; background: var(--color-bg-subtle); }
  .tools-cross-links h2 { margin-top: 0; border: none; }
  .tools-cross-links p { color: var(--color-text-muted); margin-bottom: var(--space-4); }
  .tools-cross-links__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); font-weight: 500; }
  .tools-footer-note { margin-top: var(--space-10); font-size: var(--text-sm); color: var(--color-text-muted); }
</style>
