---
import TopicLayout from '../layouts/TopicLayout.astro';
import BarChart from '../components/BarChart.astro';
import RecentDevelopments from '../components/RecentDevelopments.astro';
import { getRelatedTopics } from '../data/topic-graph';

const title = "Vietnam Retail Market 2026 — Size, Modern Trade & Players";
const lastUpdated = "June 2026";
const description = "Vietnam retail market report: total retail sales, modern vs traditional trade, grocery and convenience chains, key players, and 2025 data with sources.";
const canonicalURL = "https://vnmarketinsights.com/retail";

const relatedTopics = getRelatedTopics('retail');

const faqs = [
  {
    question: "How big is Vietnam's retail market?",
    answer: "Total retail sales of consumer goods and services reached an estimated VND 7,009 trillion (about US$270 billion) in 2025, up roughly 10% year on year — among the fastest growth in five years. Retail of goods made up about 76% (~US$206 billion), with services the remainder.",
  },
  {
    question: "What is the split between modern and traditional trade in Vietnam?",
    answer: "Traditional trade — wet markets and family-run shops — still accounts for the majority of grocery sales, but modern trade (supermarkets, minimarkets, convenience stores, and e-commerce) is growing faster, especially in cities. Domestic chains have been gaining share, including through M&A.",
  },
  {
    question: "Who are the largest retailers in Vietnam?",
    answer: "Major grocery and general retailers include WinCommerce (WinMart / WinMart+), Bach Hoa Xanh (Mobile World Group), Saigon Co.op (Co.opmart), Central Retail (GO! / Big C), AEON, MM Mega Market, and Lotte Mart. Convenience leaders include Circle K, GS25, Ministop, and 7-Eleven.",
  },
  {
    question: "How does e-commerce fit into Vietnam retail?",
    answer: "E-commerce is the fastest-growing retail channel, at roughly 10% of total retail sales in 2025 and rising. Many shoppers blend online and offline — discovering on social and livestream, then buying via marketplaces or in store.",
  },
];
---

<TopicLayout title={title} description={description} lastUpdated={lastUpdated} canonicalURL={canonicalURL} articleSection="Retail" faqs={faqs} relatedTopics={relatedTopics}>
  <section>
    <h2>Overview</h2>
    <p class="topic-definition">
      <strong>Vietnam's retail market</strong> covers the sale of consumer goods and services through
      both <strong>traditional trade</strong> (wet markets, family-run stores) and <strong>modern
      trade</strong> (supermarkets, minimarkets, convenience stores, and e-commerce). Total retail
      sales of goods and consumer services reached an estimated <strong>VND 7,009 trillion (~$270
      billion) in 2025</strong>, up about 10% year on year — among the fastest growth in five years.
      Retail of goods accounted for roughly <strong>76%</strong> (~$206 billion), with services the rest.
    </p>
  </section>

  <section>
    <h2>Market composition (2025)</h2>
    <BarChart
      title="Retail sales by type (share of total)"
      unit="%"
      data={[
        { label: 'Goods', value: 76.2, display: '76.2%' },
        { label: 'Services (food, travel, other)', value: 23.8, display: '23.8%' },
      ]}
      source="GSO / NSO, 2025"
      caption="Total retail sales of goods and consumer services ≈ $270B in 2025 (+10% YoY)."
    />
  </section>

  <section>
    <h2>Modern vs traditional trade</h2>
    <ul class="characteristics-list">
      <li><strong>Traditional trade</strong> still dominates grocery, especially outside the big cities — convenient, cash-friendly, and deeply local.</li>
      <li><strong>Modern trade</strong> (supermarkets, minimarkets, convenience) is growing faster, concentrated in Hanoi and Ho Chi Minh City and expanding into tier-2/3 provinces.</li>
      <li><strong>Domestic chains</strong> have been gaining share, including via mergers and acquisitions and rapid minimart rollouts.</li>
      <li><strong>E-commerce</strong> is the fastest-growing channel at roughly 10% of total retail and rising.</li>
    </ul>
  </section>

  <section>
    <h2>Major players</h2>
    <h3>Grocery & general retail</h3>
    <ul>
      <li><strong>WinCommerce</strong> — WinMart / WinMart+ (Masan); large minimart footprint</li>
      <li><strong>Bach Hoa Xanh</strong> — grocery chain of Mobile World Group (MWG)</li>
      <li><strong>Saigon Co.op</strong> — Co.opmart, a leading domestic cooperative</li>
      <li><strong>Central Retail</strong> — GO! / Big C (Thai-owned)</li>
      <li><strong>AEON</strong>, <strong>MM Mega Market</strong>, <strong>Lotte Mart</strong> — foreign hypermarket / wholesale operators</li>
    </ul>
    <h3>Convenience</h3>
    <ul>
      <li><strong>Circle K</strong>, <strong>GS25</strong>, <strong>Ministop</strong>, <strong>7-Eleven</strong> — urban convenience networks</li>
    </ul>
  </section>

  <section>
    <h2>Why this matters</h2>
    <ul class="characteristics-list">
      <li>Retail is a large share of GDP and a direct read on domestic consumption.</li>
      <li>The online–offline blend means retail, <a href="/ecommerce/">e-commerce</a>, <a href="/payments/">payments</a>, and <a href="/logistics/">logistics</a> strategies must be planned together.</li>
      <li>Modern-trade expansion and domestic-chain consolidation are reshaping route-to-market for brands.</li>
    </ul>
  </section>

  <section>
    <h2>Sources</h2>
    <ul class="sources-list">
      <li>General Statistics Office / National Statistics Office of Vietnam — retail sales of goods and services, 2025</li>
      <li>The Investor / Vietnam News — 2025 retail market value and growth</li>
    </ul>
  </section>

  <RecentDevelopments topic="ecommerce" title="Recent retail & commerce developments" />
</TopicLayout>
