# =============================================================================
# VNMarket Astro — environment sample
# Copy to `.env` for local dev. In production the SITE runs on Vercel:
# set the "Site" vars in Vercel → Project → Settings → Environment Variables.
#
# The news PIPELINE runs on GitHub Actions (not the site) — its secrets live in
# GitHub → repo → Settings → Secrets and variables → Actions, and are documented
# separately in `pipeline/.env.example` (ANTHROPIC_API_KEY, TELEGRAM_*, etc.).
# =============================================================================

# ---------------------------------------------------------------------------
# Site (Vercel) — runtime
# ---------------------------------------------------------------------------

# Optional: GA4 measurement ID. Leave empty to disable GA tracking.
PUBLIC_GA_MEASUREMENT_ID=

# Required for /admin/leads and /api/leads/admin. Use a long random secret.
ADMIN_LEADS_KEY=

# Semantic Smart Search: embeds the search query at runtime (Gemini
# gemini-embedding-001, must match the pipeline's embed model/dims). From
# Google AI Studio. Unset = Smart Search falls back to keyword/substring search.
GEMINI_API_KEY=

# Recommended: webhook to persist/forward leads (CRM / email automation / sheet
# worker). Without it, leads use local file storage — not durable on serverless.
LEAD_WEBHOOK_URL=

# Keep false in production. Allows /api/leads/admin?key=... fallback auth if true.
ALLOW_ADMIN_KEY_QUERY=false

# Keep false in production. Exposes the confirmation link in the subscribe API
# response when true.
PUBLIC_EXPOSE_CONFIRM_LINK=false

# ---------------------------------------------------------------------------
# Site (Vercel) — optional integrations (each degrades gracefully when unset)
# ---------------------------------------------------------------------------

# VN Trend microservice base URL (github.com/bonguynvan/vn-trend-service,
# deployed on Coolify/Hetzner). When set, /trends/daily and /api/vn-trends
# consume it server-side. Unset = feature off ("being set up" state).
# e.g. https://api.vnmarketinsights.com
TREND_SERVICE_URL=

# Perplexity Sonar — live-web, cited answers at /research + /api/research.
# Unset = /research falls back to the AI-enriched news-corpus search.
PERPLEXITY_API_KEY=
# Optional model override (default: sonar-pro). e.g. sonar, sonar-pro.
PERPLEXITY_MODEL=

# ---------------------------------------------------------------------------
# Pipeline-only — set as GitHub Actions secrets, NOT here / not in Vercel.
# The website never reads these. Full list + notes: pipeline/.env.example.
# ---------------------------------------------------------------------------

# Claude Haiku enrichment + brief generation. From console.anthropic.com.
ANTHROPIC_API_KEY=

# Daily English headlines push to a public Telegram channel (both required, or
# the step is skipped). Bot must be an admin of the channel.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL=@yourchannel   # or numeric -100... id
