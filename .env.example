# =========================
# VNMarket Astro - Env Sample
# Copy this file to `.env` for local development.
# On Vercel, set these in Project Settings -> Environment Variables.
# =========================

# Optional: GA4 measurement ID. Leave empty to disable GA tracking.
PUBLIC_GA_MEASUREMENT_ID=

# Required for /admin/leads and /api/leads/admin.
# Use a long random secret.
ADMIN_LEADS_KEY=

# Used by the website at runtime for semantic Smart Search (query embedding via
# Gemini text-embedding-004). Set this in Vercel. Get it from Google AI Studio.
GEMINI_API_KEY=

# Pipeline-only (Claude Haiku enrichment + briefs). The website does NOT use it —
# set it as a GitHub Actions secret, not in Vercel. From console.anthropic.com.
ANTHROPIC_API_KEY=

# Recommended: webhook endpoint to persist/forward leads (CRM/email automation/sheet worker).
# Without this, leads rely on local file storage and are not durable on serverless.
LEAD_WEBHOOK_URL=

# Keep false in production. Allows /api/leads/admin?key=... fallback auth if true.
ALLOW_ADMIN_KEY_QUERY=false

# Keep false in production. Exposes confirmation link in subscribe API response when true.
PUBLIC_EXPOSE_CONFIRM_LINK=false

# VN Trend microservice base URL (github.com/bonguynvan/vn-trend-service).
# When set, /trends/daily and /api/vn-trends consume it server-side. Unset = feature off.
TREND_SERVICE_URL=
